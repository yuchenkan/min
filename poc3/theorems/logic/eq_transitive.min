from core.derived import mem, implies, iff, forall
from tactics import close
from theorems.logic.iff_chain import iff_chain

# |- forall a b c z. iff(mem(z,a), mem(z,b)) -> iff(mem(z,b), mem(z,c)) -> iff(mem(z,a), mem(z,c))
$eq_transitive {
    $P mem("z", "a")
    $Q mem("z", "b")
    $R mem("z", "c")
    $formula implies(iff(P, Q), implies(iff(Q, R), iff(P, R)))
    close(iff_chain(P, Q, R, []), [], [formula], ["z", "c", "b", "a"])
}
