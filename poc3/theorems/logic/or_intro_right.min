from core.derived import neg, implies, or
from tactics import ax, wl, ir, close

# |- B -> or(A, B)
$or_intro_right \A B vars: {
    $or_AB or(A, B)
    $na neg(A)
    $s1 wl(ax([B], [B], B), [na, B], [B], na)
    $s2 ir(s1, [B], [or_AB], or_AB)
    $top implies(B, or_AB)
    $s3 ir(s2, [], [top], top)
    close(s3, [top], vars)
}
