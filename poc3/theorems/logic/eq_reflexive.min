from core.derived import mem, implies, iff, forall
from tactics import ax, ir, mp, close
from theorems.logic.iff_intro import iff_intro

# |- forall a. forall z. iff(mem(z, a), mem(z, a))
$eq_reflexive {
    $P mem("z", "a")
    $imp_PP implies(P, P)
    $iff_PP iff(P, P)
    $pp ir(ax([P], [P], P), [], [imp_PP], imp_PP)
    $s1 mp(iff_intro(P, P, []), pp, imp_PP, implies(imp_PP, iff_PP), [], [])
    $got mp(s1, pp, imp_PP, iff_PP, [], [])
    close(got, [iff_PP], ["z", "a"])
}
