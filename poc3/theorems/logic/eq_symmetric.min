from core.derived import mem, implies, iff, forall
from tactics import close
from theorems.logic.iff_sym import iff_sym

# |- forall a b z. iff(mem(z,a), mem(z,b)) -> iff(mem(z,b), mem(z,a))
$eq_symmetric {
    $P mem("z", "a")
    $Q mem("z", "b")
    $formula implies(iff(P, Q), iff(Q, P))
    close(iff_sym(P, Q, []), [formula], ["z", "b", "a"])
}
