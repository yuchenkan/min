from core.derived import neg, implies
from tactics import ax, nl, nr, ir, close

# |- P -> ~~P
$not_not_intro \P vars: {
    $s1 nl(ax([P], [P], P), [P, neg(P)], [], neg(P))
    $s2 nr(s1, [P], [neg(neg(P))], neg(neg(P)))
    $top implies(P, neg(neg(P)))
    $s3 ir(s2, [], [top], top)
    close(s3, [], [top], vars)
}
