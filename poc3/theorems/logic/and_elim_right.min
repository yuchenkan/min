from core.derived import neg, implies, and
from tactics import ax, wl, nl, nr, ir, close

# |- and(A, B) -> B
$and_elim_right \A B vars: {
    $and_AB and(A, B)
    $not_B neg(B)
    $imp_A_notB implies(A, not_B)
    $s1 wl(ax([B], [B], B), [A, B], [B], A)
    $s2 nr(s1, [A], [neg(B), B], neg(B))
    $s3 ir(s2, [], [imp_A_notB, B], imp_A_notB)
    $s4 nl(s3, [and_AB], [B], and_AB)
    $top implies(and_AB, B)
    $s5 ir(s4, [], [top], top)
    close(s5, [], [top], vars)
}
