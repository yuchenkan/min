from core.derived import implies
from tactics import ax, wl, wr, il, ir, close

# modus_ponens(A, B, vars) returns proof of:
# close(vars, A -> (A -> B) -> B)

$modus_ponens \A B vars: {
    $AB implies(A, B)
    $ABB implies(AB, B)
    $top implies(A, ABB)

    $s1 wr(ax([A], [A], A), [A], [A, B], B)
    $s2 wl(ax([B], [B], B), [A, B], [B], A)
    $s3 il(s1, s2, [A, AB], [B], AB)
    $s4 ir(s3, [A], [ABB], ABB)
    $s5 ir(s4, [], [top], top)

    close(s5, [top], vars)
}
