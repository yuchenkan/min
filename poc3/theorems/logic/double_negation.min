from core.derived import neg, implies
from tactics import ax, nl, nr, ir, close

# |- ~~A -> A
$double_negation \A vars: {
    $na neg(A)
    $nna neg(na)
    $s1 nr(ax([A], [A], A), [], [na, A], na)
    $s2 nl(s1, [nna], [A], nna)
    $top implies(nna, A)
    $s3 ir(s2, [], [top], top)
    close(s3, [top], vars)
}
