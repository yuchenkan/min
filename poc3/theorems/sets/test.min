from core.derived import mem, implies, forall, iff, eqv, exists, qed
from vocab.sets import empty, singleton, pair_set, big_union
from theorems.sets.empty_exists import empty_exists
from theorems.sets.pair_set_exists import pair_set_exists
from theorems.sets.big_union_exists import big_union_exists
from theorems.sets.empty_unique import empty_unique
from theorems.sets.set_spec_unique import set_spec_unique
from theorems.sets.singleton_unique import singleton_unique

$_ qed(empty_exists, exists("s", empty("s")))
$_ print("empty_exists ok")

$_ qed(pair_set_exists, forall("a", forall("b", exists("s", pair_set("s", "a", "b")))))
$_ print("pair_set_exists ok")

$_ qed(big_union_exists, forall("a", exists("s", big_union("s", "a"))))
$_ print("big_union_exists ok")

$_ qed(empty_unique("a", "b", ["b", "a"]),
    forall("a", forall("b", implies(empty("a"), implies(empty("b"), eqv("a", "b", "_"))))))
$_ print("empty_unique ok")

$_ qed(set_spec_unique("s1", "s2", \v: mem(v, "a"), ["a", "s2", "s1"]),
    forall("s1", forall("s2", forall("a",
        implies(forall("x", iff(mem("x", "s1"), mem("x", "a"))),
                implies(forall("x", iff(mem("x", "s2"), mem("x", "a"))),
                        eqv("s1", "s2", "_")))))))
$_ print("set_spec_unique ok")

$_ qed(singleton_unique("s1", "s2", "a", ["a", "s2", "s1"]),
    forall("s1", forall("s2", forall("a",
        implies(singleton("s1", "a"), implies(singleton("s2", "a"), eqv("s1", "s2")))))))
$_ print("singleton_unique ok")

from vocab.sets import power_set, successor
from theorems.sets.power_set_exists import power_set_exists

$_ qed(power_set_exists, forall("a", exists("s", power_set("s", "a"))))
$_ print("power_set_exists ok")

from theorems.sets.singleton_exists import singleton_exists

$_ qed(singleton_exists("a", ["a"]), forall("a", exists("s", singleton("s", "a"))))
$_ print("singleton_exists ok")

from vocab.logic import exists_unique
from theorems.sets.unique_empty import unique_empty
from theorems.sets.unique_singleton import unique_singleton
from theorems.sets.unique_pair_set import unique_pair_set
from theorems.sets.unique_big_union import unique_big_union
from theorems.sets.unique_power_set import unique_power_set

$_ qed(unique_empty, exists_unique(\v: empty(v, "_")))
$_ print("unique_empty ok")

$_ qed(unique_singleton("a", ["a"]), forall("a", exists_unique(\v: singleton(v, "a", "_"))))
$_ print("unique_singleton ok")

$_ qed(unique_pair_set("a", "b", ["b", "a"]), forall("a", forall("b", exists_unique(\v: pair_set(v, "a", "b", "_")))))
$_ print("unique_pair_set ok")

$_ qed(unique_big_union("a", ["a"]), forall("a", exists_unique(\v: big_union(v, "a", "_"))))
$_ print("unique_big_union ok")

$_ qed(unique_power_set("a", ["a"]), forall("a", exists_unique(\v: power_set(v, "a", "_"))))
$_ print("unique_power_set ok")
