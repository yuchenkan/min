from tactics import ax, wr
from core.derived import exists
from core.axioms import Pairing
from vocab.sets import pair_set

# Pairing |- forall(a, forall(b, exists(s, pair_set(s, a, b))))
$pair_set_exists {
    $a var("a") $b var("b") $s var("s")
    $f Pairing()
    $goal forall(a, forall(b, exists(s, pair_set(s, a, b))))
    wr(ax(f), sequent([f], [goal]), goal)
}
