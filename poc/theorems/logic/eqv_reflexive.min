from tactics import ax, ir, fr, close
from core.derived import iff, eqv
from theorems.logic.iff_refl import iff_refl

# |- forall(a, eqv(a, a))
# eqv(a, a) = forall(z, iff(mem(z, a), mem(z, a)))
$eqv_reflexive {
    $a var("a") $z var("z")
    $P mem(z, a)
    $got iff_refl(P)
    # [] |- [iff(P, P)]
    $eqv_aa eqv(a, a)
    $s1 fr(got, sequent([], [eqv_aa]), eqv_aa, z)
    $goal forall(a, eqv_aa)
    fr(s1, sequent([], [goal]), goal, a)
}
