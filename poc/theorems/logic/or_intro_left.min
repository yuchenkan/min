from tactics import ax, nl, wr, ir, close
from core.derived import or

# |- A -> or(A, B)
$or_intro_left \(A B vars : {
    $or_AB or(A, B)
    $s1 nl(ax(A), sequent([A, neg(A)], []), neg(A))
    $s2 wr(s1, sequent([A, neg(A)], [B]), B)
    $s3 ir(s2, sequent([A], [or_AB]), or_AB)
    $top implies(A, or_AB)
    $result ir(s3, sequent([], [top]), top)
    close(result, top, vars, [])
})
