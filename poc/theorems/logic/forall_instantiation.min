from tactics import ax, fl, ir, close

# |- forall(x, A) -> A[x:=t]
# Given a formula builder body_fn and a term, instantiate the forall
$forall_instantiation \(x body term vars : {
    $A body(x)
    $At body(term)
    $fa forall(x, A)
    $got fl(ax(At), sequent([fa], [At]), fa, term)
    $top implies(fa, At)
    $result ir(got, sequent([], [top]), top)
    close(result, top, vars, [])
})
