from core.derived import and, or, iff, exists, eqv
from vocab.logic import exists_unique
from theorems.logic.modus_ponens import modus_ponens
from theorems.logic.double_negation import double_negation
from theorems.logic.and_intro import and_intro
from theorems.logic.and_elim_left import and_elim_left
from theorems.logic.and_elim_right import and_elim_right
from theorems.logic.or_intro_left import or_intro_left
from theorems.logic.or_intro_right import or_intro_right
from theorems.logic.or_elim import or_elim
from theorems.logic.iff_intro import iff_intro
from theorems.logic.iff_elim_left import iff_elim_left
from theorems.logic.iff_elim_right import iff_elim_right
from theorems.logic.iff_sym import iff_sym
from theorems.logic.implies_trans import implies_trans
from theorems.logic.iff_chain import iff_chain
from theorems.logic.eq_reflexive import eq_reflexive
from theorems.logic.eq_symmetric import eq_symmetric
from theorems.logic.forall_instantiation import forall_instantiation
from theorems.logic.forall_implies_exists import forall_implies_exists
from theorems.logic.eq_transitive import eq_transitive
from theorems.logic.eq_substitution import eq_substitution
from theorems.logic.or_iff_compat import or_iff_compat
from theorems.logic.exists_unique_intro import exists_unique_intro
from theorems.logic.exists_intro import exists_intro
from theorems.logic.contrapositive import contrapositive
from theorems.logic.not_not_intro import not_not_intro
from theorems.logic.neg_iff_compat import neg_iff_compat
from theorems.logic.forall_iff_compat import forall_iff_compat
from theorems.logic.implies_iff_compat import implies_iff_compat
from theorems.logic.and_iff_compat import and_iff_compat
from theorems.logic.exists_iff_compat import exists_iff_compat
from theorems.logic.iff_refl import iff_refl
from theorems.logic.eqv_symmetric import eqv_symmetric
from theorems.logic.eqv_transitive import eqv_transitive
from theorems.logic.ext_substitution import ext_substitution
from theorems.logic.exists_unique_bridge import exists_unique_bridge
from theorems.logic.neg_neg_iff import neg_neg_iff
from theorems.logic.or_idempotent import or_idempotent
from theorems.logic.eqv_reflexive import eqv_reflexive
from theorems.logic.eqv_mem_left import eqv_mem_left

$a var("a") $b var("b") $c var("c") $x var("x") $y var("y") $z var("z") $s var("s")

$A mem(a, b)
$B mem(b, a)
$C mem(a, a)
$D mem(b, b)

$t01 !qed(modus_ponens(A, B, [b, a]),
          forall(a, forall(b, implies(mem(a, b), implies(implies(mem(a, b), mem(b, a)), mem(b, a))))))

$t02 !qed(double_negation(A, [b, a]),
          forall(a, forall(b, implies(neg(neg(mem(a, b))), mem(a, b)))))

$t03 !qed(and_intro(A, B, [b, a]),
          forall(a, forall(b, implies(mem(a, b), implies(mem(b, a), and(mem(a, b), mem(b, a)))))))

$t04 !qed(and_elim_left(A, B, [b, a]),
          forall(a, forall(b, implies(and(mem(a, b), mem(b, a)), mem(a, b)))))

$t05 !qed(and_elim_right(A, B, [b, a]),
          forall(a, forall(b, implies(and(mem(a, b), mem(b, a)), mem(b, a)))))

$t06 !qed(or_intro_left(A, B, [b, a]),
          forall(a, forall(b, implies(mem(a, b), or(mem(a, b), mem(b, a))))))

$t07 !qed(or_intro_right(A, B, [b, a]),
          forall(a, forall(b, implies(mem(b, a), or(mem(a, b), mem(b, a))))))

$t08 !qed(or_elim(A, B, C, [b, a]),
          forall(a, forall(b, implies(or(mem(a, b), mem(b, a)), implies(implies(mem(a, b), mem(a, a)), implies(implies(mem(b, a), mem(a, a)), mem(a, a)))))))

$t09 !qed(iff_intro(A, B, [b, a]),
          forall(a, forall(b, implies(implies(mem(a, b), mem(b, a)), implies(implies(mem(b, a), mem(a, b)), iff(mem(a, b), mem(b, a)))))))

$t10 !qed(iff_elim_left(A, B, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), implies(mem(a, b), mem(b, a))))))

$t11 !qed(iff_elim_right(A, B, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), implies(mem(b, a), mem(a, b))))))

$t12 !qed(iff_sym(A, B, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), iff(mem(b, a), mem(a, b))))))

$t13 !qed(implies_trans(A, B, C, [b, a]),
          forall(a, forall(b, implies(implies(mem(a, b), mem(b, a)), implies(implies(mem(b, a), mem(a, a)), implies(mem(a, b), mem(a, a)))))))

$t14 !qed(iff_chain(A, B, C, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), implies(iff(mem(b, a), mem(a, a)), iff(mem(a, b), mem(a, a)))))))

$t15 !qed(eq_reflexive, forall(a, forall(z, iff(mem(z, a), mem(z, a)))))

$t16 !qed(eq_symmetric, forall(a, forall(b, forall(z, implies(iff(mem(z, a), mem(z, b)), iff(mem(z, b), mem(z, a)))))))

$t17 !qed(forall_instantiation(x, \(v : mem(v, a)), b, [b, a]),
          forall(a, forall(b, implies(forall(x, mem(x, a)), mem(b, a)))))

$t18 !qed(forall_implies_exists(x, \(v : mem(v, a)), [a]),
          forall(a, implies(forall(x, mem(x, a)), exists(x, mem(x, a)))))

$t19 !qed(eq_transitive, forall(a, forall(b, forall(c, forall(z, implies(iff(mem(z, a), mem(z, b)), implies(iff(mem(z, b), mem(z, c)), iff(mem(z, a), mem(z, c)))))))))

$t20 !qed(eq_substitution(A, B, C, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), implies(implies(mem(a, b), mem(a, a)), implies(mem(b, a), mem(a, a)))))))

$t21 !qed(or_iff_compat(A, B, C, D, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(a, a)), implies(iff(mem(b, a), mem(b, b)), iff(or(mem(a, b), mem(b, a)), or(mem(a, a), mem(b, b))))))))

$t22 !qed(exists_unique_intro(\(v : mem(v, a)), b, [b, a]),
          forall(a, forall(b, implies(mem(b, a), implies(forall(y, implies(mem(y, a), eqv(b, y))), exists_unique(\(v : mem(v, a))))))))

$t23 !qed(exists_intro(x, \(v : mem(v, a)), b, [b, a]),
          forall(a, forall(b, implies(mem(b, a), exists(x, mem(x, a))))))

$t24 !qed(contrapositive(A, B, [b, a]),
          forall(a, forall(b, implies(implies(mem(a, b), mem(b, a)), implies(neg(mem(b, a)), neg(mem(a, b)))))))

$t25 !qed(not_not_intro(A, [b, a]),
          forall(a, forall(b, implies(mem(a, b), neg(neg(mem(a, b)))))))

$t26 !qed(neg_iff_compat(A, B, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(b, a)), iff(neg(mem(a, b)), neg(mem(b, a)))))))

$t27 !qed(forall_iff_compat(x, \(v : mem(v, a)), \(v : mem(v, b)), [b, a]),
          forall(a, forall(b, implies(forall(z, iff(mem(z, a), mem(z, b))), iff(forall(x, mem(x, a)), forall(x, mem(x, b)))))))

$t28 !qed(implies_iff_compat(A, B, C, D, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(a, a)), implies(iff(mem(b, a), mem(b, b)), iff(implies(mem(a, b), mem(b, a)), implies(mem(a, a), mem(b, b))))))))

$t29 !qed(and_iff_compat(A, B, C, D, [b, a]),
          forall(a, forall(b, implies(iff(mem(a, b), mem(a, a)), implies(iff(mem(b, a), mem(b, b)), iff(and(mem(a, b), mem(b, a)), and(mem(a, a), mem(b, b))))))))

$t30 !qed(exists_iff_compat(x, \(v : mem(v, a)), \(v : mem(v, b)), [b, a]),
          forall(a, forall(b, implies(forall(z, iff(mem(z, a), mem(z, b))), iff(exists(x, mem(x, a)), exists(x, mem(x, b)))))))

$t31 !qed(iff_refl(A, [b, a]),
          forall(a, forall(b, iff(mem(a, b), mem(a, b)))))

$t32 !qed(eqv_symmetric(a, b, [b, a]),
          forall(a, forall(b, implies(eqv(a, b), eqv(b, a)))))

$t33 !qed(eqv_transitive(a, b, c, [c, b, a]),
          forall(a, forall(b, forall(c, implies(eqv(a, b), implies(eqv(b, c), eqv(a, c)))))))

$t34 !qed(ext_substitution(a, b, s, [s, b, a]),
          forall(a, forall(b, forall(s, implies(eqv(a, b), iff(mem(a, s), mem(b, s)))))))

$bridge_f implies(exists_unique(\(v : mem(v, a))), iff(forall(x, implies(mem(x, a), mem(x, s))), exists(x, and(mem(x, a), mem(x, s)))))
$t35 !qed(exists_unique_bridge(\(v : mem(v, a)), s, [s, a]),
          forall(a, forall(s, bridge_f)))

# neg_neg_iff: neg(P) -> neg(Q) -> iff(P, Q)
$t36 !qed(neg_neg_iff(A, B, [b, a]),
          forall(a, forall(b, implies(neg(mem(a, b)), implies(neg(mem(b, a)), iff(mem(a, b), mem(b, a)))))))

# or_idempotent: iff(or(P, P), P)
$t37 !qed(or_idempotent(A, [b, a]),
          forall(a, forall(b, iff(or(mem(a, b), mem(a, b)), mem(a, b)))))

# eqv_reflexive: forall(a, eqv(a, a))
$t38 !qed(eqv_reflexive, forall(a, eqv(a, a)))

# eqv_mem_left: eqv(a, b) -> mem(z, a) -> mem(z, b)
$t39 !qed(eqv_mem_left(a, b, z, [z, b, a]),
          forall(a, forall(b, forall(z, implies(eqv(a, b), implies(mem(z, a), mem(z, b)))))))
