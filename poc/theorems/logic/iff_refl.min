from tactics import ax, ir, mp, close
from core.derived import iff
from theorems.logic.iff_intro import iff_intro

# |- iff(P, P)
$iff_refl \(P vars : {
    $id implies(P, P)
    $iff_PP iff(P, P)
    $got_id ir(ax(P), sequent([], [id]), id)
    $result mp(mp(iff_intro(P, P), got_id, id, implies(id, iff_PP), [], []),
               got_id, id, iff_PP, [], [])
    close(result, iff_PP, vars, [])
})
