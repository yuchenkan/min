from tactics import ax, nl, nr, ir, close

# |- ~~A -> A
$double_negation \(A vars : {
    $nna neg(neg(A))
    $na neg(A)
    $s1 nr(ax(A), sequent([], [na, A]), na)
    $s2 nl(s1, sequent([nna], [A]), nna)
    $top implies(nna, A)
    $result ir(s2, sequent([], [top]), top)
    close(result, top, vars, [])
})
