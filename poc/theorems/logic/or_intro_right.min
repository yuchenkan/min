from tactics import ax, wl, ir, close
from core.derived import or

# |- B -> or(A, B)
$or_intro_right \(A B vars : {
    $or_AB or(A, B)
    $s1 wl(ax(B), sequent([neg(A), B], [B]), neg(A))
    $s2 ir(s1, sequent([B], [or_AB]), or_AB)
    $top implies(B, or_AB)
    $result ir(s2, sequent([], [top]), top)
    close(result, top, vars, [])
})
