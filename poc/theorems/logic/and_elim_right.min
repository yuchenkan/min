from tactics import ax, wl, nl, nr, ir, close
from core.derived import and

# |- and(A, B) -> B
$and_elim_right \(A B : {
    $and_AB and(A, B)
    $not_B neg(B)
    $imp_A_notB implies(A, not_B)
    $t1 wl(ax(B), sequent([A, B], [B]), A)
    $t2 nr(t1, sequent([A], [neg(B), B]), neg(B))
    $t3 ir(t2, sequent([], [imp_A_notB, B]), imp_A_notB)
    $t4 nl(t3, sequent([and_AB], [B]), and_AB)
    $top implies(and_AB, B)
    ir(t4, sequent([], [top]), top)
})
