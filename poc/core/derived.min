# Derived connectives: expand to primitives (neg, implies, forall, mem)

$and \(a b : neg(implies(a, neg(b))))
$or \(a b : implies(neg(a), b))
$iff \(a b : neg(implies(implies(a, b), neg(implies(b, a)))))
$exists \(x body : neg(forall(x, neg(body))))
$eq \(a b : {
    $z var()
    forall(z, neg(implies(implies(mem(z, a), mem(z, b)), neg(implies(mem(z, b), mem(z, a))))))
})
