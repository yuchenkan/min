from derived import show
from util.assert import assert
from vocab.nat.nat import successor, num, inductive, omega, nat
from vocab.nat.order import lt, le
from vocab.nat.recursion import total_from, recursive, rec_approx
from vocab.nat.arithmetic.test import ok

$_ assert(eqv(show(successor("s", "a", "_")), "s = S(a)"), "successor")
$_ assert(eqv(show(num("n", 0, "_")), "n = 0"), "num(0)")
$_ assert(eqv(show(num("n", 1, "_")), "n = 1"), "num(1)")
$_ assert(eqv(show(num("n", 2, "_")), "n = 2"), "num(2)")
$_ assert(eqv(show(inductive("a", "_")), "Ind(a)"), "inductive")
$_ assert(eqv(show(omega("w", "_")), "Omega(w)"), "omega")
$_ assert(eqv(show(nat("n", "_")), "n in N"), "nat")
$_ assert(eqv(show(lt("m", "n", "_")), "m < n"), "lt")
$_ assert(eqv(show(le("m", "n", "_")), "m <= n"), "le")
$_ assert(eqv(show(total_from("f", "a", "_")), "TotalFrom(f,a)"), "total_from")
$_ assert(eqv(show(recursive("h", "a", "f", "_")), "Rec(h,a,f)"), "recursive")
$_ assert(eqv(show(rec_approx("v", "a", "f", "_")), "RA(v,a,f)"), "rec_approx")

$ok true
