$es_body implies(rec_approx("v","a","f","w","_"), implies(function("f","_"), implies(omega("w","_"), implies(mem("n","w"), implies(apply("v","n","val","_"), implies(apply("f","val","fval","_"), implies(successor("sn","n","_"), implies(ordered_pair("op","sn","fval","_"), implies(singleton("h","op","_"), implies(union("u","v","h","_"), implies(function("u","_"), implies(apply("u","sn","fval","_"), es_inner))))))))))))
