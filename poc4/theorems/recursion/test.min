from theorems.recursion.extend_consistency import extend_consistency
$ec_body implies(rec_approx("v","a","f","w","_"), implies(mem("n","w"), implies(apply("v","n","val","_"), implies(apply("f","val","fval","_"), implies(successor("sn","n","_"), implies(apply("v","sn","z","_"), eqv("fval","z","_")))))))
$_ qed(extend_consistency, forall("v", forall("a", forall("f", forall("w", forall("n", forall("sn", forall("val", forall("fval", forall("z", ec_body))))))))))
$_ print("extend_consistency ok")

from theorems.recursion.extend_base import extend_base
$eb_body implies(forall("e", implies(empty("e","_"), implies(exists("y", apply("v","e","y","_")), apply("v","e","a","_")))),
    implies(successor("sn","n","_"), implies(singleton("h","op","_"), implies(ordered_pair("op","sn","fval","_"),
        implies(union("u","v","h","_"), forall("e", implies(empty("e","_"), implies(exists("y", apply("u","e","y","_")), apply("u","e","a","_")))))))))
$_ qed(extend_base, forall("v", forall("u", forall("h", forall("op", forall("sn", forall("n", forall("a", forall("fval", eb_body)))))))))
$_ print("extend_base ok")

