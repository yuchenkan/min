from theorems.recursion.rec_base import rec_base
$_ qed(rec_base, forall("e0", forall("a", implies(empty("e0","_"), exists("h", and(function("h","_"), forall("e", implies(empty("e","_"), apply("h","e","a","_")))))))))
$_ print("rec_base ok")

