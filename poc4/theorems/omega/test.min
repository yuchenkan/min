from core.derived import mem, neg, implies, forall, and, or, iff, exists, eqv, qed
from vocab.sets import empty, successor, subset
from vocab.omega import inductive, omega
from vocab.logic import exists_unique

from theorems.omega.infinity_gives_inductive import infinity_gives_inductive
$_ qed(infinity_gives_inductive, exists("b", inductive("b")))
$_ print("infinity_gives_inductive ok")

from theorems.omega.omega_is_inductive import omega_is_inductive
$_ qed(omega_is_inductive, forall("w", implies(omega("w"), inductive("w"))))
$_ print("omega_is_inductive ok")

from theorems.omega.omega_smallest_inductive import omega_smallest_inductive
$_ qed(omega_smallest_inductive,
    forall("c", forall("w", implies(omega("w"), implies(inductive("c", "_"), subset("w", "c", "__"))))))
$_ print("omega_smallest_inductive ok")

from theorems.omega.omega_contains_empty import omega_contains_empty
$_ qed(omega_contains_empty,
    forall("e", forall("w", implies(omega("w"), implies(empty("e", "__"), mem("e", "w"))))))
$_ print("omega_contains_empty ok")

from theorems.omega.omega_succ_closed import omega_succ_closed
$_ qed(omega_succ_closed,
    forall("s", forall("n", forall("w",
        implies(omega("w"), implies(mem("n","w"), implies(successor("s","n","___"), mem("s","w"))))))))
$_ print("omega_succ_closed ok")

from theorems.omega.omega_exists import omega_exists
$_ qed(omega_exists, exists("w", omega("w")))
$_ print("omega_exists ok")

from theorems.omega.omega_unique import omega_unique
$_ qed(omega_unique,
    forall("w1", forall("w2", implies(omega("w1"), implies(omega("w2"), eqv("w1","w2"))))))
$_ print("omega_unique ok")

from theorems.omega.unique_omega import unique_omega
$_ qed(unique_omega, exists_unique(\v: omega(v, "_")))
$_ print("unique_omega ok")
