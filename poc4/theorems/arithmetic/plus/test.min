from core.derived import mem, implies, forall, and, iff, exists, eqv, qed
from vocab.sets import successor, ordered_pair
from vocab.functions import apply, function, relation, domain, product
from vocab.omega import omega
from vocab.recursion import recursive, total_from
from vocab.logic import exists_unique

$sfe_phi \p np: exists(add(np,"x"), and(mem(add(np,"x"),"w"),
    exists(add(np,"s"), and(successor(add(np,"s"),add(np,"x"),add(np,"_")),
        ordered_pair(p,add(np,"x"),add(np,"s"),add(np,"_"))))))
$sfe_sc forall("x", implies(mem("x","w"), forall("s", implies(successor("s","x","_"), mem("s","w")))))

from theorems.arithmetic.plus.succ_func_exists import succ_func_exists
$sfe_body implies(sfe_sc, exists("sf", forall("p", iff(mem("p","sf"), sfe_phi("p","_")))))
$_ qed(succ_func_exists, forall("w", sfe_body))
$_ print("succ_func_exists ok")

from theorems.arithmetic.plus.succ_func_unique import succ_func_unique
$sfu_body implies(forall("p", iff(mem("p","sf1"), sfe_phi("p","_"))),
    implies(forall("p", iff(mem("p","sf2"), sfe_phi("p","_"))), eqv("sf1","sf2","_")))
$_ qed(succ_func_unique, forall("sf1", forall("sf2", forall("w", sfu_body))))
$_ print("succ_func_unique ok")

from theorems.arithmetic.plus.unique_succ_func import unique_succ_func
$usf_char_fn \sf p: forall("p", iff(mem("p",sf), sfe_phi("p",p)))
$usf_body implies(sfe_sc, exists_unique(usf_char_fn, "_"))
$_ qed(unique_succ_func, forall("w", usf_body))
$_ print("unique_succ_func ok")

$sf_char_fn \sf w: forall("p", iff(mem("p",sf), sfe_phi("p","_")))

from theorems.arithmetic.plus.sf_apply_to_succ import sf_apply_to_succ
$_ qed(sf_apply_to_succ,
    forall("sf", forall("w", forall("x", forall("y",
        implies(sf_char_fn("sf","w"), implies(apply("sf","x","y","_"), successor("y","x","_"))))))))
$_ print("sf_apply_to_succ ok")

from theorems.arithmetic.plus.sf_succ_to_apply import sf_succ_to_apply
$_ qed(sf_succ_to_apply,
    forall("sf", forall("w", forall("x", forall("y",
        implies(sf_char_fn("sf","w"), implies(mem("x","w"), implies(successor("y","x","_"), apply("sf","x","y","_")))))))))
$_ print("sf_succ_to_apply ok")

from theorems.arithmetic.plus.sf_relation import sf_relation
$_ qed(sf_relation,
    forall("sf", forall("w",
        implies(sf_char_fn("sf","w"), relation("sf","_")))))
$_ print("sf_relation ok")

from theorems.arithmetic.plus.sf_dom_sub import sf_dom_sub
$_ qed(sf_dom_sub,
    forall("sf", forall("w", forall("xd",
        implies(sf_char_fn("sf","w"), implies(exists("yd", apply("sf","xd","yd","_")), mem("xd","w")))))))
$_ print("sf_dom_sub ok")

from theorems.arithmetic.plus.sf_props import sf_props
$sfp_succ_char forall("xc", implies(mem("xc","w"), forall("yc", iff(apply("sf","xc","yc","_"), successor("yc","xc","_")))))
$sfp_dom_sub forall("xd", implies(exists("yd", apply("sf","xd","yd","_")), mem("xd","w")))
$sfp_body implies(sfe_sc, exists("sf", and(sfp_succ_char, and(function("sf","_"), sfp_dom_sub))))
$_ qed(sf_props, forall("w", sfp_body))
$_ print("sf_props ok")

from theorems.arithmetic.plus.sf_total_from import sf_total_from
$sfp_all and(sfp_succ_char, and(function("sf","_"), sfp_dom_sub))
$sftf_body implies(sfp_all, implies(omega("w","_"), implies(mem("m","w"), total_from("sf","m","_"))))
$_ qed(sf_total_from, forall("sf", forall("w", forall("m", sftf_body))))
$_ print("sf_total_from ok")

from theorems.arithmetic.plus.rec_for_each_m import rec_for_each_m
$rfem_body implies(sfp_all, implies(omega("w","_"), implies(mem("m","w"),
    exists_unique(\h p: recursive(h,"m","sf","w",p), "_"))))
$_ qed(rec_for_each_m, forall("sf", forall("w", forall("m", rfem_body))))
$_ print("rec_for_each_m ok")

from theorems.arithmetic.plus.pf_base import pf_base
from vocab.sets import empty
from vocab.functions import product
$pf_phi \xv np: exists(add(np,"m"), and(mem(add(np,"m"),"w"),
    exists(add(np,"n"), exists(add(np,"y"), exists(add(np,"pv"),
        and(ordered_pair(add(np,"pv"),add(np,"m"),add(np,"n"),add(np,"_")),
        and(ordered_pair(xv,add(np,"pv"),add(np,"y"),add(np,"_")),
            exists(add(np,"hm"), and(recursive(add(np,"hm"),add(np,"m"),"sf","w",add(np,"_")),
                apply(add(np,"hm"),add(np,"n"),add(np,"y"),add(np,"_")))))))))))
$pf_char_h forall("xv", iff(mem("xv","h"), and(mem("xv","pwww"), pf_phi("xv","_"))))
$pf_base_body forall("m", implies(mem("m","w"),
    forall("z", implies(empty("z","_"),
        forall("pair", implies(ordered_pair("pair","m","z","_"),
            apply("h","pair","m","_")))))))
$pf_base_top implies(pf_char_h, implies(product("pww","w","w","_"), implies(product("pwww","pww","w","_"),
    implies(sfp_all, implies(omega("w","_"), pf_base_body)))))
$_ qed(pf_base, forall("h", forall("pww", forall("pwww", forall("sf", forall("w", pf_base_top))))))
$_ print("pf_base ok")

from theorems.arithmetic.plus.pf_relation import pf_relation
$pf_rel_top implies(pf_char_h, implies(product("pwww","pww","w","_"), relation("h","_")))
$_ qed(pf_relation, forall("h", forall("pww", forall("pwww", forall("sf", forall("w", pf_rel_top))))))
$_ print("pf_relation ok")

from theorems.arithmetic.plus.pf_forward import pf_forward
$pf_char_fwd forall("xv", implies(mem("xv","h"), pf_phi("xv","_")))
$pf_fwd_result \key val: exists("mv", and(mem("mv","w"), exists("nv",
    and(ordered_pair(key,"mv","nv","_"), exists("hm", and(recursive("hm","mv","sf","w","_"), apply("hm","nv",val,"_")))))))
$pf_fwd_top implies(pf_char_fwd, implies(apply("h","key","val","_"), pf_fwd_result("key","val")))
$_ qed(pf_forward, forall("h", forall("sf", forall("w", forall("key", forall("val", pf_fwd_top))))))
$_ print("pf_forward ok")

from theorems.arithmetic.plus.pf_single_valued import pf_single_valued
$pf_sv_body forall("key", forall("y1", forall("y2",
    implies(and(apply("h","key","y1","_"), apply("h","key","y2","_")), eqv("y1","y2","_")))))
$pf_sv_top implies(pf_char_fwd, implies(sfp_all, implies(omega("w","_"), pf_sv_body)))
$_ qed(pf_single_valued, forall("h", forall("sf", forall("w", pf_sv_top))))
$_ print("pf_single_valued ok")

from theorems.arithmetic.plus.pf_dom_eq import pf_dom_eq
$pf_deq_body forall("dd", implies(domain("dd","h","_"),
    forall("prod", implies(product("prod","w","w","_"), eqv("dd","prod","_")))))
$pf_deq_top implies(pf_char_h, implies(product("pww","w","w","_"), implies(product("pwww","pww","w","_"),
    implies(sfp_all, implies(omega("w","_"), pf_deq_body)))))
$_ qed(pf_dom_eq, forall("h", forall("pww", forall("pwww", forall("sf", forall("w", pf_deq_top))))))
$_ print("pf_dom_eq ok")

from theorems.arithmetic.plus.pf_backward import pf_backward
$pf_bwd_body forall("m", implies(mem("m","w"),
    forall("n", implies(mem("n","w"),
        forall("pair", implies(ordered_pair("pair","m","n","_"),
            forall("hm", implies(recursive("hm","m","sf","w","_"),
                forall("yv", implies(apply("hm","n","yv","_"),
                    apply("h","pair","yv","_")))))))))))
$pf_bwd_top implies(pf_char_h, implies(product("pww","w","w","_"), implies(product("pwww","pww","w","_"),
    implies(sfp_all, implies(omega("w","_"), pf_bwd_body)))))
$_ qed(pf_backward, forall("h", forall("pww", forall("pwww", forall("sf", forall("w", pf_bwd_top))))))
$_ print("pf_backward ok")

from theorems.arithmetic.plus.pf_step import pf_step
$pf_step_body forall("m", implies(mem("m","w"),
    forall("n", implies(mem("n","w"),
        forall("pair", implies(ordered_pair("pair","m","n","_"),
            forall("p", implies(apply("h","pair","p","_"),
                forall("sn", implies(successor("sn","n","_"),
                    forall("sp", implies(successor("sp","p","_"),
                        forall("pair2", implies(ordered_pair("pair2","m","sn","_"),
                            apply("h","pair2","sp","_")))))))))))))))
$pf_step_top implies(pf_char_h, implies(product("pww","w","w","_"), implies(product("pwww","pww","w","_"),
    implies(sfp_all, implies(omega("w","_"), pf_step_body)))))
$_ qed(pf_step, forall("h", forall("pww", forall("pwww", forall("sf", forall("w", pf_step_top))))))
$_ print("pf_step ok")

from theorems.arithmetic.plus.rec_val_in_omega import rec_val_in_omega
$rvo_sc forall("xc", implies(mem("xc","w"), forall("yc", iff(apply("sf","xc","yc","_"), successor("yc","xc","_")))))
$rvo_body implies(omega("w","_"), implies(mem("a","w"), implies(rvo_sc,
    implies(recursive("h","a","sf","w","_"), implies(mem("x","w"), implies(apply("h","x","y","_"), mem("y","w")))))))
$_ qed(rec_val_in_omega, forall("w", forall("sf", forall("a", forall("h", forall("x", forall("y", rvo_body)))))))
$_ print("rec_val_in_omega ok")

$ok true
