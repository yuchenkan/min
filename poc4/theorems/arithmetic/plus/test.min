$_pa_qed \m n: {
    $p add(m, n)
    $pa prove_addition(m, n)
    qed(pa, forall("a", implies(num("a",m,"_"), forall("b", implies(num("b",n,"_"),
        forall("c", implies(num("c",p,"_"), plus("a","b","c","_"))))))), "z")
}

$_ _pa_qed(0, 0)
$_ tap("0+0=0 ok")
$_ _pa_qed(1, 0)
$_ tap("1+0=1 ok")
$_ _pa_qed(0, 1)
$_ tap("0+1=1 ok")
$_ _pa_qed(1, 1)
$_ tap("1+1=2 ok")
$_ _pa_qed(2, 3)
$_ tap("2+3=5 ok")

$ok true
