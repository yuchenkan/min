$_ qed(h_succ_left, forall("h", implies(plus_func("h","_"),
    forall("m", implies(nat("m","_"),
        forall("sm", implies(successor("sm","m","_"),
            forall("n", implies(nat("n","_"),
                forall("pair", implies(ordered_pair("pair","m","n","_"),
                    forall("p", implies(apply("h","pair","p","_"),
                        forall("pair_sm", implies(ordered_pair("pair_sm","sm","n","_"),
