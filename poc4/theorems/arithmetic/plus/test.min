$_ qed(succ_func_exists, exists("sf", succ_func("sf","_")), "z")
$_ tap("succ_func_exists ok")

$_ qed(succ_func_unique, forall("sf1", forall("sf2",
    implies(succ_func("sf1","_"), implies(succ_func("sf2","_"), eqv("sf1","sf2","_"))))), "z")
$_ tap("succ_func_unique ok")

$_ qed(unique_succ_func, exists_unique(\sf p: succ_func(sf, p), "_"), "z")
$_ tap("unique_succ_func ok")

$sfe_phi \p np: exists(add(np,"x"), and(mem(add(np,"x"),"w"),
    exists(add(np,"s"), and(successor(add(np,"s"),add(np,"x"),add(np,"_")),
        ordered_pair(p,add(np,"x"),add(np,"s"),add(np,"_"))))))
$sf_char_fn \sf w: forall("p", iff(mem("p",sf), sfe_phi("p","_")))

$_ qed(sf_apply_to_succ,
    forall("sf", forall("w", forall("x", forall("y",
        implies(sf_char_fn("sf","w"), implies(apply("sf","x","y","_"), successor("y","x","_"))))))), "z")
$_ tap("sf_apply_to_succ ok")

$_ qed(sf_succ_to_apply,
    forall("sf", forall("w", forall("x", forall("y",
        implies(sf_char_fn("sf","w"), implies(mem("x","w"), implies(successor("y","x","_"), apply("sf","x","y","_")))))))), "z")
$_ tap("sf_succ_to_apply ok")

$_ qed(sf_relation,
    forall("sf", forall("w",
        implies(sf_char_fn("sf","w"), relation("sf","_")))), "z")
$_ tap("sf_relation ok")

$_ qed(sf_dom_sub,
    forall("sf", forall("w", forall("xd",
        implies(sf_char_fn("sf","w"), implies(exists("yd", apply("sf","xd","yd","_")), mem("xd","w")))))), "z")
$_ tap("sf_dom_sub ok")

$_ qed(sf_total_from, forall("sf", forall("m",
    implies(succ_func("sf","_"), implies(nat("m","_"), total_from("sf","m","_"))))), "z")
$_ tap("sf_total_from ok")

$_ qed(succ_func_total_from, forall("sf", forall("m",
    implies(succ_func("sf","_"), implies(nat("m","_"), total_from("sf","m","_"))))), "z")
$_ tap("succ_func_total_from ok")

$_ qed(rec_for_each_m, forall("sf", forall("m",
    implies(succ_func("sf","_"), implies(nat("m","_"),
        exists_unique(\h p: recursive(h,"m","sf",p), "_"))))), "z")
$_ tap("rec_for_each_m ok")

$pf_phi \xv np: exists(add(np,"m"), and(nat(add(np,"m"),np),
    exists(add(np,"n"), exists(add(np,"y"), exists(add(np,"pv"),
        and(ordered_pair(add(np,"pv"),add(np,"m"),add(np,"n"),add(np,"_")),
        and(ordered_pair(xv,add(np,"pv"),add(np,"y"),add(np,"_")),
            exists(add(np,"hm"), and(recursive(add(np,"hm"),add(np,"m"),"sf",add(np,"_")),
                apply(add(np,"hm"),add(np,"n"),add(np,"y"),add(np,"_")))))))))))
$pf_char_h forall("xv", iff(mem("xv","h"), pf_phi("xv","_")))
$pf_base_body implies(nat("m","_"), forall("z", implies(num("z",0,"_"),
    forall("pair", implies(ordered_pair("pair","m","z","_"), apply("h","pair","m","_"))))))
$pf_base_top implies(pf_char_h, implies(succ_func("sf","_"), forall("m", pf_base_body)))
$_ qed(pf_base, forall("h", forall("sf", pf_base_top)), "z")
$_ tap("pf_base ok")

$pf_rel_top implies(pf_char_h, relation("h","_"))
$_ qed(pf_relation, forall("h", forall("sf", pf_rel_top)), "z")
$_ tap("pf_relation ok")

$pf_char_fwd forall("xv", implies(mem("xv","h"), pf_phi("xv","_")))
$pf_fwd_result \key val: exists("mv", and(nat("mv","_"), exists("nv",
    and(ordered_pair(key,"mv","nv","_"), exists("hm", and(recursive("hm","mv","sf","_"), apply("hm","nv",val,"_")))))))
$pf_fwd_top implies(pf_char_fwd, implies(apply("h","key","val","_"), pf_fwd_result("key","val")))
$_ qed(pf_forward, forall("h", forall("sf", forall("key", forall("val", pf_fwd_top)))), "z")
$_ tap("pf_forward ok")

$pf_sv_body forall("key", forall("y1", forall("y2",
    implies(and(apply("h","key","y1","_"), apply("h","key","y2","_")), eqv("y1","y2","_")))))
$pf_sv_top implies(pf_char_fwd, implies(succ_func("sf","_"), pf_sv_body))
$_ qed(pf_single_valued, forall("h", forall("sf", pf_sv_top)), "z")
$_ tap("pf_single_valued ok")

$pf_deq_body forall("dd", forall("prod", implies(domain("dd","h","_"),
    implies(product("prod","w","w","_"), eqv("dd","prod","_")))))
$pf_deq_top implies(pf_char_h, implies(succ_func("sf","_"), implies(omega("w","_"), pf_deq_body)))
$_ qed(pf_dom_eq, forall("h", forall("sf", forall("w", pf_deq_top))), "z")
$_ tap("pf_dom_eq ok")

$pf_bwd_body implies(succ_func("sf","_"), forall("m", implies(nat("m","_"),
    forall("n", implies(nat("n","_"),
        forall("pair", implies(ordered_pair("pair","m","n","_"),
            forall("hm", implies(recursive("hm","m","sf","_"),
                forall("yv", implies(apply("hm","n","yv","_"),
                    apply("h","pair","yv","_"))))))))))))
$pf_bwd_top implies(pf_char_h, pf_bwd_body)
$_ qed(pf_backward, forall("h", forall("sf", pf_bwd_top)), "z")
$_ tap("pf_backward ok")

$pf_step_body forall("m", implies(nat("m","_"),
    forall("n", implies(nat("n","_"),
        forall("pair", implies(ordered_pair("pair","m","n","_"),
            forall("p", implies(apply("h","pair","p","_"),
                forall("sn", implies(successor("sn","n","_"),
                    forall("sp", implies(successor("sp","p","_"),
                        forall("pair2", implies(ordered_pair("pair2","m","sn","_"),
                            apply("h","pair2","sp","_")))))))))))))))
$pf_step_top implies(pf_char_h, implies(succ_func("sf","_"), pf_step_body))
$_ qed(pf_step, forall("h", forall("sf", pf_step_top)), "z")
$_ tap("pf_step ok")

$rvo_body implies(succ_char("sf","_"), implies(recursive("h","a","sf","_"),
    implies(nat("a","_"), implies(nat("x","_"), implies(apply("h","x","y","_"), nat("y","_"))))))
$_ qed(rec_val_nat, forall("sf", forall("a", forall("h", forall("x", forall("y", rvo_body))))), "z")
$_ tap("rec_val_nat ok")

