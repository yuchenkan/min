            forall("pab", implies(ordered_pair("pab","a","b","_"),
                forall("d", implies(apply("h","pab","d","_"),
                    forall("c", implies(nat("c","_"),
                        forall("pdc", implies(ordered_pair("pdc","d","c","_"),
                            forall("s", implies(apply("h","pdc","s","_"),
                                forall("pbc", implies(ordered_pair("pbc","b","c","_"),
                                    forall("t", implies(apply("h","pbc","t","_"),
                                        forall("pat", implies(ordered_pair("pat","a","t","_"),
                                            apply("h","pat","s","_"))))))))))))))))))))))), "z")
$_ tap("h_assoc_identity ok")

