from derived import mem, implies, forall, and, iff, exists, eqv, left, right, arg2
from vocab.sets import ordered_pair, product
from vocab.nat.nat import num, omega, successor
from vocab.functions import apply, function, single_valued, domain
from vocab.arithmetic.plus import plus_func
from tactics import ax, wr, wl, fl, fr, ir, mp, apply_thm, eir, eel, cut_c, close, same
from util.list import remove
from theorems.logic.and_intro import and_intro
from theorems.logic.and_elim_left import and_elim_left
from theorems.logic.and_elim_right import and_elim_right
from theorems.logic.iff_elim_left import iff_elim_left
from theorems.logic.iff_elim_right import iff_elim_right
from theorems.logic.iff_intro import iff_intro
from theorems.logic.iff_chain import iff_chain
from theorems.logic.eqv_reflexive import eqv_reflexive
from theorems.logic.eqv_symmetric import eqv_symmetric
from theorems.logic.eqv_mem_left import eqv_mem_left
from theorems.logic.ext_substitution import ext_substitution
from theorems.functions.func_unique_thm import func_unique_thm
from theorems.sets.ordpair_exists import ordpair_exists
from theorems.functions.domain_exists import domain_exists
from theorems.functions.domain_mem_elim import domain_mem_elim
from theorems.sets.product_exists import product_exists
from theorems.sets.product_in_intro import product_in_intro
from theorems.nat.nat.omega_induction import omega_induction
from theorems.nat.nat.omega_contains_zero import omega_contains_zero
from theorems.nat.nat.omega_succ_closed import omega_succ_closed
from theorems.nat.nat.omega_exists import omega_exists
from theorems.sets.ordpair_unique import ordpair_unique
from theorems.nat.nat.successor_unique import successor_unique
from theorems.nat.nat.successor_exists import successor_exists
from theorems.functions.apply_intro import apply_intro
from theorems.functions.apply_val_transfer import apply_val_transfer
from theorems.nat.nat.eq_succ_transfer import eq_succ_transfer
from theorems.functions.func_ext_from_agree import func_ext_from_agree

# plus_func_unique: PlusFunc(h1) → PlusFunc(h2) → Eqv(h1,h2)
# PlusFunc absorbed: ∀w.Omega(w)→And(func,dom_eq,base,step)
# Unwrap at omega witness, then omega induction + func_ext_from_agree.

$plus_func_unique {
    $om omega("w","_")
    $pf1_abs plus_func("h1","_")
    $pf2_abs plus_func("h2","_")

    # Unwrap PlusFunc at w: PlusFunc(h) = ∀w.Omega(w)→And(...)
    $pf1_inner and(function("h1","_"), and(
        forall("d", forall("prod", implies(domain("d","h1","_"), implies(product("prod","w","w","_"), eqv("d","prod","_"))))),
        and(forall("m", implies(mem("m","w"), forall("z", implies(num("z",0,"_"),
            forall("pair", implies(ordered_pair("pair","m","z","_"), apply("h1","pair","m","_"))))))),
            forall("m", implies(mem("m","w"), forall("n", implies(mem("n","w"),
                forall("pair", implies(ordered_pair("pair","m","n","_"), forall("p", implies(apply("h1","pair","p","_"),
                    forall("sn", implies(successor("sn","n","_"), forall("sp", implies(successor("sp","p","_"),
                        forall("pair2", implies(ordered_pair("pair2","m","sn","_"), apply("h1","pair2","sp","_"))))))))))))))))))
    $pf1_unwrap apply_thm(ax([pf1_abs],[pf1_abs],pf1_abs), pf1_abs, ["w"], ["w"],
        \w: implies(omega(w,"_"), pf1_inner), [pf1_abs])
    $pf1 mp(pf1_unwrap, ax([om],[om],om), om, pf1_inner, [pf1_abs], [om])

    $pf2_inner and(function("h2","_"), and(
        forall("d", forall("prod", implies(domain("d","h2","_"), implies(product("prod","w","w","_"), eqv("d","prod","_"))))),
        and(forall("m", implies(mem("m","w"), forall("z", implies(num("z",0,"_"),
            forall("pair", implies(ordered_pair("pair","m","z","_"), apply("h2","pair","m","_"))))))),
            forall("m", implies(mem("m","w"), forall("n", implies(mem("n","w"),
                forall("pair", implies(ordered_pair("pair","m","n","_"), forall("p", implies(apply("h2","pair","p","_"),
                    forall("sn", implies(successor("sn","n","_"), forall("sp", implies(successor("sp","p","_"),
                        forall("pair2", implies(ordered_pair("pair2","m","sn","_"), apply("h2","pair2","sp","_"))))))))))))))))))
    $pf2_unwrap apply_thm(ax([pf2_abs],[pf2_abs],pf2_abs), pf2_abs, ["w"], ["w"],
        \w: implies(omega(w,"_"), pf2_inner), [pf2_abs])
    $pf2 mp(pf2_unwrap, ax([om],[om],om), om, pf2_inner, [pf2_abs], [om])

    # Now pf1: [pf1_abs, om] ⊢ pf1_inner, pf2: [pf2_abs, om] ⊢ pf2_inner
    # The rest of the proof uses pf1 and pf2 as before, just with pf1_abs/pf2_abs/om in context.

    # Extract sv from PlusFunc:
    $func1 function("h1","_")
    $dom_eq1 forall("d", forall("prod", implies(domain("d","h1","_"), implies(product("prod","w","w","_"), eqv("d","prod","_")))))
    $base1 forall("m", implies(mem("m","w"), forall("z", implies(num("z",0,"_"),
        forall("pair", implies(ordered_pair("pair","m","z","_"), apply("h1","pair","m","_")))))))
    $step1 forall("m", implies(mem("m","w"), forall("n", implies(mem("n","w"),
        forall("pair", implies(ordered_pair("pair","m","n","_"), forall("p", implies(apply("h1","pair","p","_"),
            forall("sn", implies(successor("sn","n","_"), forall("sp", implies(successor("sp","p","_"),
                forall("pair2", implies(ordered_pair("pair2","m","sn","_"), apply("h1","pair2","sp","_")))))))))))))))
    $rest1a and(dom_eq1, and(base1, step1))
    $got_func1 mp(and_elim_left(func1, rest1a, []), pf1, pf1_inner,func1, [], left(pf1))
    $got_rest1 mp(and_elim_right(func1, rest1a, []), pf1, pf1_inner,rest1a, [], left(pf1))
    $got_base1 mp(and_elim_left(base1, step1, []),
        mp(and_elim_right(dom_eq1, and(base1, step1), []), got_rest1, rest1a, and(base1, step1), [], left(pf1)),
        and(base1, step1), base1, [], left(pf1))
    $got_step1 mp(and_elim_right(base1, step1, []),
        mp(and_elim_right(dom_eq1, and(base1, step1), []), got_rest1, rest1a, and(base1, step1), [], left(pf1)),
        and(base1, step1), step1, [], left(pf1))
    $rel1 forall("z", implies(mem("z","h1"), exists("x", exists("y", ordered_pair("z","x","y","_")))))
    $sv1 single_valued("h1","_")
    $got_sv1 mp(and_elim_right(rel1, sv1, []), got_func1, func1, sv1, [], left(pf1))

    # Same for h2:
    $func2 function("h2","_")
    $base2 forall("m", implies(mem("m","w"), forall("z", implies(num("z",0,"_"),
        forall("pair", implies(ordered_pair("pair","m","z","_"), apply("h2","pair","m","_")))))))
    $step2 forall("m", implies(mem("m","w"), forall("n", implies(mem("n","w"),
        forall("pair", implies(ordered_pair("pair","m","n","_"), forall("p", implies(apply("h2","pair","p","_"),
            forall("sn", implies(successor("sn","n","_"), forall("sp", implies(successor("sp","p","_"),
                forall("pair2", implies(ordered_pair("pair2","m","sn","_"), apply("h2","pair2","sp","_")))))))))))))))
    $rest2a and(forall("d", forall("prod", implies(domain("d","h2","_"), implies(product("prod","w","w","_"), eqv("d","prod","_"))))), and(base2, step2))
    $got_func2 mp(and_elim_left(func2, rest2a, []), pf2, pf2_inner,func2, [], left(pf2))
    $got_base2 mp(and_elim_left(base2, step2, []),
        mp(and_elim_right(forall("d", forall("prod", implies(domain("d","h2","_"), implies(product("prod","w","w","_"), eqv("d","prod","_"))))), and(base2, step2), []),
            mp(and_elim_right(func2, rest2a, []), pf2, pf2_inner,rest2a, [], left(pf2)),
            rest2a, and(base2, step2), [], left(pf2)),
        and(base2, step2), base2, [], left(pf2))
    $got_step2 mp(and_elim_right(base2, step2, []),
        mp(and_elim_right(forall("d", forall("prod", implies(domain("d","h2","_"), implies(product("prod","w","w","_"), eqv("d","prod","_"))))), and(base2, step2), []),
            mp(and_elim_right(func2, rest2a, []), pf2, pf2_inner,rest2a, [], left(pf2)),
            rest2a, and(base2, step2), [], left(pf2)),
        and(base2, step2), step2, [], left(pf2))
    $sv2 single_valued("h2","_")
    $got_sv2 mp(and_elim_right(forall("z", implies(mem("z","h2"), exists("x", exists("y", ordered_pair("z","x","y","_"))))), sv2, []),
        got_func2, func2, sv2, [], left(pf2))

    # === Omega induction: P(n) = ∀m∈w.∀pair.Op(pair,m,n)→∀v1.App(h1)→∀v2.App(h2)→Eqv(v1,v2) ===
    $pred \w n p: forall(add(p,"m"), implies(mem(add(p,"m"),w),
        forall(add(p,"pair"), implies(ordered_pair(add(p,"pair"),add(p,"m"),n,add(p,"_")),
            forall(add(p,"v1"), implies(apply("h1",add(p,"pair"),add(p,"v1"),add(p,"_")),
                forall(add(p,"v2"), implies(apply("h2",add(p,"pair"),add(p,"v2"),add(p,"_")),
                    eqv(add(p,"v1"),add(p,"v2"),add(p,"_"))))))))))
    $oi omega_induction(pred, ["h1","h2"], "_")

    # func_unique helper: sv → Apply(f,x,y1) → Apply(f,x,y2) → eqv(y1,y2)
    $_fu_b \f: \x: \y1: \y2: implies(
        single_valued(f,"_"),
        implies(apply(f,x,y1,"_"), implies(apply(f,x,y2,"_"), eqv(y1,y2,"_"))))
    # eqv_trans via iff_chain on membership:
    $_ic_b \a: \b: \c: implies(iff(a,b), implies(iff(b,c), iff(a,c)))

    # === BASE CASE: ∀e.num(e,0)→P(e) ===
    $emp num("e",0,"_")
    $mw mem("m","w")
    $op_pair ordered_pair("pair","m","e","_")
    $app1v apply("h1","pair","v1","_")
    $app2v apply("h2","pair","v2","_")
    $app1m apply("h1","pair","m","_")
    $app2m apply("h2","pair","m","_")

    # base1 at m,e,pair → Apply(h1,pair,m) — step by step
    $b1i apply_thm(got_base1, base1, ["m"], ["m"],
        \m: implies(mem(m,"w"), forall("z", implies(num("z",0,"_"), forall("pair", implies(ordered_pair("pair",m,"z","_"), apply("h1","pair",m,"_")))))), left(pf1))
    $b1a mp(b1i, ax([mw], [mw], mw), mw, arg2(head(right(b1i))), left(pf1), [mw])
    $b1b apply_thm(b1a, head(right(b1a)), ["e"], ["e"],
        \z: implies(num(z,0,"_"), forall("pair", implies(ordered_pair("pair","m",z,"_"), apply("h1","pair","m","_")))), left(b1a))
    $b1c mp(b1b, ax([emp], [emp], emp), emp, arg2(head(right(b1b))), left(b1a), [emp])
    $b1d apply_thm(b1c, head(right(b1c)), ["pair"], ["pair"],
        \pair: implies(ordered_pair(pair,"m","e","_"), apply("h1",pair,"m","_")), left(b1c))
    $gb1 mp(b1d, ax([op_pair], [op_pair], op_pair), op_pair, app1m, left(b1c), [op_pair])
    # func_unique h1: v1=m
    $fu1_inst apply_thm(func_unique_thm, head(right(func_unique_thm)), ["h1","pair","v1","m"],
        ["f","x","y1","y2"], _fu_b, [])
    $fu1a mp(fu1_inst, got_sv1, sv1, implies(app1v, implies(app1m, eqv("v1","m","_"))), [], left(pf1))
    $fu1b mp(fu1a, ax([app1v], [app1v], app1v), app1v, implies(app1m, eqv("v1","m","_")), left(pf1), [app1v])
    $geq1 mp(fu1b, gb1, app1m, eqv("v1","m","_"), left(fu1b), left(gb1))

    # base2 at m,e,pair → Apply(h2,pair,m), func_unique h2: v2=m
    $b2i apply_thm(got_base2, base2, ["m"], ["m"],
        \m: implies(mem(m,"w"), forall("z", implies(num("z",0,"_"), forall("pair", implies(ordered_pair("pair",m,"z","_"), apply("h2","pair",m,"_")))))), left(pf2))
    $b2a mp(b2i, ax([mw], [mw], mw), mw, arg2(head(right(b2i))), left(pf2), [mw])
    $b2b apply_thm(b2a, head(right(b2a)), ["e"], ["e"],
        \z: implies(num(z,0,"_"), forall("pair", implies(ordered_pair("pair","m",z,"_"), apply("h2","pair","m","_")))), left(b2a))
    $b2c mp(b2b, ax([emp], [emp], emp), emp, arg2(head(right(b2b))), left(b2a), [emp])
    $b2d apply_thm(b2c, head(right(b2c)), ["pair"], ["pair"],
        \pair: implies(ordered_pair(pair,"m","e","_"), apply("h2",pair,"m","_")), left(b2c))
    $gb2 mp(b2d, ax([op_pair], [op_pair], op_pair), op_pair, app2m, left(b2c), [op_pair])
    $fu2_inst apply_thm(func_unique_thm, head(right(func_unique_thm)), ["h2","pair","v2","m"],
        ["f","x","y1","y2"], _fu_b, [])
    $fu2a mp(fu2_inst, got_sv2, sv2, implies(app2v, implies(app2m, eqv("v2","m","_"))), [], left(pf2))
    $fu2b mp(fu2a, ax([app2v], [app2v], app2v), app2v, implies(app2m, eqv("v2","m","_")), left(pf2), [app2v])
    $geq2 mp(fu2b, gb2, app2m, eqv("v2","m","_"), left(fu2b), left(gb2))

    # eqv_trans: eqv(v1,m) + eqv(m,v2) → eqv(v1,v2) via iff_chain on membership
    $_es_b \a: \b: implies(eqv(a,b,"_"), eqv(b,a,"_"))
    $geq2s mp(apply_thm(eqv_symmetric, head(right(eqv_symmetric)), ["v2","m"], ["a","b"], _es_b, []),
        geq2, eqv("v2","m","_"), eqv("m","v2","_"), [], left(geq2))
    # fl eqv(v1,m) at zz, fl eqv(m,v2) at zz, iff_chain
    $iff_v1m iff(mem("zz","v1"), mem("zz","m"))
    $iff_mv2 iff(mem("zz","m"), mem("zz","v2"))
    $iff_v1v2 iff(mem("zz","v1"), mem("zz","v2"))
    $giff1 fl(ax([iff_v1m], [iff_v1m], iff_v1m), [eqv("v1","m","_")], [iff_v1m], eqv("v1","m","_"), "zz")
    $giff2 fl(ax([iff_mv2], [iff_mv2], iff_mv2), [eqv("m","v2","_")], [iff_mv2], eqv("m","v2","_"), "zz")
    # iff_chain(A,B,C,vars): iff(A,B) → iff(B,C) → iff(A,C)
    $ic iff_chain(mem("zz","v1"), mem("zz","m"), mem("zz","v2"), [])
    $giff3 mp(mp(ic, giff1, iff_v1m, implies(iff_mv2, iff_v1v2), [], [eqv("v1","m","_")]),
        giff2, iff_mv2, iff_v1v2, [eqv("v1","m","_")], [eqv("m","v2","_")])
    $giff4 cut_c(geq1, cut_c(geq2s, giff3, eqv("m","v2","_"), left(geq2s), left(giff3), iff_v1v2),
        eqv("v1","m","_"), left(geq1), left(cut_c(geq2s, giff3, eqv("m","v2","_"), left(geq2s), left(giff3), iff_v1v2)), iff_v1v2)
    $eqv_v1v2 eqv("v1","v2","_")
    $got_base_eqv fr(giff4, left(giff4), [eqv_v1v2], eqv_v1v2, "zz")

    # Close base: ir app2v, fr v2, ir app1v, fr v1, ir op_pair, fr pair, ir mw, fr m, ir emp, fr e
    $cur got_base_eqv
    $cur ir(cur, remove(same, app2v, left(cur)), [implies(app2v, eqv_v1v2)], implies(app2v, eqv_v1v2))
    $cur fr(cur, left(cur), [forall("v2", implies(app2v, eqv_v1v2))], forall("v2", implies(app2v, eqv_v1v2)), "v2")
    $iv1 implies(app1v, head(right(cur)))
    $cur ir(cur, remove(same, app1v, left(cur)), [iv1], iv1)
    $cur fr(cur, left(cur), [forall("v1", iv1)], forall("v1", iv1), "v1")
    $ip implies(op_pair, head(right(cur)))
    $cur ir(cur, remove(same, op_pair, left(cur)), [ip], ip)
    $cur fr(cur, left(cur), [forall("pair", ip)], forall("pair", ip), "pair")
    $im implies(mw, head(right(cur)))
    $cur ir(cur, remove(same, mw, left(cur)), [im], im)
    $cur fr(cur, left(cur), [forall("m", im)], forall("m", im), "m")
    $ie implies(emp, head(right(cur)))
    $cur ir(cur, remove(same, emp, left(cur)), [ie], ie)
    $base_case forall("e", ie)
    $got_bc fr(cur, left(cur), [base_case], base_case, "e")

    # Extract dom_eq from both PlusFuncs:
    $got_deq1 mp(and_elim_left(dom_eq1, and(base1, step1), []),
        got_rest1, rest1a, dom_eq1, [], left(pf1))
    $dom_eq2 forall("d", forall("prod", implies(domain("d","h2","_"), implies(product("prod","w","w","_"), eqv("d","prod","_")))))
    $got_deq2 mp(and_elim_left(dom_eq2, and(base2, step2), []),
        mp(and_elim_right(func2, and(dom_eq2, and(base2, step2)), []),
            pf2, pf2_inner,and(dom_eq2, and(base2, step2)), [], left(pf2)),
        and(dom_eq2, and(base2, step2)), dom_eq2, [], left(pf2))

    # === STEP CASE: ∀n. n∈w → P(n) → ∀s. Succ(s,n) → P(s) ===
    # Assume nw, P(n), Succ(s,n), mw, OrdPair(pair2,m,s), Apply(h1,pair2,v1), Apply(h2,pair2,v2).
    # Derive Eqv(v1,v2).
    $nw mem("n","w")
    $pn pred("w","n","_")
    $succ_sn successor("s","n","_")
    $op_s ordered_pair("pair2","m","s","_")
    $app1s apply("h1","pair2","v1","_")
    $app2s apply("h2","pair2","v2","_")

    # --- A. ordpair_exists ⟨m,n⟩ ---
    $oe_ctx left(ordpair_exists)
    $_oe_b \a: \b: exists("p", ordered_pair("p",a,b,"_"))
    $got_ex_pmn apply_thm(ordpair_exists, head(right(ordpair_exists)), ["m","n"], ["a","b"], _oe_b, oe_ctx)
    $op_pmn ordered_pair("pmn","m","n","_")

    # --- B. product_in_intro: pmn∈pww ---
    $pe_ctx left(product_exists)
    $_pe_b \a: \b: exists("p", product("p",a,b,"_"))
    $got_pe apply_thm(product_exists, head(right(product_exists)), ["w","w"], ["a","b"], _pe_b, pe_ctx)
    $prod_pww product("pww","w","w","_")
    $_pii_b \q1: \q2: \q3: \q4: \q5: \q6: implies(product(q1,q2,q3,"_"),
        implies(mem(q4,q2), implies(mem(q5,q3), implies(ordered_pair(q6,q4,q5,"_"), mem(q6,q1)))))
    $pii_r forall("q1", forall("q2", forall("q3", forall("q4", forall("q5", forall("q6",
        _pii_b("q1")("q2")("q3")("q4")("q5")("q6")))))))
    $pii_thm wr(product_in_intro, [], [pii_r], pii_r)
    $pmn_pww mem("pmn","pww")
    $pii_inst apply_thm(pii_thm, pii_r, ["pww","w","w","m","n","pmn"],
        ["q1","q2","q3","q4","q5","q6"], _pii_b, [])
    $pi1 mp(pii_inst, ax([prod_pww], [prod_pww], prod_pww), prod_pww, arg2(head(right(pii_inst))), [], [prod_pww])
    $pi2 mp(pi1, ax([mw], [mw], mw), mw, arg2(head(right(pi1))), [prod_pww], [mw])
    $pi3 mp(pi2, ax([nw], [nw], nw), nw, arg2(head(right(pi2))), [prod_pww, mw], [nw])
    $got_pmn_pww mp(pi3, ax([op_pmn], [op_pmn], op_pmn), op_pmn, pmn_pww, left(pi3), [op_pmn])

    # --- C. Domain chain for h1: pmn∈dh1 → ∃p1.Apply(h1,pmn,p1) ---
    $de_ctx left(domain_exists)
    $dom_dh1 domain("dh1","h1","_")
    # dom_eq1 at dh1,pww → Eqv(dh1,pww)
    $deq1i apply_thm(got_deq1, dom_eq1, ["dh1","pww"], ["d","prod"],
        \d: \prod: implies(domain(d,"h1","_"), implies(product(prod,"w","w","_"), eqv(d,prod,"_"))), left(pf1))
    $deq1a mp(deq1i, ax([dom_dh1], [dom_dh1], dom_dh1), dom_dh1, implies(prod_pww, eqv("dh1","pww","_")), left(pf1), [dom_dh1])
    $deq1b mp(deq1a, ax([prod_pww], [prod_pww], prod_pww), prod_pww, eqv("dh1","pww","_"), left(deq1a), [prod_pww])
    # eqv(pww,dh1) → pmn∈pww → pmn∈dh1
    $got_epd1 mp(apply_thm(eqv_symmetric, head(right(eqv_symmetric)), ["dh1","pww"], ["a","b"], _es_b, []),
        deq1b, eqv("dh1","pww","_"), eqv("pww","dh1","_"), [], left(deq1b))
    $_eml_b \a: \b: \z: implies(eqv(a,b,"_"), implies(mem(z,a), mem(z,b)))
    $got_pmn_dh1 mp(mp(apply_thm(eqv_mem_left, head(right(eqv_mem_left)), ["pww","dh1","pmn"],
        ["a","b","z"], _eml_b, []),
        got_epd1, eqv("pww","dh1","_"), implies(pmn_pww, mem("pmn","dh1")), [], left(got_epd1)),
        got_pmn_pww, pmn_pww, mem("pmn","dh1"), left(got_epd1), left(got_pmn_pww))
    # domain_mem_elim: dom_dh1 → pmn∈dh1 → ∃p1.Apply(h1,pmn,p1)
    # close vars ["x","d","f"] → outermost "f"
    $_dme_b \f: \d: \x: implies(domain(d,f,"_"), implies(mem(x,d), exists("y", apply(f,x,"y","_"))))
    $dme1 apply_thm(domain_mem_elim, head(right(domain_mem_elim)), ["h1","dh1","pmn"],
        ["f","d","x"], _dme_b, [])
    $got_ex_p1 mp(mp(dme1, ax([dom_dh1], [dom_dh1], dom_dh1), dom_dh1,
        implies(mem("pmn","dh1"), exists("y", apply("h1","pmn","y","_"))), [], [dom_dh1]),
        got_pmn_dh1, mem("pmn","dh1"), exists("y", apply("h1","pmn","y","_")), [dom_dh1], left(got_pmn_dh1))
    # eel dh1, cut domain_exists
    $got_ex_p1b eel(got_ex_p1, \d: domain(d,"h1","_"), "d", "dh1", left(got_ex_p1),
        exists("y", apply("h1","pmn","y","_")))
    $got_de1 apply_thm(domain_exists, head(right(domain_exists)), ["h1"], ["h1"],
        \f: exists("d", domain("d",f,"_")), de_ctx)
    $got_ex_p1c cut_c(got_de1, got_ex_p1b, head(right(got_de1)), de_ctx, left(got_ex_p1b),
        exists("y", apply("h1","pmn","y","_")))
    # eel pww, cut product_exists
    $got_ex_p1d eel(got_ex_p1c, \pww: product(pww,"w","w","_"), "p", "pww", left(got_ex_p1c),
        exists("y", apply("h1","pmn","y","_")))
    $got_ex_p1e cut_c(got_pe, got_ex_p1d, head(right(got_pe)), pe_ctx, left(got_ex_p1d),
        exists("y", apply("h1","pmn","y","_")))
    # [pe_ctx, de_ctx, pf1, op_pmn, nw, mw] |- ∃p1.Apply(h1,pmn,p1)

    # --- D. Same domain chain for h2 ---
    $dom_dh2 domain("dh2","h2","_")
    $deq2i apply_thm(got_deq2, dom_eq2, ["dh2","pww"], ["d","prod"],
        \d: \prod: implies(domain(d,"h2","_"), implies(product(prod,"w","w","_"), eqv(d,prod,"_"))), left(pf2))
    $deq2a mp(deq2i, ax([dom_dh2], [dom_dh2], dom_dh2), dom_dh2, implies(prod_pww, eqv("dh2","pww","_")), left(pf2), [dom_dh2])
    $deq2b mp(deq2a, ax([prod_pww], [prod_pww], prod_pww), prod_pww, eqv("dh2","pww","_"), left(deq2a), [prod_pww])
    $got_epd2 mp(apply_thm(eqv_symmetric, head(right(eqv_symmetric)), ["dh2","pww"], ["a","b"], _es_b, []),
        deq2b, eqv("dh2","pww","_"), eqv("pww","dh2","_"), [], left(deq2b))
    $got_pmn_dh2 mp(mp(apply_thm(eqv_mem_left, head(right(eqv_mem_left)), ["pww","dh2","pmn"],
        ["a","b","z"], _eml_b, []),
        got_epd2, eqv("pww","dh2","_"), implies(pmn_pww, mem("pmn","dh2")), [], left(got_epd2)),
        got_pmn_pww, pmn_pww, mem("pmn","dh2"), left(got_epd2), left(got_pmn_pww))
    $dme2 apply_thm(domain_mem_elim, head(right(domain_mem_elim)), ["h2","dh2","pmn"],
        ["f","d","x"], _dme_b, [])
    $got_ex_p2 mp(mp(dme2, ax([dom_dh2], [dom_dh2], dom_dh2), dom_dh2,
        implies(mem("pmn","dh2"), exists("y", apply("h2","pmn","y","_"))), [], [dom_dh2]),
