from derived import mem, implies, forall, and, iff, exists, eqv, left, right, arg2
from vocab.sets import ordered_pair
from vocab.nat.nat import nat, num, omega, successor
from vocab.functions import apply, function, single_valued, domain
from vocab.sets import product
from vocab.arithmetic.plus import plus_func, plus
from tactics import ax, wr, fl, fr, ir, mp, apply_thm, eir, eel, cut_c, close, same
from util import remove
from theorems.logic.and_elim_left import and_elim_left
from theorems.logic.and_elim_right import and_elim_right
from theorems.functions.func_unique_thm import func_unique_thm
from theorems.sets.ordpair_exists import ordpair_exists
from theorems.arithmetic.plus.plus_func_exists import plus_func_exists
from theorems.nat.nat.omega_exists import omega_exists

# plus_val_unique: ∀a,b,c,c2. Plus(a,b,c) → Plus(a,b,c2) → Eqv(c,c2)

$plus_val_unique {
    $plus_abc plus("a","b","c","_")
    $plus_abc2 plus("a","b","c2","_")
    $goal eqv("c","c2","_")

    # PlusFunc(h)
    $pf_abs plus_func("h","_")

    # === Extract SingleValued(h) from PlusFunc(h) ===
    $func_h function("h","_")
    $sv_h single_valued("h","_")
    $dom_eq forall("d", forall("prod", implies(domain("d","h","_"), implies(product("prod","w","w","_"), eqv("d","prod","_")))))
    $base_f forall("m", implies(mem("m","w"), forall("zz", implies(num("zz",0,"_"),
        forall("pair", implies(ordered_pair("pair","m","zz","_"), apply("h","pair","m","_")))))))
    $step_f forall("m", implies(mem("m","w"), forall("n", implies(mem("n","w"),
        forall("pair", implies(ordered_pair("pair","m","n","_"), forall("p", implies(apply("h","pair","p","_"),
            forall("sn", implies(successor("sn","n","_"), forall("sp", implies(successor("sp","p","_"),
                forall("pair2", implies(ordered_pair("pair2","m","sn","_"), apply("h","pair2","sp","_")))))))))))))))
    $om omega("w","_")
    $pf_inner and(func_h, and(dom_eq, and(base_f, step_f)))
    $pf_unwrap apply_thm(ax([pf_abs],[pf_abs],pf_abs), pf_abs, ["w"], ["w"],
        \w: implies(omega(w,"_"), pf_inner), [pf_abs])
    $pf_at_w mp(pf_unwrap, ax([om],[om],om), om, pf_inner, [pf_abs], [om])
    $got_func mp(and_elim_left(func_h, and(dom_eq, and(base_f, step_f)), []),
        pf_at_w, pf_inner, func_h, [], left(pf_at_w))
    $got_sv mp(and_elim_right(
        forall("z", implies(mem("z","h"), exists("x", exists("y", ordered_pair("z","x","y","_"))))),
        sv_h, []), got_func, func_h, sv_h, [], left(pf_at_w))

    $_ tap("sv ok")

    # === Open Plus(a,b,c) at h → Apply(h,pair,c) ===
    $op_ab ordered_pair("pair","a","b","_")
    $app_c apply("h","pair","c","_")
    $pi1 apply_thm(ax([plus_abc],[plus_abc],plus_abc), plus_abc, ["h"], ["h"],
        \h: implies(plus_func(h,"_"), forall("pair", implies(ordered_pair("pair","a","b","_"), apply(h,"pair","c","_")))),
        [plus_abc])
    $pi2 mp(pi1, ax([pf_abs],[pf_abs],pf_abs), pf_abs,
        forall("pair", implies(op_ab, app_c)), [plus_abc], [pf_abs])
    $pi3 apply_thm(pi2, head(right(pi2)), ["pair"], ["pair"],
        \pair: implies(ordered_pair(pair,"a","b","_"), apply("h",pair,"c","_")), left(pi2))
    $got_app_c mp(pi3, ax([op_ab],[op_ab],op_ab), op_ab, app_c, left(pi3), [op_ab])

    $_ tap("app_c ok")

    # === Open Plus(a,b,c2) at h → Apply(h,pair,c2) ===
    $app_c2 apply("h","pair","c2","_")
    $qi1 apply_thm(ax([plus_abc2],[plus_abc2],plus_abc2), plus_abc2, ["h"], ["h"],
        \h: implies(plus_func(h,"_"), forall("pair", implies(ordered_pair("pair","a","b","_"), apply(h,"pair","c2","_")))),
        [plus_abc2])
    $qi2 mp(qi1, ax([pf_abs],[pf_abs],pf_abs), pf_abs,
        forall("pair", implies(op_ab, app_c2)), [plus_abc2], [pf_abs])
    $qi3 apply_thm(qi2, head(right(qi2)), ["pair"], ["pair"],
        \pair: implies(ordered_pair(pair,"a","b","_"), apply("h",pair,"c2","_")), left(qi2))
    $got_app_c2 mp(qi3, ax([op_ab],[op_ab],op_ab), op_ab, app_c2, left(qi3), [op_ab])

    $_ tap("app_c2 ok")

    # === func_unique: sv → Apply(h,pair,c) → Apply(h,pair,c2) → Eqv(c,c2) ===
    $_fu_b \f: \x: \y1: \y2: implies(single_valued(f,"_"),
        implies(apply(f,x,y1,"_"), implies(apply(f,x,y2,"_"), eqv(y1,y2,"_"))))
    $fu_inst apply_thm(func_unique_thm, head(right(func_unique_thm)), ["h","pair","c","c2"],
        ["f","x","y1","y2"], _fu_b, [])
    $fu1 mp(fu_inst, got_sv, sv_h, arg2(head(right(fu_inst))), [], left(pf_at_w))
    $fu2 mp(fu1, got_app_c, app_c, implies(app_c2, goal), left(fu1), left(got_app_c))
    $got_goal mp(fu2, got_app_c2, app_c2, goal, left(fu2), left(got_app_c2))

    $_ tap("unique ok")

    # === eel pair from ordpair_exists ===
    $oe_ctx left(ordpair_exists)
    $oe_renamed forall("oa", forall("ob", exists("p", ordered_pair("p","oa","ob","_"))))
    $oe_wr wr(ordpair_exists, oe_ctx, [oe_renamed], oe_renamed)
    $_oe_b \oa: \ob: exists("p", ordered_pair("p",oa,ob,"_"))
    $got_oe apply_thm(oe_wr, oe_renamed, ["a","b"], ["oa","ob"], _oe_b, oe_ctx)
    $cur eel(got_goal, \pair: ordered_pair(pair,"a","b","_"), "p", "pair", left(got_goal), goal)
    $cur cut_c(got_oe, cur, head(right(got_oe)), oe_ctx, left(cur), goal)

    # === eel h from plus_func_exists ===
    $cur eel(cur, \h: plus_func(h,"_"), "h", "h", left(cur), goal)
    $ex_h exists("h", plus_func("h","_"))
    $cur cut_c(plus_func_exists, cur, ex_h, left(plus_func_exists), left(cur), goal)

    # === eel w from omega_exists ===
    $cur eel(cur, \w: omega(w,"_"), "w", "w", remove(same, om, left(cur)), goal)
    $cur cut_c(omega_exists, cur, exists("w", omega("w","_")), left(omega_exists), left(cur), goal)

    $_ tap("eel ok")

    # === Discharge and close ===
    $cur ir(cur, remove(same, plus_abc2, left(cur)), [implies(plus_abc2, goal)], implies(plus_abc2, goal))
    $cur ir(cur, remove(same, plus_abc, left(cur)), [implies(plus_abc, head(right(cur)))], implies(plus_abc, head(right(cur))))
    $cur fr(cur, left(cur), [forall("c2", head(right(cur)))], forall("c2", head(right(cur))), "c2")
    $cur fr(cur, left(cur), [forall("c", head(right(cur)))], forall("c", head(right(cur))), "c")
    $cur fr(cur, left(cur), [forall("b", head(right(cur)))], forall("b", head(right(cur))), "b")
    $top forall("a", head(right(cur)))
    $cur fr(cur, left(cur), [top], top, "a")
    close(cur, left(cur), [top], [])
}
