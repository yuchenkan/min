        implies(apply("a","x","y","_"), implies(union("u","a","b","_"), apply("u","x","y","_")))))))))
$_ print("union_apply_left ok")

$_ qed(union_apply_right,
    forall("u", forall("a", forall("b", forall("x", forall("y",
        implies(apply("b","x","y","_"), implies(union("u","a","b","_"), apply("u","x","y","_")))))))))
$_ print("union_apply_right ok")

$_ qed(domain_mem_intro,
    forall("f", forall("d", forall("x", forall("y",
        implies(apply("f","x","y","_"), implies(domain("d","f","_"), mem("x","d"))))))))
$_ print("domain_mem_intro ok")

$_ qed(domain_mem_elim,
    forall("f", forall("d", forall("x",
        implies(domain("d","f","_"), implies(mem("x","d"), exists("y2", apply("f","x","y2","_"))))))))
$_ print("domain_mem_elim ok")

$_ qed(apply_key_transfer,
    forall("f", forall("x", forall("x2", forall("y",
        implies(eqv("x","x2","_"), implies(apply("f","x","y","_"), apply("f","x2","y","_"))))))))
$_ print("apply_key_transfer ok")

$_ qed(apply_val_transfer,
    forall("f", forall("x", forall("y", forall("y2",
        implies(eqv("y","y2","_"), implies(apply("f","x","y","_"), apply("f","x","y2","_"))))))))
