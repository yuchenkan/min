        implies(domain("s1","f","_"), implies(domain("s2","f","_"), eq("s1","s2","_")))))), "z")
$_ tap("domain_unique ok")

$_ qed(unique_domain, forall("f", exists_unique(\v p: domain(v, "f", p), "_")), "z")
