$efc_top implies(function("v","_"), implies(singleton("h","op","_"), implies(ordered_pair("op","k","y0","_"),
    implies(forall("z", implies(apply("v","k","z","_"), eq("y0","z","_"))),
        implies(union("u","v","h","_"), function("u","_"))))))
$_ qed(extend_function, forall("v", forall("k", forall("y0", forall("op", forall("h", forall("u", efc_top)))))), "z")
$_ tap("extend_function ok")

$_ qed(apply_func_transfer, forall("f", forall("g", forall("x", forall("y",
    implies(eq("f", "g", "_"), implies(apply("f", "x", "y", "_"),
        apply("g", "x", "y", "_"))))))), "z")
$_ tap("apply_func_transfer ok")

$_ qed(func_eq_transfer, forall("f", forall("g",
    implies(eq("f", "g", "_"), implies(function("f", "_"), function("g", "_"))))), "z")
$_ tap("func_eq_transfer ok")


$ok true
