$_ qed(domain_exists, forall("f", exists("d", domain("d", "f", "_"))))
$_ print("domain_exists ok")

$_ qed(unique_domain, forall("f", exists_unique(\v p: domain(v, "f", p), "_")))
$_ print("unique_domain ok")

$_ qed(func_unique_thm, forall("f", forall("x", forall("y1", forall("y2",
    implies(single_valued("f","_"),
        implies(apply("f","x","y1","_"), implies(apply("f","x","y2","_"), eqv("y1","y2","_")))))))))
$_ print("func_unique_thm ok")

$_ qed(func_preserves_eq, forall("f", forall("x1", forall("x2", forall("y1", forall("y2",
    implies(single_valued("f","_"), implies(eqv("x1","x2","_"), implies(apply("f","x1","y1","_"),
        implies(apply("f","x2","y2","_"), eqv("y1","y2","_")))))))))))
$_ print("func_preserves_eq ok")

$_ qed(apply_intro, forall("p", forall("f", forall("x", forall("y",
    implies(ordered_pair("p","x","y","_"), implies(mem("p","f"), apply("f","x","y","_"))))))))
$_ print("apply_intro ok")



$_fea_agree forall("x", forall("v1", forall("v2", implies(apply("h1","x","v1","_"), implies(apply("h2","x","v2","_"), eqv("v1","v2","_"))))))
$_fea_df forall("x", forall("v", implies(apply("h1","x","v","_"), exists("v2", apply("h2","x","v2","_")))))
$_fea_db forall("x", forall("v", implies(apply("h2","x","v","_"), exists("v1", apply("h1","x","v1","_")))))
$_fea_top implies(relation("h1","_"), implies(relation("h2","_"), implies(_fea_agree, implies(_fea_df, implies(_fea_db, eqv("h1","h2","_"))))))
$_ qed(func_ext_from_agree, forall("h1", forall("h2", _fea_top)))
$_ print("func_ext_from_agree ok")

$_ qed(apply_in_double_union,
    forall("f", forall("x", forall("y", forall("uf", forall("uuf",
        implies(apply("f","x","y","_"), implies(big_union("uf","f","_"),
            implies(big_union("uuf","uf","_"), mem("x","uuf"))))))))))
$_ print("apply_in_double_union ok")

$_ qed(domain_exists, forall("f", exists("d", domain("d", "f", "_"))))
$_ print("domain_exists ok")

$_ qed(domain_unique,
    forall("f", forall("s1", forall("s2",
        implies(domain("s1","f","_"), implies(domain("s2","f","_"), eqv("s1","s2","_")))))))
$_ print("domain_unique ok")

$_ qed(unique_domain, forall("f", exists_unique(\v p: domain(v, "f", p), "_")))
$_ print("unique_domain ok")

