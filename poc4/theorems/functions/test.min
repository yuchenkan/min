from core.derived import mem, neg, implies, forall, and, or, iff, exists, eqv, qed
from vocab.sets import ordered_pair, successor, singleton, big_union, union, relation, product
from vocab.functions import apply, function, single_valued, domain
from vocab.logic import exists_unique
from theorems.functions.domain_exists import domain_exists
from theorems.functions.unique_domain import unique_domain
