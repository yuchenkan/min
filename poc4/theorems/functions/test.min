$_ qed(union_apply_elim,
    forall("u", forall("a", forall("b", forall("x", forall("y",
        implies(apply("u","x","y","_"), implies(union("u","a","b","_"),
            or(apply("a","x","y","_"), apply("b","x","y","_"))))))))))
$_ print("union_apply_elim ok")

$_ qed(domain_neg_no_apply,
    forall("f", forall("d", forall("x", forall("y",
        implies(domain("d","f","_"), implies(neg(mem("x","d")), neg(apply("f","x","y","_")))))))))
$_ print("domain_neg_no_apply ok")

$_ qed(extend_apply_new,
    forall("u", forall("h", forall("op", forall("g", forall("k", forall("v",
        implies(singleton("h","op","_"), implies(ordered_pair("op","k","v","_"),
            implies(union("u","g","h","_"), apply("u","k","v","_")))))))))))
$_ print("extend_apply_new ok")

$_ qed(extend_apply_old,
    forall("u", forall("g", forall("h", forall("x", forall("y",
        implies(apply("g","x","y","_"), implies(union("u","g","h","_"), apply("u","x","y","_")))))))))
$_ print("extend_apply_old ok")

$_ qed(eqv_apply,
    forall("f", forall("g", forall("x", forall("y",
        implies(eqv("f","g","_"), implies(apply("f","x","y","_"), apply("g","x","y","_"))))))))
$_ print("eqv_apply ok")

$efc_top implies(function("v","_"), implies(singleton("h","op","_"), implies(ordered_pair("op","k","y0","_"),
    implies(forall("z", implies(apply("v","k","z","_"), eqv("y0","z","_"))),
        implies(union("u","v","h","_"), function("u","_"))))))
$_ qed(extend_function, forall("v", forall("k", forall("y0", forall("op", forall("h", forall("u", efc_top)))))))
$_ print("extend_function ok")





$ok true
