$_ qed(func_unique_thm, forall("f", forall("x", forall("y1", forall("y2",
    implies(sv, implies(apply("f","x","y1","_"), implies(apply("f","x","y2","_"), eqv("y1","y2","_")))))))))
$_ print("func_unique_thm ok")

$_ qed(func_preserves_eq, forall("f", forall("x1", forall("x2", forall("y1", forall("y2",
    implies(sv, implies(eqv("x1","x2","_"), implies(apply("f","x1","y1","_"),
        implies(apply("f","x2","y2","_"), eqv("y1","y2","_")))))))))))
$_ print("func_preserves_eq ok")

