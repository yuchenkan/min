from core.derived import implies, iff
from tactics import ax, ir, mp, close
from theorems.logic.iff_intro import iff_intro

# |- iff(P, P)
$iff_refl \P vars: {
    $id implies(P, P)
    $iff_PP iff(P, P)
    $got_id ir(ax([P], [P], P), [], [id], id)
    $s1 mp(iff_intro(P, P, []), got_id, id, implies(id, iff_PP), [], [])
    $result mp(s1, got_id, id, iff_PP, [], [])
    close(result, [], [iff_PP], vars)
}
