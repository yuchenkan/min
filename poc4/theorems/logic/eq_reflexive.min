from derived import mem, iff, eq
from tactics import fr, close
from theorems.logic.iff_refl import iff_refl

# |- forall(a, eq(a, a))
$eq_reflexive {
    $P mem("z", "a")
    $got iff_refl(P, [])
    $eq_aa eq("a", "a", "_")
    $s1 fr(got, [], [eq_aa], eq_aa, "z")
    close(s1, [], [eq_aa], ["a"])
}
