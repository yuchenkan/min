from derived import neg, implies, and
from tactics import ax, wr, nl, ir, close

# |- and(A, B) -> A
$and_elim_left \A B vars: {
    $and_AB and(A, B)
    $not_B neg(B)
    $imp_A_notB implies(A, not_B)
    $s1 wr(ax([A], [A], A), [A], [A, not_B], not_B)
    $s2 ir(s1, [], [imp_A_notB, A], imp_A_notB)
    $s3 nl(s2, [and_AB], [A], and_AB)
    $top implies(and_AB, A)
    $s4 ir(s3, [], [top], top)
    close(s4, [], [top], vars)
}
