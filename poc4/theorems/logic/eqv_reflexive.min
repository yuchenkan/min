from derived import mem, iff, eqv
from tactics import fr, close
from theorems.logic.iff_refl import iff_refl

# |- forall(a, eqv(a, a))
$eqv_reflexive {
    $P mem("z", "a")
    $got iff_refl(P, [])
    $eqv_aa eqv("a", "a", "_")
    $s1 fr(got, [], [eqv_aa], eqv_aa, "z")
    close(s1, [], [eqv_aa], ["a"])
}
