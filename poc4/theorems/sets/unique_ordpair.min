from core.derived import implies, forall, exists, or, eqv, pairing_ax, left, right
from vocab.sets import singleton, pair_set, ordered_pair
from vocab.logic import exists_unique
from tactics import ax, fr, mp, wl, apply_thm, eel, cut_c, close
from theorems.logic.exists_unique_intro import exists_unique_intro
from theorems.sets.ordpair_unique import ordpair_unique
from theorems.sets.ordpair_exists import ordpair_exists

# pairing_ax |- forall(a, forall(b, exists_unique(p, ordered_pair(p, a, b))))
$unique_ordpair {
    $body_fn \v p: ordered_pair(v, "a", "b", p)
    $eu exists_unique(body_fn, "_")
    $op_u body_fn("u", "_")
    $imp_inner implies(body_fn("y", "_"), eqv("u", "y", "_"))
    $_ou_f head(right(ordpair_unique))
    $ou_inst apply_thm(ordpair_unique, _ou_f, [["a", ["b","s1","s2"]], ["b", ["s1","s2"]], ["u", ["s2"]], ["y", []]],
        \a: \b: \s1: \s2: implies(ordered_pair(s1,a,b,"_"), implies(ordered_pair(s2,a,b,"_"), eqv(s1,s2,"_"))), [])
    $got_inner mp(ou_inst, ax([op_u], [op_u], op_u), op_u, imp_inner, [], [op_u])
    $fa_uniq forall("y", imp_inner)
    $got_fa fr(got_inner, [op_u], [fa_uniq], fa_uniq, "y")
    $got_eu mp(mp(exists_unique_intro(body_fn, "u", []), ax([op_u], [op_u], op_u), op_u, implies(fa_uniq, eu), [], [op_u]),
               got_fa, fa_uniq, eu, [op_u], [op_u])
    $got_ex eel(got_eu, \v: body_fn(v, "_"), "p", "u", [op_u], eu)
    $_oe_f head(right(ordpair_exists))
    $oe_ctx left(ordpair_exists)
    $got_oe apply_thm(ordpair_exists, _oe_f, [["a", ["b"]], ["b", []]],
        \a: \b: exists("p", ordered_pair("p",a,b,"_")), oe_ctx)
    $ex_op exists("p", body_fn("p", "_"))
    $got_cut cut_c(got_oe, got_ex, ex_op, oe_ctx, [ex_op], eu)
    close(got_cut, oe_ctx, [eu], ["b","a"])
}
