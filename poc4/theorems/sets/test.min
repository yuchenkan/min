$ob_sub_w forall("d", implies(mem("d","s"), mem("d","w")))
$ob_pw forall("s", iff(mem("s","pw"), ob_sub_w))
$ob_sub_pw forall("d", implies(mem("d","s"), mem("d","pw")))
$ob_ppw forall("s", iff(mem("s","ppw"), ob_sub_pw))
$ob_body implies(mem("x","w"), implies(mem("y","w"), implies(ordered_pair("p","x","y","_"), implies(ob_pw, implies(ob_ppw, mem("p","ppw"))))))
$_ qed(ordpair_bounded, forall("w", forall("x", forall("y", forall("p", forall("pw", forall("ppw", ob_body)))))), "z")
$_ tap("ordpair_bounded ok")


