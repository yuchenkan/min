from theorems.sets.singleton_pair_eq import singleton_pair_eq
from theorems.sets.pair_injection import pair_injection
from theorems.sets.singleton_injection import singleton_injection

$_ qed(singleton_injection,
    forall("a", forall("b", implies(forall("w", iff(eqv("w","a"), eqv("w","b"))), eqv("a","b")))))
$_ print("singleton_injection ok")

$_ qed(singleton_pair_eq,
    forall("a", forall("c", forall("d",
        implies(forall("w", iff(eqv("w","a"), or(eqv("w","c"), eqv("w","d")))),
                and(eqv("c","a"), eqv("d","a")))))))
$_ print("singleton_pair_eq ok")

$_ qed(pair_injection,
    forall("a", forall("b", forall("c", forall("d",
        implies(forall("w", iff(or(eqv("w","a"),eqv("w","b")), or(eqv("w","c"),eqv("w","d")))),
                or(and(eqv("a","c"),eqv("b","d")), and(eqv("a","d"),eqv("b","c")))))))))
$_ print("pair_injection ok")

from theorems.sets.kuratowski import kuratowski
from vocab.sets import ordered_pair
$op \t a b: ordered_pair(t, a, b)
$_ qed(kuratowski, forall("t1", forall("t2", forall("a", forall("b", forall("c", forall("d",
    implies(op("t1","a","b"), implies(op("t2","c","d"), implies(eqv("t1","t2","_"), and(eqv("a","c"), eqv("b","d"))))))))))))
$_ print("kuratowski ok")

