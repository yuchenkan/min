$_ qed(big_union_exists, forall("a", exists("s", big_union("s", "a", "_"))), "z")
$_ tap("big_union_exists ok")

$_ qed(empty_unique,
    forall("a", forall("b", implies(empty("a", "_"), implies(empty("b", "_"), eq("a", "b", "_"))))), "z")
$_ tap("empty_unique ok")

$_ qed(set_spec_unique(\v p: mem(v, "a"), ["a"], "_"),
    forall("a", forall("s1", forall("s2",
        implies(forall("x", iff(mem("x", "s1"), mem("x", "a"))),
                implies(forall("x", iff(mem("x", "s2"), mem("x", "a"))),
                        eq("s1", "s2", "_")))))), "z")
$_ tap("set_spec_unique ok")

$_ qed(singleton_unique,
