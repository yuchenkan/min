$_ qed(singleton_injection,
    forall("a", forall("b", implies(forall("w", iff(eq("w","a","_"), eq("w","b","_"))), eq("a","b","_")))), "z")
$_ tap("singleton_injection ok")

$_ qed(singleton_pair_eq,
    forall("a", forall("c", forall("d",
        implies(forall("w", iff(eq("w","a","_"), or(eq("w","c","_"), eq("w","d","_")))),
                and(eq("c","a","_"), eq("d","a","_")))))), "z")
$_ tap("singleton_pair_eq ok")

$_ qed(pair_injection,
    forall("a", forall("b", forall("c", forall("d",
        implies(forall("w", iff(or(eq("w","a","_"),eq("w","b","_")), or(eq("w","c","_"),eq("w","d","_")))),
                or(and(eq("a","c","_"),eq("b","d","_")), and(eq("a","d","_"),eq("b","c","_")))))))), "z")
$_ tap("pair_injection ok")

$op \t a b: ordered_pair(t, a, b, "_")
