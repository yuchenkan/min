from core.derived import mem, implies, forall, or, iff, eqv, left, right
from vocab.sets import successor
from tactics import ax, wr, fl, fr, ir, mp, apply_thm, close
from theorems.logic.iff_chain import iff_chain
from theorems.logic.iff_sym import iff_sym
from theorems.logic.or_iff_compat import or_iff_compat
from theorems.sets.eq_transfer import eq_transfer
from theorems.sets.eq_in_eq import eq_in_eq

# |- eqv(a,c) ‚Üí eqv(b,d) ‚Üí Succ(c,d) ‚Üí Succ(a,b)
# Transfers successor through equalities on both set and base.
$eq_succ_transfer {
    $eqv_ac eqv("a", "c", "_")
    $eqv_bd eqv("b", "d", "_")
    $succ_cd successor("c", "d", "_")
    $succ_ab successor("a", "b", "_")

    $za mem("z", "a")
    $zb mem("z", "b")
    $zc mem("z", "c")
    $zd mem("z", "d")
    $eq_zb eqv("z", "b", "_")
    $eq_zd eqv("z", "d", "_")
    $or_b or(zb, eq_zb)
    $or_d or(zd, eq_zd)

    # Alpha-rename eq_transfer to avoid bound var "b" clashing with term "b":
    # eq_transfer result: ‚àÄa.‚àÄb.‚àÄz. eqv(a,b) ‚Üí iff(mem(z,a),mem(z,b))
    # Renamed:            ‚àÄp.‚àÄq.‚àÄr. eqv(p,q) ‚Üí iff(mem(r,p),mem(r,q))
    $_et_b \p: \q: \r: implies(eqv(p,q,"_"), iff(mem(r,p),mem(r,q)))
    $et_r forall("p", forall("q", forall("r", _et_b("p")("q")("r"))))
    $et_thm wr(eq_transfer, [], [et_r], et_r)

    # Step 1: eqv(a,c) ‚Üí iff(z‚ààa, z‚ààc)
    $got_iff_ac mp(apply_thm(et_thm, et_r, ["a", "c", "z"], ["p", "q", "r"], _et_b, []),
        ax([eqv_ac], [eqv_ac], eqv_ac), eqv_ac, iff(za, zc), [], [eqv_ac])

    # Step 2: eqv(b,d) ‚Üí iff(z‚ààb, z‚ààd) ‚Üí iff_sym ‚Üí iff(z‚ààd, z‚ààb)
    $got_iff_bd mp(apply_thm(et_thm, et_r, ["b", "d", "z"], ["p", "q", "r"], _et_b, []),
        ax([eqv_bd], [eqv_bd], eqv_bd), eqv_bd, iff(zb, zd), [], [eqv_bd])
    $got_iff_db mp(iff_sym(zb, zd, []), got_iff_bd, iff(zb, zd), iff(zd, zb), [], [eqv_bd])

    # Step 3: eqv(b,d) ‚Üí iff(eqv(z,b), eqv(z,d)) ‚Üí iff_sym ‚Üí iff(eqv(z,d), eqv(z,b))
    # eq_in_eq close order ["x2","x1","z"] ‚Üí result: ‚àÄz.‚àÄx1.‚àÄx2.body
    # terms outermost-first: ["z","b","d"] ‚Üí z‚Üíz, x1‚Üíb, x2‚Üíd. No clashes.
    $_eie head(right(eq_in_eq))
    $_eie_b \z: \x1: \x2: implies(eqv(x1,x2,"_"), iff(eqv(z,x1,"_"), eqv(z,x2,"_")))
    $got_iff_eq mp(apply_thm(eq_in_eq, _eie, ["z", "b", "d"], ["z", "x1", "x2"], _eie_b, []),
        ax([eqv_bd], [eqv_bd], eqv_bd), eqv_bd, iff(eq_zb, eq_zd), [], [eqv_bd])
    $got_iff_eq_rev mp(iff_sym(eq_zb, eq_zd, []), got_iff_eq, iff(eq_zb, eq_zd), iff(eq_zd, eq_zb), [], [eqv_bd])

    # Step 4: or_iff_compat: iff(z‚ààd,z‚ààb) ‚Üí iff(eqv(z,d),eqv(z,b)) ‚Üí iff(or(d),or(b))
    $got_iff_or mp(mp(or_iff_compat(zd, eq_zd, zb, eq_zb, []),
        got_iff_db, iff(zd, zb), implies(iff(eq_zd, eq_zb), iff(or_d, or_b)), [], [eqv_bd]),
        got_iff_eq_rev, iff(eq_zd, eq_zb), iff(or_d, or_b), [eqv_bd], [eqv_bd])

    # Step 5: fl Succ(c,d) at z: iff(z‚ààc, or(z‚ààd, z=d))
    $iff_succ iff(zc, or_d)
    $got_iff_succ fl(ax([iff_succ], [iff_succ], iff_succ), [succ_cd], [iff_succ], succ_cd, "z")

    # Step 6: Chain: iff(z‚ààa,z‚ààc) + iff(z‚ààc, or(d)) ‚Üí iff(z‚ààa, or(d))
    $got_iff_a_d mp(mp(iff_chain(za, zc, or_d, []),
        got_iff_ac, iff(za, zc), implies(iff_succ, iff(za, or_d)), [], [eqv_ac]),
        got_iff_succ, iff_succ, iff(za, or_d), [eqv_ac], [succ_cd])

    # Chain: iff(z‚ààa, or(d)) + iff(or(d), or(b)) ‚Üí iff(z‚ààa, or(b)) = succ_ab body
    $iff_body iff(za, or_b)
    $got_iff_body mp(mp(iff_chain(za, or_d, or_b, []),
        got_iff_a_d, iff(za, or_d), implies(iff(or_d, or_b), iff_body), [], [eqv_ac, succ_cd]),
        got_iff_or, iff(or_d, or_b), iff_body, [eqv_ac, succ_cd], [eqv_bd])

    # Step 7: fr z ‚Üí Succ(a,b)
    $got_succ fr(got_iff_body, [eqv_ac, succ_cd, eqv_bd], [succ_ab], succ_ab, "z")

    # Close: eqv(a,c) ‚Üí eqv(b,d) ‚Üí Succ(c,d) ‚Üí Succ(a,b)
    $imp3 implies(succ_cd, succ_ab)
    $imp2 implies(eqv_bd, imp3)
    $top implies(eqv_ac, imp2)
    $r1 ir(got_succ, [eqv_ac, eqv_bd], [imp3], imp3)
    $r2 ir(r1, [eqv_ac], [imp2], imp2)
    $r3 ir(r2, [], [top], top)
    close(r3, [], [top], ["d","c","b","a"])
}
