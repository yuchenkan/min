from derived import mem, implies, forall, iff, or, eq, right
from vocab.sets import ordered_pair, singleton, pair_set
from tactics import ax, fl, fr, ir, mp, apply_thm, close
from theorems.logic.iff_intro import iff_intro
from theorems.logic.iff_chain import iff_chain
from theorems.logic.or_iff_compat import or_iff_compat
from theorems.logic.iff_refl import iff_refl
from theorems.logic.forall_iff_compat import forall_iff_compat
from theorems.sets.eq_in_eq import eq_in_eq
from theorems.logic.iff_elim_left import iff_elim_left
from theorems.logic.iff_sym import iff_sym

# |- eq(b,c) -> ordered_pair(t,a,b) -> ordered_pair(t,a,c)
$ordpair_val_transfer {
    $eq_bc eq("b", "c", "_")
    $op_b ordered_pair("t", "a", "b", "_")
    $op_c ordered_pair("t", "a", "c", "_")

    # eq_in_eq: eq(b,c) -> iff(eq(w,b), eq(w,c))
    $_eie head(right(eq_in_eq))
    $eq_wb eq("w", "b", "_")
    $eq_wc eq("w", "c", "_")
    $iff_eq iff(eq_wb, eq_wc)
    $got_eie apply_thm(eq_in_eq, _eie, ["w", "b", "c"], ["w", "x1", "x2"],
        \z: \x1: \x2: implies(eq(x1,x2,"_"), iff(eq(z,x1,"_"), eq(z,x2,"_"))), [])
    $got_iff_eq mp(got_eie, ax([eq_bc], [eq_bc], eq_bc), eq_bc, iff_eq, [], [eq_bc])

    $eq_wa eq("w", "a", "_")
    $got_iff_a iff_refl(eq_wa, [])

    $or_b or(eq_wa, eq_wb)
    $or_c or(eq_wa, eq_wc)
    $iff_or iff(or_b, or_c)
    $oic or_iff_compat(eq_wa, eq_wb, eq_wa, eq_wc, [])
    $got_step1 mp(oic, got_iff_a, iff(eq_wa, eq_wa), implies(iff_eq, iff_or), [], [])
    $got_iff_or mp(got_step1, got_iff_eq, iff_eq, iff_or, [], [eq_bc])

    # pair_set level
    $wx mem("w", "r")
    $ps_b pair_set("r", "a", "b", "_")
    $ps_c pair_set("r", "a", "c", "_")
    $iff_wz_b iff(wx, or_b)
    $iff_wz_c iff(wx, or_c)

    $got_chain mp(mp(iff_chain(wx, or_b, or_c, []),
        ax([iff_wz_b], [iff_wz_b], iff_wz_b), iff_wz_b,
        implies(iff_or, iff_wz_c), [], [iff_wz_b]),
        got_iff_or, iff_or, iff_wz_c, [iff_wz_b], [eq_bc])

    $iff_or_rev iff(or_c, or_b)
    $got_iff_or_rev mp(iff_sym(or_b, or_c, []), got_iff_or, iff_or, iff_or_rev, [], [eq_bc])
    $got_chain_rev mp(mp(iff_chain(wx, or_c, or_b, []),
        ax([iff_wz_c], [iff_wz_c], iff_wz_c), iff_wz_c,
        implies(iff_or_rev, iff_wz_b), [], [iff_wz_c]),
        got_iff_or_rev, iff_or_rev, iff_wz_b, [iff_wz_c], [eq_bc])

    $iff_bodies iff(iff_wz_b, iff_wz_c)
    $got_fwd_ir ir(got_chain, [eq_bc], [implies(iff_wz_b, iff_wz_c)], implies(iff_wz_b, iff_wz_c))
    $got_bwd_ir ir(got_chain_rev, [eq_bc], [implies(iff_wz_c, iff_wz_b)], implies(iff_wz_c, iff_wz_b))
    $got_iff_bodies mp(mp(iff_intro(iff_wz_b, iff_wz_c, []),
        got_fwd_ir, implies(iff_wz_b, iff_wz_c), implies(implies(iff_wz_c, iff_wz_b), iff_bodies), [], [eq_bc]),
        got_bwd_ir, implies(iff_wz_c, iff_wz_b), iff_bodies, [eq_bc], [eq_bc])

    $fa_iff_bodies forall("w", iff_bodies)
    $got_fa_iff fr(got_iff_bodies, [eq_bc], [fa_iff_bodies], fa_iff_bodies, "w")
    $iff_ps iff(ps_b, ps_c)
    $bp \w: iff(mem(w,"r"), or(eq(w,"a","_"), eq(w,"b","_")))
    $bq \w: iff(mem(w,"r"), or(eq(w,"a","_"), eq(w,"c","_")))
    $got_iff_ps mp(forall_iff_compat("w", bp, bq, []),
        got_fa_iff, fa_iff_bodies, iff_ps, [], [eq_bc])

    # ordered_pair level — use "r" as element var
    $sing singleton("r", "a", "_")
    $ps_b2 pair_set("r", "a", "b", "_")
    $ps_c2 pair_set("r", "a", "c", "_")
    $or_op_b or(sing, ps_b2)
    $or_op_c or(sing, ps_c2)
    $got_iff_sing iff_refl(sing, [])
    $iff_ps2 iff(ps_b2, ps_c2)
    $iff_or_op iff(or_op_b, or_op_c)
    $got_iff_or_op mp(mp(or_iff_compat(sing, ps_b2, sing, ps_c2, []),
        got_iff_sing, iff(sing, sing), implies(iff_ps2, iff_or_op), [], []),
        got_iff_ps, iff_ps2, iff_or_op, [], [eq_bc])

    $rt mem("r", "t")
    $op_body_b iff(rt, or_op_b)
    $op_body_c iff(rt, or_op_c)

    $got_chain2 mp(mp(iff_chain(rt, or_op_b, or_op_c, []),
        ax([op_body_b], [op_body_b], op_body_b), op_body_b,
        implies(iff_or_op, op_body_c), [], [op_body_b]),
        got_iff_or_op, iff_or_op, op_body_c, [op_body_b], [eq_bc])

    $got_iff_or_op_rev mp(iff_sym(or_op_b, or_op_c, []),
        got_iff_or_op, iff_or_op, iff(or_op_c, or_op_b), [], [eq_bc])
    $got_chain2_rev mp(mp(iff_chain(rt, or_op_c, or_op_b, []),
        ax([op_body_c], [op_body_c], op_body_c), op_body_c,
        implies(iff(or_op_c, or_op_b), op_body_b), [], [op_body_c]),
        got_iff_or_op_rev, iff(or_op_c, or_op_b), op_body_b, [op_body_c], [eq_bc])

    $iff_op_bodies iff(op_body_b, op_body_c)
    $got_fwd2 ir(got_chain2, [eq_bc], [implies(op_body_b, op_body_c)], implies(op_body_b, op_body_c))
    $got_bwd2 ir(got_chain2_rev, [eq_bc], [implies(op_body_c, op_body_b)], implies(op_body_c, op_body_b))
    $got_iff_op mp(mp(iff_intro(op_body_b, op_body_c, []),
        got_fwd2, implies(op_body_b, op_body_c), implies(implies(op_body_c, op_body_b), iff_op_bodies), [], [eq_bc]),
        got_bwd2, implies(op_body_c, op_body_b), iff_op_bodies, [eq_bc], [eq_bc])

    $fa_iff_op forall("r", iff_op_bodies)
    $got_fa_iff_op fr(got_iff_op, [eq_bc], [fa_iff_op], fa_iff_op, "r")
    $bp2 \v: iff(mem(v,"t"), or(singleton(v,"a","_"), pair_set(v,"a","b","_")))
    $bq2 \v: iff(mem(v,"t"), or(singleton(v,"a","_"), pair_set(v,"a","c","_")))
    $iff_ops iff(op_b, op_c)
    $got_iff_ops mp(forall_iff_compat("r", bp2, bq2, []),
        got_fa_iff_op, fa_iff_op, iff_ops, [], [eq_bc])

    $got_op_c mp(mp(iff_elim_left(op_b, op_c, []),
        got_iff_ops, iff_ops, implies(op_b, op_c), [], [eq_bc]),
        ax([op_b], [op_b], op_b), op_b, op_c, [eq_bc], [op_b])

    $imp2 implies(op_b, op_c)
    $s1 ir(got_op_c, [eq_bc], [imp2], imp2)
    $top implies(eq_bc, imp2)
    $s2 ir(s1, [], [top], top)
    close(s2, [], [top], ["c","b","a","t"])
}
