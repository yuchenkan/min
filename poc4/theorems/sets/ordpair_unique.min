from core.derived import or, eqv
from vocab.sets import singleton, pair_set, ordered_pair
from theorems.sets.set_spec_unique import set_spec_unique

# |- ordered_pair(t,a,b) -> ordered_pair(s,a,b) -> eqv(t,s)
# ordered_pair IS set_spec with cond = \v: or(singleton(v,a,"_"), pair_set(v,a,b,"_"))
$ordpair_unique set_spec_unique(\v: or(singleton(v, "a", "_"), pair_set(v, "a", "b", "_")), ["b", "a"])
