from core.derived import implies, forall, exists, or, eqv, pairing_ax, left, right
from vocab.sets import pair_set
from vocab.logic import exists_unique
from tactics import ax, fr, mp, wl, apply_thm, eel, cut_c, close
from theorems.logic.exists_unique_intro import exists_unique_intro
from theorems.sets.set_spec_unique import set_spec_unique
from theorems.sets.pair_set_exists import pair_set_exists

$unique_pair_set {
    $cond_fn \v p: or(eqv(v, "a", p), eqv(v, "b", p))
    $body_fn \v p: pair_set(v, "a", "b", p)
    $eu exists_unique(body_fn, "_")
    $ps_u body_fn("u", "_")
    $imp_inner implies(body_fn("y", "_"), eqv("u", "y", "_"))
    $ssu set_spec_unique(cond_fn, [])
    $_ssu_f head(right(ssu))
    $ssu_inst apply_thm(ssu, _ssu_f, [["u", ["s2"]], ["y", []]],
        \s1: \s2: implies(body_fn(s1,"_"), implies(body_fn(s2,"_"), eqv(s1,s2,"_"))), [])
    $got_inner mp(ssu_inst, ax([ps_u], [ps_u], ps_u), ps_u, imp_inner, [], [ps_u])
    $fa_uniq forall("y", imp_inner)
    $got_fa fr(got_inner, [ps_u], [fa_uniq], fa_uniq, "y")
    $got_eu mp(mp(exists_unique_intro(body_fn, "u", []), ax([ps_u], [ps_u], ps_u), ps_u, implies(fa_uniq, eu), [], [ps_u]),
               got_fa, fa_uniq, eu, [ps_u], [ps_u])
    $got_ex eel(got_eu, \v: body_fn(v, "_"), "s", "u", [ps_u], eu)
    $_pe_f head(right(pair_set_exists))
    $pe_ctx left(pair_set_exists)
    $got_pe apply_thm(pair_set_exists, _pe_f, [["a", ["b"]], ["b", []]],
        \a: \b: exists("s", pair_set("s",a,b,"_")), pe_ctx)
    $ex_ps exists("s", body_fn("s", "_"))
    $got_cut cut_c(got_pe, got_ex, ex_ps, pe_ctx, [ex_ps], eu)
    close(got_cut, pe_ctx, [eu], ["b","a"])
}
