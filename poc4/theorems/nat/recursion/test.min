$es_inner forall("m", implies(mem("m","w"), forall("sm", implies(successor("sm","m","_"), implies(exists("y5", apply("u","sm","y5","_")), and(exists("val5", apply("u","m","val5","_")), forall("val5", implies(apply("u","m","val5","_"), forall("fv5", implies(apply("f","val5","fv5","_"), apply("u","sm","fv5","_")))))))))))
$es_body implies(rec_approx("v","a","f","_"), implies(function("f","_"), implies(omega("w","_"), implies(nat("n","_"), implies(apply("v","n","val","_"), implies(apply("f","val","fval","_"), implies(successor("sn","n","_"), implies(ordered_pair("op","sn","fval","_"), implies(singleton("h","op","_"), implies(union("u","v","h","_"), implies(function("u","_"), implies(apply("u","sn","fval","_"), es_inner))))))))))))
