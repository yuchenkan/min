$res_func function("u", "_")
$res_dom forall("x2", implies(exists("y2", apply("u","x2","y2","_")), mem("x2","w")))
$res_ran forall("x2", forall("y2", implies(apply("u","x2","y2","_"), exists("z2", apply("f","y2","z2","_")))))
$res_base forall("e2", implies(empty("e2","_"), implies(exists("y2", apply("u","e2","y2","_")), apply("u","e2","a","_"))))
$res_step forall("n2", implies(mem("n2","w"), forall("sn2", implies(successor("sn2","n2","_"), implies(exists("y2", apply("u","sn2","y2","_")), and(exists("val2", apply("u","n2","val2","_")), forall("val2", implies(apply("u","n2","val2","_"), forall("fval2", implies(apply("f","val2","fval2","_"), apply("u","sn2","fval2","_")))))))))))
$res_ra_body and(res_func, and(res_dom, and(res_ran, and(res_base, res_step))))
$res_ra forall("w", implies(omega("w","_"), res_ra_body))
$res_goal and(res_ra, apply("u","sn","fval","_"))
$res_rfc forall("y", forall("z", implies(apply("f","y","z","_"), exists("w2", apply("f","z","w2","_")))))
$res_body implies(rec_approx("v","a","f","_"), implies(function("f","_"), implies(nat("n","_"), implies(apply("v","n","val","_"), implies(apply("f","val","fval","_"), implies(res_rfc, implies(successor("sn","n","_"), implies(ordered_pair("op","sn","fval","_"), implies(singleton("h","op","_"), implies(union("u","v","h","_"), res_goal))))))))))
$_ qed(rec_exists_step, forall("v", forall("a", forall("f", forall("n", forall("val", forall("fval", forall("sn", forall("op", forall("h", forall("u", res_body)))))))))))
$_ print("rec_exists_step ok")

$sr_body implies(num("e",0,"_"), implies(exists("z", apply("f","a","z","_")),
