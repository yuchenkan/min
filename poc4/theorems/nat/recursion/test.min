$rva_pred \w n p: exists(add(p,"y"), and(apply("h",n,add(p,"y"),add(p,"_")),
    and(apply("h2",n,add(p,"y"),add(p,"_")), exists(add(p,"z"), apply("f",add(p,"y"),add(p,"z"),add(p,"_"))))))
