$re_pred \w n p: exists(add(p,"g"), and(rec_approx(add(p,"g"), "a", "f", w, add(p,"_")), exists(add(p,"y"), apply(add(p,"g"), n, add(p,"y"), add(p,"_")))))
$re_rfc forall("y3", forall("z3", implies(apply("f","y3","z3","_"), exists("w2", apply("f","z3","w2","_")))))
$re_body implies(function("f","_"), implies(exists("z", apply("f","a","z","_")), implies(re_rfc, implies(omega("w","_"), forall("n", implies(mem("n","w"), re_pred("w","n","_")))))))
$_ qed(rec_exists, forall("w", forall("f", forall("a", re_body))))
$_ print("rec_exists ok")

$ra_pred \w n p: forall(add(p,"v1"), forall(add(p,"v2"), forall(add(p,"y1"), forall(add(p,"y2"),
    implies(rec_approx(add(p,"v1"),"a","f",add(p,"_")),
    implies(rec_approx(add(p,"v2"),"a","f",add(p,"_")),
    implies(apply(add(p,"v1"),n,add(p,"y1"),add(p,"_")),
    implies(apply(add(p,"v2"),n,add(p,"y2"),add(p,"_")),
        eqv(add(p,"y1"),add(p,"y2"),add(p,"_"))))))))))
$ra_body implies(omega("w","_"), implies(function("f","_"), forall("n", implies(mem("n","w"), ra_pred("w","n","_")))))
$_ qed(rec_agree, forall("w", forall("f", forall("a", ra_body))))
$_ print("rec_agree ok")

$rge_phi \p np: exists(add(np,"n"), and(nat(add(np,"n"),np),
    exists(add(np,"v"), exists(add(np,"y"), and(and(rec_approx(add(np,"v"),"a","f",add(np,"_")),
        apply(add(np,"v"),add(np,"n"),add(np,"y"),add(np,"_"))), ordered_pair(p,add(np,"n"),add(np,"y"),add(np,"_")))))))
$rge_body exists("h", forall("p", iff(mem("p","h"), and(mem("p","ppb"), rge_phi("p","_")))))
