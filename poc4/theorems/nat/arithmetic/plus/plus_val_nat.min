from derived import mem, implies, forall, and, exists, eqv, left, right
from vocab.sets import ordered_pair
from vocab.nat.nat import nat
from vocab.functions import apply
from vocab.nat.arithmetic.plus import plus_func, plus
from tactics import ax, fl, fr, ir, mp, apply_thm, eir, eel, cut_c, close, same
from util.list import remove, head
from theorems.sets.ordpair_exists import ordpair_exists
from theorems.nat.arithmetic.plus.plus_func_exists import plus_func_exists
from theorems.nat.arithmetic.plus.h_val_nat import h_val_nat

# |- ∀m,n,p. Nat(m) → Nat(n) → Plus(m,n,p) → Nat(p)
$plus_val_nat {
    $nat_m nat("m", "_")
    $nat_n nat("n", "_")
    $plus_mnp plus("m", "n", "p", "_")
    $nat_p nat("p", "_")
    $pf_h plus_func("h", "_")
    $op_mn ordered_pair("pair", "m", "n", "_")
    $app_hp apply("h", "pair", "p", "_")

    # === Step 1: From Plus(m,n,p), get Apply(h,pair,p) ===
    $fa_pair forall("pair", implies(op_mn, app_hp))
    $pf_impl implies(pf_h, fa_pair)
    $got_plus fl(ax([pf_impl],[pf_impl],pf_impl),
        [plus_mnp], [pf_impl], plus_mnp, "h")
    $got_plus mp(got_plus, ax([pf_h],[pf_h],pf_h), pf_h,
        fa_pair, [plus_mnp], [pf_h])

    $op_app implies(op_mn, app_hp)
    $got_fl fl(ax([op_app],[op_app],op_app),
        [fa_pair], [op_app], fa_pair, "pair")
    $got_plus cut_c(got_plus, got_fl, fa_pair,
        left(got_plus), left(got_fl), op_app)
    $got_plus mp(got_plus, ax([op_mn],[op_mn],op_mn), op_mn,
        app_hp, left(got_plus), [op_mn])
    # [Plus, PF(h), OP(pair,m,n)] |- Apply(h,pair,p)
    $_ tap("got Apply(h,pair,p)")

    # === Step 2: h_val_nat → Nat(p) ===
    # h_val_nat: ∀h. PF(h) → ∀m. Nat(m) → ∀n. Nat(n) → ∀pair. OP → ∀p. Apply → Nat(p)
    # Peel one forall at a time, mp each hypothesis.

    # Build the expected formulas at each level
    $rest_after_p implies(app_hp, nat_p)
    $rest_after_pair implies(op_mn, forall("p", rest_after_p))
    $rest_after_n implies(nat_n, forall("pair", rest_after_pair))
    $rest_after_m implies(nat_m, forall("n", rest_after_n))
    $rest_after_h implies(pf_h, forall("m", rest_after_m))

    # Peel ∀h
    $_hv head(right(h_val_nat))
    $_hv1 \h: implies(plus_func(h,"_"),
        forall("m", implies(nat("m","_"),
            forall("n", implies(nat("n","_"),
                forall("pair", implies(ordered_pair("pair","m","n","_"),
                    forall("p", implies(apply(h,"pair","p","_"),
                        nat("p","_"))))))))))
    $got_hv apply_thm(h_val_nat, _hv, ["h"], ["h"], _hv1, left(h_val_nat))
    # [...] |- PF(h) → ∀m...
    $got_hv mp(got_hv, ax([pf_h],[pf_h],pf_h), pf_h,
        forall("m", rest_after_m),
        left(got_hv), [pf_h])
    # [..., PF(h)] |- ∀m. Nat(m) → ...

    # Peel ∀m
    $_hv2 \m: implies(nat(m,"_"),
        forall("n", implies(nat("n","_"),
            forall("pair", implies(ordered_pair("pair",m,"n","_"),
                forall("p", implies(apply("h","pair","p","_"),
                    nat("p","_"))))))))
    $got_hv apply_thm(got_hv, head(right(got_hv)), ["m"], ["m"], _hv2, left(got_hv))
    $got_hv mp(got_hv, ax([nat_m],[nat_m],nat_m), nat_m,
        forall("n", rest_after_n),
        left(got_hv), [nat_m])

    # Peel ∀n
    $_hv3 \n: implies(nat(n,"_"),
        forall("pair", implies(ordered_pair("pair","m",n,"_"),
            forall("p", implies(apply("h","pair","p","_"),
                nat("p","_"))))))
    $got_hv apply_thm(got_hv, head(right(got_hv)), ["n"], ["n"], _hv3, left(got_hv))
    $got_hv mp(got_hv, ax([nat_n],[nat_n],nat_n), nat_n,
        forall("pair", rest_after_pair),
        left(got_hv), [nat_n])

    # Peel ∀pair
    $_hv4 \pair: implies(ordered_pair(pair,"m","n","_"),
        forall("p", implies(apply("h",pair,"p","_"),
            nat("p","_"))))
    $got_hv apply_thm(got_hv, head(right(got_hv)), ["pair"], ["pair"], _hv4, left(got_hv))
    $got_hv mp(got_hv, ax([op_mn],[op_mn],op_mn), op_mn,
        forall("p", rest_after_p),
        left(got_hv), [op_mn])

    # Peel ∀p
    $_hv5 \p: implies(apply("h","pair",p,"_"), nat(p,"_"))
    $got_hv apply_thm(got_hv, head(right(got_hv)), ["p"], ["p"], _hv5, left(got_hv))
    $got_hv mp(got_hv, got_plus, app_hp,
        nat_p, left(got_hv), left(got_plus))
    # [..., PF(h), OP, Nat(m), Nat(n), Plus] |- Nat(p)
    $_ tap("got Nat(p)")

    # === Step 3: eel pair from OP(pair,m,n), cut with ordpair_exists ===
    $got_result got_hv
    $got_result eel(got_result, \v: ordered_pair(v,"m","n","_"),
        "pair", "pair", remove(same, op_mn, left(got_result)), nat_p)
    $ex_pair exists("pair", op_mn)
    $_oe head(right(ordpair_exists))
    $_oe_b \a: \b: exists("pair", ordered_pair("pair", a, b, "_"))
    $got_ex_pair apply_thm(ordpair_exists, _oe, ["m","n"], ["a","b"], _oe_b, left(ordpair_exists))
    $got_result cut_c(got_ex_pair, got_result, ex_pair,
        left(got_ex_pair), left(got_result), nat_p)
    $_ tap("eel pair done")

    # === Step 4: eel h from PF(h), cut with plus_func_exists ===
    $got_result eel(got_result, \v: plus_func(v,"_"),
        "h", "h", remove(same, pf_h, left(got_result)), nat_p)
    $ex_h exists("h", pf_h)
    $got_result cut_c(plus_func_exists,
        got_result, ex_h,
        left(plus_func_exists), left(got_result), nat_p)
    $_ tap("eel h done")

    # === Step 5: Discharge and close ===
    $proof got_result
    $goal_f nat_p
    $proof ir(proof, remove(same, plus_mnp, left(proof)),
        [implies(plus_mnp, goal_f)], implies(plus_mnp, goal_f))
    $goal_f head(right(proof))
    $proof ir(proof, remove(same, nat_n, left(proof)),
        [implies(nat_n, goal_f)], implies(nat_n, goal_f))
    $goal_f head(right(proof))
    $proof ir(proof, remove(same, nat_m, left(proof)),
        [implies(nat_m, goal_f)], implies(nat_m, goal_f))
    $goal_f head(right(proof))

    $proof fr(proof, left(proof), [forall("p", goal_f)], forall("p", goal_f), "p")
    $goal_f head(right(proof))
    $proof fr(proof, left(proof), [forall("n", goal_f)], forall("n", goal_f), "n")
    $goal_f head(right(proof))
    $proof fr(proof, left(proof), [forall("m", goal_f)], forall("m", goal_f), "m")

    proof
}
