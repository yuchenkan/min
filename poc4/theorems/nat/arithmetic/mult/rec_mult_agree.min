    $avt_inst4 apply_thm(avt_thm, avt_r, ["hm1","s","fv2","v2"], ["f","x","y","y2"], _avt_b, [])
    $avt_mp4 mp(avt_inst4, got_fv2v2, eq("fv2","v2","_"),
