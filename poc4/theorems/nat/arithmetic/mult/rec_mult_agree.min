        ax([app_hs2],[app_hs2],app_hs2), app_hs2, implies(app_hs2_fv2, eq("v2","fv2","_")), left(got_body2), [app_hs2]),
        got_hm2_sfv2, app_hs2_fv2, eq("v2","fv2","_"), [rec2, om, app_hs2], left(got_hm2_sfv2))

    # --- Chain: v1=fv1, fv1=fv2, v2=fv2 → v1=v2 ---
    # Transfer: v1=fv1 → Apply(hm1,s,fv1) exists, and fv1=fv2 → fv2=fv1 (sym)
    # Use apply_val_transfer: eq(fv1,fv2) → Apply(hm1,s,fv1) → Apply(hm1,s,fv2)
    # Then func_unique: Apply(hm1,s,v1) ∧ Apply(hm1,s,fv2) → v1=fv2
    # And v2=fv2 → fv2=v2 (sym), then Apply(hm2,s,fv2) → Apply(hm2,s,v2)... no
    # Simpler chain:
