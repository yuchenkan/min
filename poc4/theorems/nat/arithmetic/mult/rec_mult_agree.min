    # --- func_unique(hm1): Apply(hm1,s,v1) ∧ Apply(hm1,s,fv1) → v1=fv1 ---
    $fut5 apply_thm(func_unique_thm, _fut, ["hm1","s","v1","fv1"], ["f","x","y1","y2"], _fut_b, [])
    $got_v1fv1 mp(mp(mp(fut5, got_sv1, sv_hm1,
        implies(app_hs1, implies(app_hs1_fv1, eq("v1","fv1","_"))), [], left(got_body1)),
        ax([app_hs1],[app_hs1],app_hs1), app_hs1, implies(app_hs1_fv1, eq("v1","fv1","_")), left(got_body1), [app_hs1]),
        got_hm1_sfv1, app_hs1_fv1, eq("v1","fv1","_"), [rec1, om, app_hs1], left(got_hm1_sfv1))

    # --- func_unique(hm2): Apply(hm2,s,v2) ∧ Apply(hm2,s,fv2) → v2=fv2 ---
    $fut6 apply_thm(func_unique_thm, _fut, ["hm2","s","v2","fv2"], ["f","x","y1","y2"], _fut_b, [])
    $got_v2fv2 mp(mp(mp(fut6, got_sv2, sv_hm2,
