from derived import mem, implies, forall, and, iff, exists, eq, left, right, arg2
from vocab.sets import relation
from vocab.nat.nat import nat, num, omega, successor
from vocab.functions import apply, function, domain, single_valued
from vocab.nat.recursion import recursive
from vocab.nat.arithmetic.plus import plus
from vocab.nat.arithmetic.mult import add_func
from tactics import ax, wr, fl, fr, ir, mp, apply_thm, eir, eel, cut_c, close, same
from util.list import remove
from theorems.logic.and_intro import and_intro
from theorems.logic.and_elim_left import and_elim_left
from theorems.logic.and_elim_right import and_elim_right
from theorems.logic.iff_elim_left import iff_elim_left
from theorems.logic.iff_elim_right import iff_elim_right
from theorems.logic.eq_symmetric import eq_symmetric
from theorems.logic.ext_substitution import ext_substitution
from theorems.functions.func_unique_thm import func_unique_thm
from theorems.functions.apply_val_transfer import apply_val_transfer
from theorems.functions.apply_key_transfer import apply_key_transfer
from theorems.nat.nat.omega_induction import omega_induction
from theorems.nat.nat.omega_exists import omega_exists
from theorems.nat.nat.omega_unique import omega_unique
from theorems.nat.nat.nat_elim import nat_elim
from theorems.nat.nat.num_nat import num_nat
from theorems.nat.nat.num_unique import num_unique
from theorems.sets.eq_transfer import eq_transfer
from theorems.logic.eq_mem_left import eq_mem_left
from theorems.functions.domain_exists import domain_exists
from theorems.functions.domain_mem_elim import domain_mem_elim
from theorems.nat.arithmetic.plus.plus_val_unique import plus_val_unique
from theorems.nat.arithmetic.plus.plus_val_exists import plus_val_exists
from theorems.nat.arithmetic.mult.rec_val_mult import rec_val_mult

# rec_mult_agree:
# AddFunc(af1,m) → AddFunc(af2,m) → Rec(hm1,z1,af1) → Rec(hm2,z2,af2) →
# Num(z1,0) → Num(z2,0) → Nat(m) → Nat(n) →
# Apply(hm1,n,v1) → Apply(hm2,n,v2) → eq(v1,v2)
#
# By omega_induction on n with P(n) = ∀v1,v2. Apply(hm1,n,v1) → Apply(hm2,n,v2) → eq(v1,v2).
# Base: hm1(0)=z1, hm2(0)=z2. num_unique: z1=z2. func_unique: v1=z1, v2=z2. So v1=v2.
# Step: Rec steps → hm1(S(n))=af1(hm1(n)), hm2(S(n))=af2(hm2(n)).
#   IH: hm1(n)=hm2(n). Both af's are Plus(_,m,_). plus_val_unique → same output.

$rec_mult_agree {
    $af1 add_func("af1","m","_")
    $af2 add_func("af2","m","_")
    $rec1 recursive("hm1","z1","af1","_")
    $rec2 recursive("hm2","z2","af2","_")
    $nz1 num("z1",0,"_")
    $nz2 num("z2",0,"_")
    $nat_m nat("m","_")
    $nat_n nat("n","_")
    $app1 apply("hm1","n","v1","_")
    $app2 apply("hm2","n","v2","_")
    $eq_goal eq("v1","v2","_")
    $om omega("w","_")

    # P(n) = ∀v1,v2. Apply(hm1,n,v1) → Apply(hm2,n,v2) → eq(v1,v2)
    $pred \w n p: forall(add(p,"v1"), forall(add(p,"v2"),
        implies(apply("hm1",n,add(p,"v1"),add(p,"_")),
            implies(apply("hm2",n,add(p,"v2"),add(p,"_")),
                eq(add(p,"v1"),add(p,"v2"),add(p,"_"))))))

    # === Decompose AddFunc(af1,m) and AddFunc(af2,m) ===
    $func_af1 function("af1","_")
    $fwd1 forall("x", forall("y", implies(apply("af1","x","y","_"), plus("x","m","y","_"))))
    $bwd1 forall("x", implies(nat("x","_"), forall("y", implies(plus("x","m","y","_"), apply("af1","x","y","_")))))
    $dom_sub1 forall("x", implies(exists("y", apply("af1","x","y","_")), nat("x","_")))
    $rest_af1 and(fwd1, and(bwd1, dom_sub1))
    $got_fwd1 mp(and_elim_left(fwd1, and(bwd1, dom_sub1), []),
        mp(and_elim_right(func_af1, rest_af1, []),
            ax([af1],[af1],af1), af1, rest_af1, [], [af1]),
        rest_af1, fwd1, [], [af1])

    $func_af2 function("af2","_")
    $fwd2 forall("x", forall("y", implies(apply("af2","x","y","_"), plus("x","m","y","_"))))
    $rest_af2 and(fwd2, and(forall("x", implies(nat("x","_"), forall("y", implies(plus("x","m","y","_"), apply("af2","x","y","_"))))),
        forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_")))))
    $got_fwd2 mp(and_elim_left(fwd2, and(forall("x", implies(nat("x","_"), forall("y", implies(plus("x","m","y","_"), apply("af2","x","y","_"))))),
        forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_")))), []),
        mp(and_elim_right(func_af2, rest_af2, []),
            ax([af2],[af2],af2), af2, rest_af2, [], [af2]),
        rest_af2, fwd2, [], [af2])

    # === Unwrap Recursive at omega ===
    $func_hm1 function("hm1","_")
    $base_hm1 forall("e", implies(num("e",0,"_"), apply("hm1","e","z1","_")))
    $step_hm1 forall("nb", implies(mem("nb","w"), forall("val", implies(apply("hm1","nb","val","_"),
        forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af1","val","fval","_"), apply("hm1","sn","fval","_")))))))))
    $dom_hm1 forall("d", implies(domain("d","hm1","_"), eq("d","w","_")))
    $body_hm1 and(func_hm1, and(dom_hm1, and(base_hm1, step_hm1)))
    $_r1_b \w: implies(omega(w,"_"), body_hm1)
    $r1_inst apply_thm(ax([rec1],[rec1],rec1), rec1, ["w"], ["w"], _r1_b, [rec1])
    $got_body1 mp(r1_inst, ax([om],[om],om), om, body_hm1, [rec1], [om])
    $got_func1 mp(and_elim_left(func_hm1, and(dom_hm1, and(base_hm1, step_hm1)), []),
        got_body1, body_hm1, func_hm1, [], left(got_body1))
    $sv_hm1 single_valued("hm1","_")
    $got_sv1 mp(and_elim_right(relation("hm1","_"), sv_hm1, []),
        got_func1, func_hm1, sv_hm1, [], left(got_body1))
    $got_rest1 mp(and_elim_right(func_hm1, and(dom_hm1, and(base_hm1, step_hm1)), []),
        got_body1, body_hm1, and(dom_hm1, and(base_hm1, step_hm1)), [], left(got_body1))
    $got_dom1 mp(and_elim_left(dom_hm1, and(base_hm1, step_hm1), []),
        got_rest1, and(dom_hm1, and(base_hm1, step_hm1)), dom_hm1, [], left(got_body1))
    $got_base1 mp(and_elim_left(base_hm1, step_hm1, []),
        mp(and_elim_right(dom_hm1, and(base_hm1, step_hm1), []),
            got_rest1, and(dom_hm1, and(base_hm1, step_hm1)), and(base_hm1, step_hm1), [], left(got_body1)),
        and(base_hm1, step_hm1), base_hm1, [], left(got_body1))
    $got_step1 mp(and_elim_right(base_hm1, step_hm1, []),
        mp(and_elim_right(dom_hm1, and(base_hm1, step_hm1), []),
            got_rest1, and(dom_hm1, and(base_hm1, step_hm1)), and(base_hm1, step_hm1), [], left(got_body1)),
        and(base_hm1, step_hm1), step_hm1, [], left(got_body1))

    $func_hm2 function("hm2","_")
    $base_hm2 forall("e", implies(num("e",0,"_"), apply("hm2","e","z2","_")))
    $step_hm2 forall("nb", implies(mem("nb","w"), forall("val", implies(apply("hm2","nb","val","_"),
        forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af2","val","fval","_"), apply("hm2","sn","fval","_")))))))))
    $body_hm2 and(func_hm2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)))
    $_r2_b \w: implies(omega(w,"_"), body_hm2)
    $r2_inst apply_thm(ax([rec2],[rec2],rec2), rec2, ["w"], ["w"], _r2_b, [rec2])
    $got_body2 mp(r2_inst, ax([om],[om],om), om, body_hm2, [rec2], [om])
    $got_func2 mp(and_elim_left(func_hm2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)), []),
        got_body2, body_hm2, func_hm2, [], left(got_body2))
    $sv_hm2 single_valued("hm2","_")
    $got_sv2 mp(and_elim_right(relation("hm2","_"), sv_hm2, []),
        got_func2, func_hm2, sv_hm2, [], left(got_body2))
    $got_rest2 mp(and_elim_right(func_hm2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)), []),
        got_body2, body_hm2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)), [], left(got_body2))
    $got_base2 mp(and_elim_left(base_hm2, step_hm2, []),
        mp(and_elim_right(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2), []),
            got_rest2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)),
            and(base_hm2, step_hm2), [], left(got_body2)),
        and(base_hm2, step_hm2), base_hm2, [], left(got_body2))
    $got_step2 mp(and_elim_right(base_hm2, step_hm2, []),
        mp(and_elim_right(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2), []),
            got_rest2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)),
            and(base_hm2, step_hm2), [], left(got_body2)),
        and(base_hm2, step_hm2), step_hm2, [], left(got_body2))

    # === num_unique(0): z1=z2 ===
    $_nu head(right(num_unique(0)))
    $_nu_b \n1: \n2: implies(num(n1,0,"_"), implies(num(n2,0,"_"), eq(n1,n2,"_")))
    $nu_ctx left(num_unique(0))
    $nu_inst apply_thm(num_unique(0), _nu, ["z1","z2"], ["n1","n2"], _nu_b, nu_ctx)
    $eq_z12 eq("z1","z2","_")
    $nu1 mp(nu_inst,
        ax([nz1],[nz1],nz1), nz1,
        implies(nz2, eq_z12), left(num_unique(0)), [nz1])
    $got_eq_z mp(nu1,
        ax([nz2],[nz2],nz2), nz2,
        eq_z12, left(nu1), [nz2])

    # === n∈w from Nat(n) ===
    $_ne_b \m: \w: implies(nat(m,"_"), implies(omega(w,"_"), mem(m,w)))
    $ne_n apply_thm(nat_elim, head(right(nat_elim)), ["n","w"], ["m","w"], _ne_b, [])
    $nw mem("n","w")
    $got_nw mp(mp(ne_n, ax([nat_n],[nat_n],nat_n), nat_n, implies(om,nw), [], [nat_n]),
        ax([om],[om],om), om, nw, [nat_n], [om])

    # === omega_induction ===
    $oi omega_induction(pred, ["hm1","z1","af1","hm2","z2","af2","m"], "_")

    # === BASE CASE: ∀e. Num(e,0) → P(e) ===
    # P(e) = ∀v1,v2. Apply(hm1,e,v1) → Apply(hm2,e,v2) → eq(v1,v2)
    $emp num("e",0,"_")
    $app_he1 apply("hm1","e","v1","_")
    $app_he2 apply("hm2","e","v2","_")
    $app_he_z1 apply("hm1","e","z1","_")
    $app_he_z2 apply("hm2","e","z2","_")
    $eq_v12 eq("v1","v2","_")

    # base1: Num(e,0) → Apply(hm1,e,z1)
    $got_b1 mp(apply_thm(got_base1, base_hm1, ["e"], ["e"],
        \e: implies(num(e,0,"_"), apply("hm1",e,"z1","_")), left(got_body1)),
        ax([emp],[emp],emp), emp, app_he_z1, left(got_body1), [emp])

    # base2: Num(e,0) → Apply(hm2,e,z2)
    $got_b2 mp(apply_thm(got_base2, base_hm2, ["e"], ["e"],
        \e: implies(num(e,0,"_"), apply("hm2",e,"z2","_")), left(got_body2)),
        ax([emp],[emp],emp), emp, app_he_z2, left(got_body2), [emp])

    # func_unique: sv(hm1) ∧ Apply(hm1,e,v1) ∧ Apply(hm1,e,z1) → v1=z1
    $_fut head(right(func_unique_thm))
    $_fut_b \f: \x: \y1: \y2: implies(single_valued(f,"_"),
        implies(apply(f,x,y1,"_"), implies(apply(f,x,y2,"_"), eq(y1,y2,"_"))))
    $fut1 apply_thm(func_unique_thm, _fut, ["hm1","e","v1","z1"], ["f","x","y1","y2"], _fut_b, [])
    $got_v1z1 mp(mp(mp(fut1, got_sv1, sv_hm1,
        implies(app_he1, implies(app_he_z1, eq("v1","z1","_"))), [], left(got_body1)),
        ax([app_he1],[app_he1],app_he1), app_he1, implies(app_he_z1, eq("v1","z1","_")), left(got_body1), [app_he1]),
        got_b1, app_he_z1, eq("v1","z1","_"), [rec1, om, app_he1], left(got_b1))

    # func_unique: sv(hm2) ∧ Apply(hm2,e,v2) ∧ Apply(hm2,e,z2) → v2=z2
    $fut2 apply_thm(func_unique_thm, _fut, ["hm2","e","v2","z2"], ["f","x","y1","y2"], _fut_b, [])
    $got_v2z2 mp(mp(mp(fut2, got_sv2, sv_hm2,
        implies(app_he2, implies(app_he_z2, eq("v2","z2","_"))), [], left(got_body2)),
        ax([app_he2],[app_he2],app_he2), app_he2, implies(app_he_z2, eq("v2","z2","_")), left(got_body2), [app_he2]),
        got_b2, app_he_z2, eq("v2","z2","_"), [rec2, om, app_he2], left(got_b2))

    # Transitivity: v1=z1, z1=z2, v2=z2 → v1=v2
    # v1=z1 → (v1∈S ↔ z1∈S) → via z1=z2 → (z1∈S ↔ z2∈S) → v2=z2 → (v2∈S ↔ z2∈S)
    # Actually just use ext_substitution chains:
    # v1=z1 and z1=z2 → v1=z2 (via ext_substitution transitivity pattern)
    # Then v2=z2 → z2=v2 (symmetric), and v1=z2 + z2=v2 → v1=v2
    $_es head(right(ext_substitution))
    $_es_b \a: \b: \s: implies(eq(a,b,"_"), iff(mem(a,s), mem(b,s)))
    $es_ctx left(ext_substitution)

    $_esym head(right(eq_symmetric))
    $_esym_b \a: \b: implies(eq(a,b,"_"), eq(b,a,"_"))
    $got_z2v2 mp(apply_thm(eq_symmetric, _esym, ["v2","z2"], ["a","b"], _esym_b, []),
        got_v2z2, eq("v2","z2","_"), eq("z2","v2","_"), [], left(got_v2z2))

    # apply_val_transfer: eq(z1,z2) → Apply(hm1,e,z1) → Apply(hm1,e,z2)
    # Then: v1=z1, z1=z2, z2=v2 chain to v1=v2 via func_unique on hm1
    # Actually simpler: v1=z1 → ext_sub → (v1∈S ↔ z1∈S). z1=z2 → (z1∈S ↔ z2∈S). Compose.
    # z2=v2 → (z2∈S ↔ v2∈S). Chain all → v1∈S ↔ v2∈S → eq(v1,v2) by ext_axiom reverse.

    # Actually the cleanest approach: transfer Apply(hm2,e,z2) to Apply(hm2,e,z1) via eq(z1,z2),
    # then func_unique(hm2) on Apply(hm2,e,v2) and Apply(hm2,e,z1) → v2=z1.
    # Then v1=z1 and v2=z1 → v1=v2 via symmetric+ext_sub.

    # Step A: apply_val_transfer: eq(z2,z1) → Apply(hm2,e,z2) → Apply(hm2,e,z1)
    $_avt_b \f: \x: \y: \y2: implies(eq(y,y2,"_"), implies(apply(f,x,y,"_"), apply(f,x,y2,"_")))
    $avt_r forall("f", forall("x", forall("y", forall("y2", _avt_b("f")("x")("y")("y2")))))
    $avt_thm wr(apply_val_transfer, [], [avt_r], avt_r)
    $got_eq_z21 mp(apply_thm(eq_symmetric, _esym, ["z1","z2"], ["a","b"], _esym_b, []),
        got_eq_z, eq_z12, eq("z2","z1","_"), [], left(got_eq_z))
    $avt_inst apply_thm(avt_thm, avt_r, ["hm2","e","z2","z1"], ["f","x","y","y2"], _avt_b, [])
    $avt_mp1 mp(avt_inst, got_eq_z21, eq("z2","z1","_"),
        implies(app_he_z2, apply("hm2","e","z1","_")), [], left(got_eq_z21))
    $got_app_hz1 mp(avt_mp1, got_b2, app_he_z2, apply("hm2","e","z1","_"),
        left(avt_mp1), left(got_b2))

    # Step B: func_unique(hm2): Apply(hm2,e,v2) ∧ Apply(hm2,e,z1) → v2=z1
    $app_hz1 apply("hm2","e","z1","_")
    $fut3 apply_thm(func_unique_thm, _fut, ["hm2","e","v2","z1"], ["f","x","y1","y2"], _fut_b, [])
    $got_v2z1 mp(mp(mp(fut3, got_sv2, sv_hm2,
        implies(app_he2, implies(app_hz1, eq("v2","z1","_"))), [], left(got_body2)),
        ax([app_he2],[app_he2],app_he2), app_he2, implies(app_hz1, eq("v2","z1","_")), left(got_body2), [app_he2]),
        got_app_hz1, app_hz1, eq("v2","z1","_"), [rec2, om, app_he2], left(got_app_hz1))

    # Step C: v1=z1 and v2=z1 → v1=v2
    # v2=z1 → z1=v2 (symmetric)
    $got_z1v2 mp(apply_thm(eq_symmetric, _esym, ["v2","z1"], ["a","b"], _esym_b, []),
        got_v2z1, eq("v2","z1","_"), eq("z1","v2","_"), [], left(got_v2z1))
    # ext_sub: v1=z1 → (v1∈S ↔ z1∈S). Then z1=v2 → (z1∈S ↔ v2∈S). Chain → v1∈S ↔ v2∈S.
    # Use a specific set S and derive eq from the iff chain... this is getting complex.
    # Simpler: apply_val_transfer on hm1: eq(z1,v2) → Apply(hm1,e,z1) → Apply(hm1,e,v2)
    # Then func_unique(hm1): Apply(hm1,e,v1) ∧ Apply(hm1,e,v2) → v1=v2

    $avt_inst2 apply_thm(avt_thm, avt_r, ["hm1","e","z1","v2"], ["f","x","y","y2"], _avt_b, [])
    $avt_mp2 mp(avt_inst2, got_z1v2, eq("z1","v2","_"),
        implies(app_he_z1, apply("hm1","e","v2","_")), [], left(got_z1v2))
    $got_app_hv2 mp(avt_mp2, got_b1, app_he_z1, apply("hm1","e","v2","_"),
        left(avt_mp2), left(got_b1))

    $fut4 apply_thm(func_unique_thm, _fut, ["hm1","e","v1","v2"], ["f","x","y1","y2"], _fut_b, [])
    $got_base_eq mp(mp(mp(fut4, got_sv1, sv_hm1,
        implies(app_he1, implies(apply("hm1","e","v2","_"), eq_v12)), [], left(got_body1)),
        ax([app_he1],[app_he1],app_he1), app_he1, implies(apply("hm1","e","v2","_"), eq_v12), left(got_body1), [app_he1]),
        got_app_hv2, apply("hm1","e","v2","_"), eq_v12, [rec1, om, app_he1], left(got_app_hv2))

    # Close base: ir app_he2, ir app_he1, fr v2, fr v1, ir emp, fr e
    $bc1 ir(got_base_eq, remove(same, app_he2, left(got_base_eq)),
        [implies(app_he2, eq_v12)], implies(app_he2, eq_v12))
    $bc2 ir(bc1, remove(same, app_he1, left(bc1)),
        [implies(app_he1, implies(app_he2, eq_v12))], implies(app_he1, implies(app_he2, eq_v12)))
    $bc3 fr(bc2, left(bc2), [forall("v2", implies(app_he1, implies(apply("hm2","e","v2","_"), eq("v1","v2","_"))))],
        forall("v2", implies(app_he1, implies(apply("hm2","e","v2","_"), eq("v1","v2","_")))), "v2")
    $bc4 fr(bc3, left(bc3), [pred("w","e","_")], pred("w","e","_"), "v1")
    $bc5 ir(bc4, remove(same, emp, left(bc4)),
        [implies(emp, pred("w","e","_"))], implies(emp, pred("w","e","_")))
    $base_case forall("e", implies(emp, pred("w","e","_")))
    $got_bc fr(bc5, left(bc5), [base_case], base_case, "e")

    # === STEP CASE: ∀nb. nb∈w → P(nb) → ∀s. Succ(s,nb) → P(s) ===
    $nbw mem("nb","w")
    $pnb pred("w","nb","_")
    $succ_snb successor("s","nb","_")
    $app_hs1 apply("hm1","s","v1","_")
    $app_hs2 apply("hm2","s","v2","_")

    # Eigvars for step: val1, val2 (IH values), fv1, fv2 (step outputs)
    $app_hnb1 apply("hm1","nb","val1","_")
    $app_hnb2 apply("hm2","nb","val2","_")
    $app_af1_v1f1 apply("af1","val1","fv1","_")
    $app_af2_v2f2 apply("af2","val2","fv2","_")
    $app_hs1_fv1 apply("hm1","s","fv1","_")
    $app_hs2_fv2 apply("hm2","s","fv2","_")

    # --- IH: P(nb) at val1,val2 → eq(val1,val2) ---
    $eq_val12 eq("val1","val2","_")
    $pnb_v1 apply_thm(ax([pnb],[pnb],pnb), pnb, ["val1"], ["val1"],
        \v1: forall("v2", implies(apply("hm1","nb",v1,"_"), implies(apply("hm2","nb","v2","_"), eq(v1,"v2","_")))),
        [pnb])
    $pnb_v12 apply_thm(pnb_v1, head(right(pnb_v1)), ["val2"], ["val2"],
        \v2: implies(apply("hm1","nb","val1","_"), implies(apply("hm2","nb",v2,"_"), eq("val1",v2,"_"))),
        [pnb])
    $got_eq_val mp(mp(pnb_v12,
        ax([app_hnb1],[app_hnb1],app_hnb1), app_hnb1, implies(app_hnb2, eq_val12), [pnb], [app_hnb1]),
        ax([app_hnb2],[app_hnb2],app_hnb2), app_hnb2, eq_val12, [pnb, app_hnb1], [app_hnb2])

    # --- Rec step chain for hm1: nb∈w → Apply(hm1,nb,val1) → Succ(s,nb) → Apply(af1,val1,fv1) → Apply(hm1,s,fv1) ---
    $s1_nb mp(apply_thm(got_step1, step_hm1, ["nb"], ["nb"],
        \n: implies(mem(n,"w"), forall("val", implies(apply("hm1",n,"val","_"),
            forall("sn", implies(successor("sn",n,"_"), forall("fval", implies(apply("af1","val","fval","_"), apply("hm1","sn","fval","_")))))))),
        left(got_body1)),
        ax([nbw],[nbw],nbw), nbw, forall("val", implies(apply("hm1","nb","val","_"),
            forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af1","val","fval","_"), apply("hm1","sn","fval","_"))))))),
        left(got_body1), [nbw])
    $s1_val mp(apply_thm(s1_nb, head(right(s1_nb)), ["val1"], ["val1"],
        \v: implies(apply("hm1","nb",v,"_"), forall("sn", implies(successor("sn","nb","_"),
            forall("fval", implies(apply("af1",v,"fval","_"), apply("hm1","sn","fval","_")))))),
        left(s1_nb)),
        ax([app_hnb1],[app_hnb1],app_hnb1), app_hnb1,
        forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af1","val1","fval","_"), apply("hm1","sn","fval","_"))))),
        left(s1_nb), [app_hnb1])
    $s1_s mp(apply_thm(s1_val, head(right(s1_val)), ["s"], ["s"],
        \sn: implies(successor(sn,"nb","_"), forall("fval", implies(apply("af1","val1","fval","_"), apply("hm1",sn,"fval","_")))),
        left(s1_val)),
        ax([succ_snb],[succ_snb],succ_snb), succ_snb,
        forall("fval", implies(apply("af1","val1","fval","_"), apply("hm1","s","fval","_"))),
        left(s1_val), [succ_snb])
    $got_hm1_sfv1 mp(apply_thm(s1_s, head(right(s1_s)), ["fv1"], ["fv1"],
        \fv: implies(apply("af1","val1",fv,"_"), apply("hm1","s",fv,"_")), left(s1_s)),
        ax([app_af1_v1f1],[app_af1_v1f1],app_af1_v1f1), app_af1_v1f1, app_hs1_fv1, left(s1_s), [app_af1_v1f1])

    # --- Rec step chain for hm2: nb∈w → Apply(hm2,nb,val2) → Succ(s,nb) → Apply(af2,val2,fv2) → Apply(hm2,s,fv2) ---
    $s2_nb mp(apply_thm(got_step2, step_hm2, ["nb"], ["nb"],
        \n: implies(mem(n,"w"), forall("val", implies(apply("hm2",n,"val","_"),
            forall("sn", implies(successor("sn",n,"_"), forall("fval", implies(apply("af2","val","fval","_"), apply("hm2","sn","fval","_")))))))),
        left(got_body2)),
        ax([nbw],[nbw],nbw), nbw, forall("val", implies(apply("hm2","nb","val","_"),
            forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af2","val","fval","_"), apply("hm2","sn","fval","_"))))))),
        left(got_body2), [nbw])
    $s2_val mp(apply_thm(s2_nb, head(right(s2_nb)), ["val2"], ["val2"],
        \v: implies(apply("hm2","nb",v,"_"), forall("sn", implies(successor("sn","nb","_"),
            forall("fval", implies(apply("af2",v,"fval","_"), apply("hm2","sn","fval","_")))))),
        left(s2_nb)),
        ax([app_hnb2],[app_hnb2],app_hnb2), app_hnb2,
        forall("sn", implies(successor("sn","nb","_"), forall("fval", implies(apply("af2","val2","fval","_"), apply("hm2","sn","fval","_"))))),
        left(s2_nb), [app_hnb2])
    $s2_s mp(apply_thm(s2_val, head(right(s2_val)), ["s"], ["s"],
        \sn: implies(successor(sn,"nb","_"), forall("fval", implies(apply("af2","val2","fval","_"), apply("hm2",sn,"fval","_")))),
        left(s2_val)),
        ax([succ_snb],[succ_snb],succ_snb), succ_snb,
        forall("fval", implies(apply("af2","val2","fval","_"), apply("hm2","s","fval","_"))),
        left(s2_val), [succ_snb])
    $got_hm2_sfv2 mp(apply_thm(s2_s, head(right(s2_s)), ["fv2"], ["fv2"],
        \fv: implies(apply("af2","val2",fv,"_"), apply("hm2","s",fv,"_")), left(s2_s)),
        ax([app_af2_v2f2],[app_af2_v2f2],app_af2_v2f2), app_af2_v2f2, app_hs2_fv2, left(s2_s), [app_af2_v2f2])

    # --- fwd1: Apply(af1,val1,fv1) → Plus(val1,m,fv1) ---
    $plus_v1mf1 plus("val1","m","fv1","_")
    $got_fwd1_val mp(apply_thm(
        apply_thm(got_fwd1, fwd1, ["val1"], ["val1"],
            \x: forall("y", implies(apply("af1",x,"y","_"), plus(x,"m","y","_"))), [af1]),
        head(right(apply_thm(got_fwd1, fwd1, ["val1"], ["val1"],
            \x: forall("y", implies(apply("af1",x,"y","_"), plus(x,"m","y","_"))), [af1]))),
        ["fv1"], ["fv1"],
        \y: implies(apply("af1","val1",y,"_"), plus("val1","m",y,"_")), [af1]),
        ax([app_af1_v1f1],[app_af1_v1f1],app_af1_v1f1), app_af1_v1f1, plus_v1mf1, [af1], [app_af1_v1f1])

    # --- fwd2: Apply(af2,val2,fv2) → Plus(val2,m,fv2) ---
    $plus_v2mf2 plus("val2","m","fv2","_")
    $got_fwd2_val mp(apply_thm(
