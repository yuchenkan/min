    $got_eq_ww2 mp(mp(ou_inst, ax([om],[om],om), om, implies(om2, eq("w","w2","_")), [], [om]),
        ax([om2],[om2],om2), om2, eq("w","w2","_"), [om], [om2])
    $et_nb apply_thm(eq_transfer, _et, ["w","w2","nb"], ["a","b","z"], _et_b, [])
    $got_nbw2 mp(mp(iff_elim_left(nbw, mem("nb","w2"), []),
        mp(et_nb, got_eq_ww2, eq("w","w2","_"), iff(nbw, mem("nb","w2")), [], [om, om2]),
        iff(nbw, mem("nb","w2")), implies(nbw, mem("nb","w2")), [], [om, om2]),
        ax([nbw],[nbw],nbw), nbw, mem("nb","w2"), [om, om2], [nbw])
    $nat_nb nat("nb","_")
    $got_nat_nb_ir ir(got_nbw2, remove(same, om2, left(got_nbw2)), [implies(om2, mem("nb","w2"))], implies(om2, mem("nb","w2")))
    $got_nat_nb fr(got_nat_nb_ir, left(got_nat_nb_ir), [nat_nb], nat_nb, "w2")

    $rvm1_5 mp(rvm1_4, got_nat_nb, nat_nb, implies(app_hnb1, nat("val1","_")), left(rvm1_4), left(got_nat_nb))
    $nat_val1 nat("val1","_")
    $got_nat_val1 mp(rvm1_5, ax([app_hnb1],[app_hnb1],app_hnb1), app_hnb1, nat_val1, left(rvm1_5), [app_hnb1])

    # bwd1 at val1: Nat(val1) → ∀y.Plus(val1,m,y) → Apply(af1,val1,y)
    $bwd1_decomp mp(and_elim_left(bwd1, dom_sub1, []),
        mp(and_elim_right(fwd1, and(bwd1, dom_sub1), []),
            mp(and_elim_right(func_af1, rest_af1, []),
                ax([af1],[af1],af1), af1, rest_af1, [], [af1]),
            rest_af1, and(bwd1, dom_sub1), [], [af1]),
        and(bwd1, dom_sub1), bwd1, [], [af1])
    $got_bwd1_val mp(apply_thm(bwd1_decomp, bwd1, ["val1"], ["val1"],
        \x: implies(nat(x,"_"), forall("y", implies(plus(x,"m","y","_"), apply("af1",x,"y","_")))), [af1]),
        got_nat_val1, nat_val1, forall("y", implies(plus("val1","m","y","_"), apply("af1","val1","y","_"))),
        [af1], left(got_nat_val1))
    $got_bwd1_vp mp(apply_thm(got_bwd1_val, head(right(got_bwd1_val)), ["p"], ["p"],
        \y: implies(plus("val1","m",y,"_"), apply("af1","val1",y,"_")), left(got_bwd1_val)),
        ax([plus("val1","m","p","_")],[plus("val1","m","p","_")],plus("val1","m","p","_")),
        plus("val1","m","p","_"), apply("af1","val1","p","_"), left(got_bwd1_val), [plus("val1","m","p","_")])
    $got_ex_af1vp eir(got_bwd1_vp, \p: apply("af1","val1",p,"_"), "p", "p", left(got_bwd1_vp))
    $got_ex_af1vp2 eel(got_ex_af1vp, \p: plus("val1","m",p,"_"), "p", "p", left(got_ex_af1vp),
        exists("p", apply("af1","val1","p","_")))

    # plus_val_exists at val1,m
    $_pve head(right(plus_val_exists))
    $_pve_b1 \a: implies(nat(a,"_"), forall("n", implies(nat("n","_"), exists("p", plus(a,"n","p","_")))))
    $pve_ctx left(plus_val_exists)
    $pve_inst1 apply_thm(plus_val_exists, _pve, ["val1"], ["val1"], _pve_b1, pve_ctx)
    $pve_mp1 mp(pve_inst1, got_nat_val1, nat_val1,
        forall("n", implies(nat("n","_"), exists("p", plus("val1","n","p","_")))),
        pve_ctx, left(got_nat_val1))
    $pve_inst2 apply_thm(pve_mp1, head(right(pve_mp1)), ["m"], ["m"],
        \n: implies(nat(n,"_"), exists("p", plus("val1",n,"p","_"))), left(pve_mp1))
    $ex_plus_vm exists("p", plus("val1","m","p","_"))
    $got_ex_plus_vm mp(pve_inst2, ax([nat_m],[nat_m],nat_m), nat_m, ex_plus_vm, left(pve_inst2), [nat_m])

    $ex_af1v exists("p", apply("af1","val1","p","_"))
    $got_ex_af1v cut_c(got_ex_plus_vm, got_ex_af1vp2, ex_plus_vm, left(got_ex_plus_vm), left(got_ex_af1vp2), ex_af1v)

    # Rename to match eel bound var "fv"
    $ex_af1v_fv exists("fv", apply("af1","val1","fv","_"))
    $got_cut_fv1 cut_c(got_ex_af1v, got_eel_fv1, ex_af1v_fv, left(got_ex_af1v), left(got_eel_fv1), eq_v12)

    # Similarly for ∃fv.Apply(af2,val2,fv):
    # Get Nat(val2) from rec_val_mult on hm2:
    $rvm2_inst apply_thm(rec_val_mult, _rvm, ["af2","m","z2","hm2","nb","val2"],
        ["af","m","z","hm","x","y"], _rvm_b, rvm_ctx)
    $rvm2_1 mp(rvm2_inst, ax([af2],[af2],af2), af2, arg2(head(right(rvm2_inst))), rvm_ctx, [af2])
    $rvm2_2 mp(rvm2_1, ax([rec2],[rec2],rec2), rec2, arg2(head(right(rvm2_1))), left(rvm2_1), [rec2])
    $rvm2_3 mp(rvm2_2, ax([nz2],[nz2],nz2), nz2, arg2(head(right(rvm2_2))), left(rvm2_2), [nz2])
    $rvm2_4 mp(rvm2_3, ax([nat_m],[nat_m],nat_m), nat_m, arg2(head(right(rvm2_3))), left(rvm2_3), [nat_m])
    $rvm2_5 mp(rvm2_4, got_nat_nb, nat_nb, implies(app_hnb2, nat("val2","_")), left(rvm2_4), left(got_nat_nb))
    $nat_val2 nat("val2","_")
    $got_nat_val2 mp(rvm2_5, ax([app_hnb2],[app_hnb2],app_hnb2), app_hnb2, nat_val2, left(rvm2_5), [app_hnb2])

    # bwd2 at val2
    $bwd2_full forall("x", implies(nat("x","_"), forall("y", implies(plus("x","m","y","_"), apply("af2","x","y","_")))))
    $got_bwd2 mp(and_elim_left(bwd2_full,
        forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_"))), []),
        mp(and_elim_right(fwd2, and(bwd2_full,
            forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_")))), []),
            mp(and_elim_right(func_af2, rest_af2, []),
                ax([af2],[af2],af2), af2, rest_af2, [], [af2]),
            rest_af2, and(bwd2_full,
                forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_")))), [], [af2]),
        and(bwd2_full,
            forall("x", implies(exists("y", apply("af2","x","y","_")), nat("x","_")))), bwd2_full, [], [af2])
    $got_bwd2_val mp(apply_thm(got_bwd2, bwd2_full, ["val2"], ["val2"],
        \x: implies(nat(x,"_"), forall("y", implies(plus(x,"m","y","_"), apply("af2",x,"y","_")))), [af2]),
        got_nat_val2, nat_val2, forall("y", implies(plus("val2","m","y","_"), apply("af2","val2","y","_"))),
        [af2], left(got_nat_val2))
    $got_bwd2_vp mp(apply_thm(got_bwd2_val, head(right(got_bwd2_val)), ["q"], ["q"],
        \y: implies(plus("val2","m",y,"_"), apply("af2","val2",y,"_")), left(got_bwd2_val)),
        ax([plus("val2","m","q","_")],[plus("val2","m","q","_")],plus("val2","m","q","_")),
        plus("val2","m","q","_"), apply("af2","val2","q","_"), left(got_bwd2_val), [plus("val2","m","q","_")])
    $got_ex_af2vp eir(got_bwd2_vp, \q: apply("af2","val2",q,"_"), "q", "q", left(got_bwd2_vp))
    $got_ex_af2vp2 eel(got_ex_af2vp, \q: plus("val2","m",q,"_"), "q", "q", left(got_ex_af2vp),
        exists("q", apply("af2","val2","q","_")))

    # plus_val_exists at val2,m
    $pve2_inst1 apply_thm(plus_val_exists, _pve, ["val2"], ["val2"], _pve_b1, pve_ctx)
    $pve2_mp1 mp(pve2_inst1, got_nat_val2, nat_val2,
        forall("n", implies(nat("n","_"), exists("p", plus("val2","n","p","_")))),
        pve_ctx, left(got_nat_val2))
    $pve2_inst2 apply_thm(pve2_mp1, head(right(pve2_mp1)), ["m"], ["m"],
        \n: implies(nat(n,"_"), exists("p", plus("val2",n,"p","_"))), left(pve2_mp1))
    $ex_plus_v2m exists("p", plus("val2","m","p","_"))
    $got_ex_plus_v2m mp(pve2_inst2, ax([nat_m],[nat_m],nat_m), nat_m, ex_plus_v2m, left(pve2_inst2), [nat_m])

    $ex_af2v exists("q", apply("af2","val2","q","_"))
    $got_ex_af2v cut_c(got_ex_plus_v2m, got_ex_af2vp2, ex_plus_v2m, left(got_ex_plus_v2m), left(got_ex_af2vp2), ex_af2v)
    $ex_af2v_fv exists("fv", apply("af2","val2","fv","_"))
    $got_cut_fv2 cut_c(got_ex_af2v, got_cut_fv1, ex_af2v_fv, left(got_ex_af2v), left(got_cut_fv1), eq_v12)

    # eel val1, val2 from domain chains
    $got_eel_val2 eel(got_cut_fv2, \v: apply("hm2","nb",v,"_"), "vb2", "val2", left(got_cut_fv2), eq_v12)
    $got_eel_val1 eel(got_eel_val2, \v: apply("hm1","nb",v,"_"), "vb1", "val1", left(got_eel_val2), eq_v12)

    # Domain chain for hm1: need ∃val.Apply(hm1,nb,val)
    $dom_d1 domain("d","hm1","_")
    $nd1 mem("nb","d")
    $got_eq_d1 mp(apply_thm(got_dom1, dom_hm1, ["d"], ["d"],
        \d: implies(domain(d,"hm1","_"), eq(d,"w","_")), left(got_body1)),
        ax([dom_d1],[dom_d1],dom_d1), dom_d1, eq("d","w","_"), left(got_body1), [dom_d1])
    $got_eq_wd1 mp(apply_thm(eq_symmetric, _esym, ["d","w"], ["a","b"], _esym_b, []),
        got_eq_d1, eq("d","w","_"), eq("w","d","_"), [], left(got_eq_d1))
    $_eml_f head(right(eq_mem_left))
    $_eml_b \a: \b: \z: implies(eq(a,b,"_"), implies(mem(z,a), mem(z,b)))
    $got_nd1 mp(mp(apply_thm(eq_mem_left, _eml_f, ["w","d","nb"], ["a","b","z"], _eml_b, []),
        got_eq_wd1, eq("w","d","_"), implies(nbw, nd1), [], left(got_eq_wd1)),
        ax([nbw],[nbw],nbw), nbw, nd1, left(got_eq_wd1), [nbw])
    $_dme_f head(right(domain_mem_elim))
    $_dme_b \f: \d: \x: implies(domain(d,f,"_"), implies(mem(x,d), exists("y2", apply(f,x,"y2","_"))))
    $dme1 apply_thm(domain_mem_elim, _dme_f, ["hm1","d","nb"], ["f","d","x"], _dme_b, [])
    $got_ex_val1_d mp(mp(dme1, ax([dom_d1],[dom_d1],dom_d1), dom_d1,
        implies(nd1, exists("y2", apply("hm1","nb","y2","_"))), [], [dom_d1]),
        got_nd1, nd1, exists("y2", apply("hm1","nb","y2","_")), [dom_d1], left(got_nd1))
    $got_ex_val1_eel eel(got_ex_val1_d, \d: domain(d,"hm1","_"), "d", "d",
        left(got_ex_val1_d), exists("y2", apply("hm1","nb","y2","_")))
    $de_ctx left(domain_exists)
    $_de_f head(right(domain_exists))
    $_de_b \f: exists("d", domain("d",f,"_"))
    $got_de1 apply_thm(domain_exists, _de_f, ["hm1"], ["hm1"], _de_b, de_ctx)
    $ex_dom1 exists("d", domain("d","hm1","_"))
    $got_ex_val1 cut_c(got_de1, got_ex_val1_eel, ex_dom1, de_ctx, left(got_ex_val1_eel),
        exists("y2", apply("hm1","nb","y2","_")))
    $ex_val1_fv exists("vb1", apply("hm1","nb","vb1","_"))
    $got_cut_val1 cut_c(got_ex_val1, got_eel_val1, ex_val1_fv, left(got_ex_val1), left(got_eel_val1), eq_v12)

    # Domain chain for hm2: same pattern
    $dom_d2 domain("d","hm2","_")
    $nd2 mem("nb","d")
    $got_eq_d2 mp(apply_thm(
        mp(and_elim_left(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2), []),
            got_rest2, and(forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), and(base_hm2, step_hm2)),
            forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), [], left(got_body2)),
        forall("d", implies(domain("d","hm2","_"), eq("d","w","_"))), ["d"], ["d"],
        \d: implies(domain(d,"hm2","_"), eq(d,"w","_")), left(got_body2)),
        ax([dom_d2],[dom_d2],dom_d2), dom_d2, eq("d","w","_"), left(got_body2), [dom_d2])
    $got_eq_wd2 mp(apply_thm(eq_symmetric, _esym, ["d","w"], ["a","b"], _esym_b, []),
        got_eq_d2, eq("d","w","_"), eq("w","d","_"), [], left(got_eq_d2))
    $got_nd2 mp(mp(apply_thm(eq_mem_left, _eml_f, ["w","d","nb"], ["a","b","z"], _eml_b, []),
        got_eq_wd2, eq("w","d","_"), implies(nbw, nd2), [], left(got_eq_wd2)),
        ax([nbw],[nbw],nbw), nbw, nd2, left(got_eq_wd2), [nbw])
    $dme2 apply_thm(domain_mem_elim, _dme_f, ["hm2","d","nb"], ["f","d","x"], _dme_b, [])
    $got_ex_val2_d mp(mp(dme2, ax([dom_d2],[dom_d2],dom_d2), dom_d2,
        implies(nd2, exists("y2", apply("hm2","nb","y2","_"))), [], [dom_d2]),
        got_nd2, nd2, exists("y2", apply("hm2","nb","y2","_")), [dom_d2], left(got_nd2))
    $got_ex_val2_eel eel(got_ex_val2_d, \d: domain(d,"hm2","_"), "d", "d",
        left(got_ex_val2_d), exists("y2", apply("hm2","nb","y2","_")))
    $got_de2 apply_thm(domain_exists, _de_f, ["hm2"], ["hm2"], _de_b, de_ctx)
    $ex_dom2 exists("d", domain("d","hm2","_"))
    $got_ex_val2 cut_c(got_de2, got_ex_val2_eel, ex_dom2, de_ctx, left(got_ex_val2_eel),
        exists("y2", apply("hm2","nb","y2","_")))
    $ex_val2_fv exists("vb2", apply("hm2","nb","vb2","_"))
    $got_cut_val2 cut_c(got_ex_val2, got_cut_val1, ex_val2_fv, left(got_ex_val2), left(got_cut_val1), eq_v12)

    # === Close step_case ===
    $sc_1 ir(got_cut_val2, remove(same, app_hs2, left(got_cut_val2)),
        [implies(app_hs2, eq_v12)], implies(app_hs2, eq_v12))
    $sc_2 ir(sc_1, remove(same, app_hs1, left(sc_1)),
        [implies(app_hs1, implies(app_hs2, eq_v12))], implies(app_hs1, implies(app_hs2, eq_v12)))
    $sc_3 fr(sc_2, left(sc_2), [forall("v2", implies(app_hs1, implies(apply("hm2","s","v2","_"), eq("v1","v2","_"))))],
        forall("v2", implies(app_hs1, implies(apply("hm2","s","v2","_"), eq("v1","v2","_")))), "v2")
    $sc_4 fr(sc_3, left(sc_3), [pred("w","s","_")], pred("w","s","_"), "v1")
    $sc_5 ir(sc_4, remove(same, succ_snb, left(sc_4)),
        [implies(succ_snb, pred("w","s","_"))], implies(succ_snb, pred("w","s","_")))
    $sc_6 fr(sc_5, left(sc_5), [forall("s", implies(succ_snb, pred("w","s","_")))],
        forall("s", implies(succ_snb, pred("w","s","_"))), "s")
    $sc_pn implies(pnb, forall("s", implies(succ_snb, pred("w","s","_"))))
    $sc_7 ir(sc_6, remove(same, pnb, left(sc_6)), [sc_pn], sc_pn)
    $sc_nw implies(nbw, sc_pn)
    $sc_8 ir(sc_7, remove(same, nbw, left(sc_7)), [sc_nw], sc_nw)
    $step_case forall("nb", sc_nw)
    $got_sc fr(sc_8, left(sc_8), [step_case], step_case, "nb")

    # === Assembly: omega_induction + base + step → ∀n∈w.P(n) ===
    $oi_body \w: \m: \af2: \z2: \hm2: \af1: \z1: \hm1: implies(omega(w,"_"), implies(
        forall("e", implies(num("e",0,"_"), pred(w,"e","_"))),
        implies(step_case, forall("nb", implies(mem("nb",w), pred(w,"nb","_"))))))
    $oi_inst apply_thm(oi, head(right(oi)), ["w","m","af2","z2","hm2","af1","z1","hm1"],
        ["w","m","af2","z2","hm2","af1","z1","hm1"], oi_body, left(oi))
    $oi_r1 arg2(head(right(oi_inst)))
    $oi_mp1 mp(oi_inst, ax([om], [om], om), om, oi_r1, left(oi), [om])
    $oi_r2 arg2(head(right(oi_mp1)))
    $oi_mp2 mp(oi_mp1, got_bc, head(right(got_bc)), oi_r2, left(oi_mp1), left(got_bc))
    $oi_r3 arg2(head(right(oi_mp2)))
    $oi_mp3 mp(oi_mp2, got_sc, head(right(got_sc)), oi_r3, left(oi_mp2), left(got_sc))

    # Inst at n:
    $oi_n apply_thm(oi_mp3, head(right(oi_mp3)), ["n"], ["n"],
        \nb: implies(mem(nb,"w"), pred("w",nb,"_")), left(oi_mp3))
    $oi_n2 mp(oi_n, got_nw, nw, pred("w","n","_"), left(oi_n), [nat_n, om])

    # Inst at v1, v2:
    $oi_v1 apply_thm(oi_n2, head(right(oi_n2)), ["v1"], ["v1"],
        \v1: forall("v2", implies(apply("hm1","n",v1,"_"), implies(apply("hm2","n","v2","_"), eq(v1,"v2","_")))),
        left(oi_n2))
    $oi_v2 apply_thm(oi_v1, head(right(oi_v1)), ["v2"], ["v2"],
        \v2: implies(apply("hm1","n","v1","_"), implies(apply("hm2","n",v2,"_"), eq("v1",v2,"_"))),
        left(oi_v1))
    $oi_mp1 mp(oi_v2,
        ax([app1],[app1],app1), app1, implies(app2, eq_goal), left(oi_v2), [app1])
    $got_agree mp(oi_mp1,
        ax([app2],[app2],app2), app2, eq_goal, left(oi_mp1), [app2])

    # === eel omega witness ===
    $got_eel_w eel(got_agree, \w: omega(w,"_"), "w", "w", remove(same, om, left(got_agree)), eq_goal)
    $ex_om exists("w", omega("w","_"))
    $got_final cut_c(omega_exists, got_eel_w, ex_om, left(omega_exists), left(got_eel_w), eq_goal)

    # === Close: ir/fr chain ===
    $f1 ir(got_final, remove(same, app2, left(got_final)), [implies(app2, eq_goal)], implies(app2, eq_goal))
    $f2 ir(f1, remove(same, app1, left(f1)), [implies(app1, implies(app2, eq_goal))], implies(app1, implies(app2, eq_goal)))
    $f3 ir(f2, remove(same, nat_n, left(f2)),
        [implies(nat_n, implies(app1, implies(app2, eq_goal)))],
        implies(nat_n, implies(app1, implies(app2, eq_goal))))
    $f4 ir(f3, remove(same, nat_m, left(f3)),
        [implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))],
        implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))
    $f5 ir(f4, remove(same, nz2, left(f4)),
        [implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))],
        implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))
    $f6 ir(f5, remove(same, nz1, left(f5)),
        [implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))],
        implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))))
    $f7 ir(f6, remove(same, rec2, left(f6)),
        [implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))))],
        implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))))
    $f8 ir(f7, remove(same, rec1, left(f7)),
        [implies(rec1, implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))))],
        implies(rec1, implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))))))
    $f9 ir(f8, remove(same, af2, left(f8)),
        [implies(af2, implies(rec1, implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal)))))))))],
        implies(af2, implies(rec1, implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))))))
    $top implies(af1, implies(af2, implies(rec1, implies(rec2, implies(nz1, implies(nz2, implies(nat_m, implies(nat_n, implies(app1, implies(app2, eq_goal))))))))))
    $f10 ir(f9, remove(same, af1, left(f9)), [top], top)
    close(f10, left(f10), [top], ["v2","v1","n","hm2","z2","af2","hm1","z1","m","af1"])
}
