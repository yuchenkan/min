    # func_unique(hm1): Apply(hm1,s,v1) ∧ Apply(hm1,s,v2) → v1=v2
    $fut8 apply_thm(func_unique_thm, _fut, ["hm1","s","v1","v2"], ["f","x","y1","y2"], _fut_b, [])
    $got_step_eq mp(mp(mp(fut8, got_sv1, sv_hm1,
        implies(app_hs1, implies(apply("hm1","s","v2","_"), eq_v12)), [], left(got_body1)),
        ax([app_hs1],[app_hs1],app_hs1), app_hs1, implies(apply("hm1","s","v2","_"), eq_v12), left(got_body1), [app_hs1]),
        got_app_hs1_v2, apply("hm1","s","v2","_"), eq_v12, [rec1, om, app_hs1], left(got_app_hs1_v2))

    # === eel eigvars: fv1 (from af1 totality), fv2 (from af2 totality), val1 (from domain), val2 (from domain) ===
    # Need: ∃fv1.Apply(af1,val1,fv1), ∃fv2.Apply(af2,val2,fv2), ∃val1.Apply(hm1,nb,val1), ∃val2.Apply(hm2,nb,val2)

    # eel fv2
    $got_eel_fv2 eel(got_step_eq, \fv: apply("af2","val2",fv,"_"), "fv", "fv2", left(got_step_eq), eq_v12)
    # eel fv1
    $got_eel_fv1 eel(got_eel_fv2, \fv: apply("af1","val1",fv,"_"), "fv", "fv1", left(got_eel_fv2), eq_v12)

    # Need ∃fv.Apply(af1,val1,fv): from bwd1 + plus_val_exists, similar to rec_val_mult
    # Actually simpler: use rec_val_mult to get Nat(val1), then bwd1 + plus_val_exists → ∃fv.Apply(af1,val1,fv)
    # But that's a lot of steps. Let me use domain_mem_elim on af1 instead.
    # af1 is a Function, dom(af1) ⊇ ω (from totality). val1 is natural (from rec_val_mult).
    # Actually, just use the add_func backward direction:
    # bwd1: Nat(val1) → Plus(val1,m,y) → Apply(af1,val1,y)
    # plus_val_exists: Nat(val1) → Nat(m) → ∃p.Plus(val1,m,p)
    # So: ∃p.Plus(val1,m,p) → ∃p.Apply(af1,val1,p)

    # First get Nat(val1) from rec_val_mult:
    $_rvm head(right(rec_val_mult))
    $_rvm_b \af: \m: \z: \hm: \x: \y: implies(add_func(af,m,"_"),
        implies(recursive(hm,z,af,"_"), implies(num(z,0,"_"), implies(nat(m,"_"),
            implies(nat(x,"_"), implies(apply(hm,x,y,"_"), nat(y,"_")))))))
    $rvm_ctx left(rec_val_mult)
    $rvm1_inst apply_thm(rec_val_mult, _rvm, ["af1","m","z1","hm1","nb","val1"],
        ["af","m","z","hm","x","y"], _rvm_b, rvm_ctx)
    $rvm1_1 mp(rvm1_inst, ax([af1],[af1],af1), af1, arg2(head(right(rvm1_inst))), rvm_ctx, [af1])
    $rvm1_2 mp(rvm1_1, ax([rec1],[rec1],rec1), rec1, arg2(head(right(rvm1_1))), left(rvm1_1), [rec1])
    $rvm1_3 mp(rvm1_2, ax([nz1],[nz1],nz1), nz1, arg2(head(right(rvm1_2))), left(rvm1_2), [nz1])
    $rvm1_4 mp(rvm1_3, ax([nat_m],[nat_m],nat_m), nat_m, arg2(head(right(rvm1_3))), left(rvm1_3), [nat_m])
    # Need Nat(nb). nb∈w + omega → Nat(nb) via omega_unique transfer
    $_ou head(right(omega_unique))
    $_ou_b \w1: \w2: implies(omega(w1,"_"), implies(omega(w2,"_"), eq(w1,w2,"_")))
    $om2 omega("w2","_")
    $_et head(right(eq_transfer))
    $_et_b \a: \b: \z: implies(eq(a,b,"_"), iff(mem(z,a), mem(z,b)))
