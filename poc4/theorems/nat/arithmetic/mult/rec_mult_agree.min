        got_af2_v1f2, apply("af2","val1","fv2","_"), plus_v1mf2, [af2], left(got_af2_v1f2))

    # plus_val_unique: Plus(val1,m,fv1) ∧ Plus(val1,m,fv2) → fv1=fv2
    $_pvu head(right(plus_val_unique))
    $_pvu_b \a: \b: \c: \c2: implies(plus(a,b,c,"_"), implies(plus(a,b,c2,"_"), eq(c,c2,"_")))
    $pvu_ctx left(plus_val_unique)
    $pvu_inst apply_thm(plus_val_unique, _pvu, ["val1","m","fv1","fv2"], ["a","b","c","c2"], _pvu_b, pvu_ctx)
    $eq_fv12 eq("fv1","fv2","_")
    $pvu_mp1 mp(pvu_inst,
