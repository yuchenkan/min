    # v1=fv2: transfer Apply(hm1,s,fv1) via eq(fv1,fv2) → Apply(hm1,s,fv2)
    $avt_inst3 apply_thm(avt_thm, avt_r, ["hm1","s","fv1","fv2"], ["f","x","y","y2"], _avt_b, [])
    $avt_mp3 mp(avt_inst3, got_eq_fv, eq_fv12,
        implies(app_hs1_fv1, apply("hm1","s","fv2","_")), [], left(got_eq_fv))
    $got_app_hs1_fv2 mp(avt_mp3,
