    # func_unique(hm1): Apply(hm1,s,v1) ∧ Apply(hm1,s,fv2) → v1=fv2
    $fut7 apply_thm(func_unique_thm, _fut, ["hm1","s","v1","fv2"], ["f","x","y1","y2"], _fut_b, [])
    $got_v1fv2 mp(mp(mp(fut7, got_sv1, sv_hm1,
