        ax([app_hs1],[app_hs1],app_hs1), app_hs1, implies(apply("hm1","s","fv2","_"), eq("v1","fv2","_")), left(got_body1), [app_hs1]),
        got_app_hs1_fv2, apply("hm1","s","fv2","_"), eq("v1","fv2","_"), [rec1, om, app_hs1], left(got_app_hs1_fv2))

    # fv2=v2 (from v2=fv2 symmetric)
    $got_fv2v2 mp(apply_thm(eq_symmetric, _esym, ["v2","fv2"], ["a","b"], _esym_b, []),
        got_v2fv2, eq("v2","fv2","_"), eq("fv2","v2","_"), [], left(got_v2fv2))

