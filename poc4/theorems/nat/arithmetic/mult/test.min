from derived import mem, implies, forall, and, iff, exists, eq, qed
from vocab.sets import ordered_pair, relation
from vocab.functions import apply
from vocab.nat.nat import nat
from vocab.nat.arithmetic.plus import plus
from vocab.nat.arithmetic.mult import add_func
from theorems.nat.arithmetic.mult.af_apply_to_plus import af_apply_to_plus
from theorems.nat.arithmetic.mult.af_plus_to_apply import af_plus_to_apply
from theorems.nat.arithmetic.mult.af_relation import af_relation
from theorems.nat.arithmetic.mult.af_dom_sub import af_dom_sub
from theorems.nat.arithmetic.mult.add_func_exists import add_func_exists
from theorems.nat.arithmetic.mult.add_func_total_from import add_func_total_from
from theorems.nat.arithmetic.mult.rec_for_mult import rec_for_mult
from theorems.nat.arithmetic.mult.mf_relation import mf_relation
from theorems.nat.arithmetic.mult.mf_forward import mf_forward
from theorems.nat.arithmetic.mult.mf_base import mf_base
from theorems.nat.arithmetic.mult.rec_val_mult import rec_val_mult
from theorems.nat.arithmetic.mult.rec_mult_agree import rec_mult_agree
from theorems.nat.arithmetic.mult.add_func_eq_transfer import add_func_eq_transfer
from theorems.nat.arithmetic.mult.mf_single_valued import mf_single_valued
from theorems.nat.arithmetic.mult.mf_backward import mf_backward
from vocab.nat.recursion import recursive, total_from
from vocab.functions import function, single_valued
from vocab.sets import relation
from vocab.nat.nat import num
from vocab.logic import exists_unique

$af_phi \p np: exists(add(np,"x"), and(mem(add(np,"x"),"w"),
    exists(add(np,"y"), and(plus(add(np,"x"),"m",add(np,"y"),add(np,"_")),
        ordered_pair(p,add(np,"x"),add(np,"y"),add(np,"_"))))))
$af_char_fn \af: forall("p", iff(mem("p",af), af_phi("p","_")))

$mf_phi \xv np: exists(add(np,"m"), and(nat(add(np,"m"),np),
    exists(add(np,"n"), exists(add(np,"y"), exists(add(np,"pv"),
        and(ordered_pair(add(np,"pv"),add(np,"m"),add(np,"n"),add(np,"_")),
        and(ordered_pair(xv,add(np,"pv"),add(np,"y"),add(np,"_")),
            exists(add(np,"z"), and(num(add(np,"z"),0,np),
                exists(add(np,"af"), and(add_func(add(np,"af"),add(np,"m"),add(np,"_")),
                    exists(add(np,"hm"), and(recursive(add(np,"hm"),add(np,"z"),add(np,"af"),add(np,"_")),
                        apply(add(np,"hm"),add(np,"n"),add(np,"y"),add(np,"_")))))))))))))))
$mf_char_fn \h: forall("xv", iff(mem("xv",h), mf_phi("xv","_")))

$_ qed(af_apply_to_plus,
    forall("af", forall("w", forall("m", forall("x", forall("y",
        implies(af_char_fn("af"), implies(apply("af","x","y","_"), plus("x","m","y","_")))))))), "z")
$_ tap("af_apply_to_plus ok")

$_ qed(af_plus_to_apply,
    forall("af", forall("w", forall("m", forall("x", forall("y",
        implies(af_char_fn("af"), implies(mem("x","w"), implies(plus("x","m","y","_"), apply("af","x","y","_"))))))))), "z")
$_ tap("af_plus_to_apply ok")

$_ qed(af_relation,
    forall("af", forall("m", forall("w",
        implies(af_char_fn("af"), relation("af","_"))))), "z")
$_ tap("af_relation ok")

$_ qed(af_dom_sub,
    forall("af", forall("m", forall("w", forall("xd",
        implies(af_char_fn("af"), implies(exists("yd", apply("af","xd","yd","_")), mem("xd","w"))))))), "z")
$_ tap("af_dom_sub ok")

$_ qed(add_func_exists,
    forall("m", implies(nat("m","_"), exists("af", add_func("af","m","_")))), "z")
$_ tap("add_func_exists ok")

$_ qed(add_func_total_from,
    forall("af", forall("m", forall("n",
        implies(add_func("af","m","_"), implies(nat("m","_"), implies(nat("n","_"),
            total_from("af","n","_"))))))), "z")
$_ tap("add_func_total_from ok")

$_ qed(rec_for_mult,
    forall("af", forall("m", forall("z",
        implies(add_func("af","m","_"), implies(nat("m","_"), implies(num("z",0,"_"),
            exists_unique(\h p: recursive(h,"z","af",p), "_"))))))), "z")
$_ tap("rec_for_mult ok")

$_ qed(mf_relation,
    forall("h", implies(mf_char_fn("h"), relation("h","_"))), "z")
$_ tap("mf_relation ok")

$mf_char_fwd \h: forall("xv", implies(mem("xv",h), mf_phi("xv","_")))
$mf_fwd_result \h: forall("key", forall("val",
    implies(mf_char_fwd(h), implies(apply(h,"key","val","_"),
        exists("mv", and(nat("mv","_"), exists("nv", and(ordered_pair("key","mv","nv","_"),
            exists("zv", and(num("zv",0,"_"),
                exists("afv", and(add_func("afv","mv","_"),
                    exists("hm", and(recursive("hm","zv","afv","_"), apply("hm","nv","val","_")))))))))))))))
$_ qed(mf_forward, forall("h", mf_fwd_result("h")), "z")
$_ tap("mf_forward ok")

$_ qed(mf_base,
    forall("h", implies(mf_char_fn("h"),
        forall("m", implies(nat("m","_"),
            forall("z", implies(num("z",0,"_"),
                forall("pair", implies(ordered_pair("pair","m","z","_"),
                    apply("h","pair","z","_"))))))))), "z")
$_ tap("mf_base ok")

$_ qed(rec_val_mult,
    forall("af", forall("m", forall("z", forall("hm", forall("x", forall("y",
        implies(add_func("af","m","_"),
            implies(recursive("hm","z","af","_"),
                implies(num("z",0,"_"),
                    implies(nat("m","_"),
                        implies(nat("x","_"),
                            implies(apply("hm","x","y","_"), nat("y","_"))))))))))))), "z")
$_ tap("rec_val_mult ok")

$_ qed(rec_mult_agree,
    forall("af1", forall("m", forall("z1", forall("hm1", forall("af2", forall("z2", forall("hm2", forall("n", forall("v1", forall("v2",
        implies(add_func("af1","m","_"),
            implies(add_func("af2","m","_"),
                implies(recursive("hm1","z1","af1","_"),
                    implies(recursive("hm2","z2","af2","_"),
                        implies(num("z1",0,"_"),
                            implies(num("z2",0,"_"),
                                implies(nat("m","_"),
                                    implies(nat("n","_"),
                                        implies(apply("hm1","n","v1","_"),
                                            implies(apply("hm2","n","v2","_"),
                                                eq("v1","v2","_"))))))))))))))))))))), "z")
$_ tap("rec_mult_agree ok")

$_ qed(add_func_eq_transfer,
    forall("af", forall("m1", forall("m2",
        implies(add_func("af","m1","_"),
            implies(eq("m1","m2","_"), add_func("af","m2","_")))))), "z")
$_ tap("add_func_eq_transfer ok")

$_ qed(mf_single_valued,
    forall("h", implies(mf_char_fwd("h"),
        forall("key", forall("y1", forall("y2",
            implies(and(apply("h","key","y1","_"), apply("h","key","y2","_")),
                eq("y1","y2","_"))))))), "z")
$_ tap("mf_single_valued ok")

$_ qed(mf_backward,
    forall("h", implies(mf_char_fn("h"),
        forall("hm", forall("af", forall("z", forall("m", forall("n", forall("yv",
            implies(nat("m","_"), implies(nat("n","_"), implies(num("z",0,"_"),
                implies(add_func("af","m","_"), implies(recursive("hm","z","af","_"),
                    implies(apply("hm","n","yv","_"),
                        forall("pair", implies(ordered_pair("pair","m","n","_"),
                            apply("h","pair","yv","_"))))))))))))))))), "z")
$_ tap("mf_backward ok")

$ok true
