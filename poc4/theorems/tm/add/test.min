from derived import implies, forall, exists, and, eqv, qed, mem, or, empty
from vocab.sets import ordered_pair
from vocab.functions import apply, function
from vocab.tm.tm import tm_config, tm_transition, tm_step
from vocab.nat.nat import num, successor, omega
from theorems.tm.add.phase1_step_tmstep import phase1_step_tmstep
from theorems.tm.add.phase1_step_extend_trace import phase1_step_extend_trace
from theorems.tm.add.phase1_base import phase1_base
from theorems.tm.add.tape_read_low import tape_read_low
from vocab.tm.add import phase1_ind, unary_tape

$pst_expected forall("delta", forall("q0", forall("ka", forall("ska",
    forall("tape_in", forall("ca", forall("one", forall("d1",
    implies(function("delta", "_"),
    implies(tm_transition("delta", "q0", "one", "one", "d1", "q0", "_"),
    implies(tm_config("ca", "q0", "ka", "tape_in", "_"),
    implies(function("tape_in", "_"),
    implies(apply("tape_in", "ka", "one", "_"),
    implies(num("d1", 1, "_"),
    implies(successor("ska", "ka", "_"),
        exists("ca_new", and(
            tm_config("ca_new", "q0", "ska", "tape_in", "_"),
            tm_step("delta", "ca", "ca_new", "_"))))))))))))))))))
$_ qed(phase1_step_tmstep, pst_expected, "z")
$_ tap("phase1_step_tmstep ok")

$_sv_body \v: \n: forall("ja", implies(mem("ja", n),
    forall("sja", implies(successor("sja", "ja", "_"),
        forall("cja", implies(apply(v, "ja", "cja", "_"),
            exists("cja1", and(apply(v, "sja", "cja1", "_"),
                tm_step("delta", "cja", "cja1", "_")))))))))
$_db_body \v: \n: forall("xdn", forall("ydn",
    implies(apply(v, "xdn", "ydn", "_"), or(mem("xdn", n), eqv("xdn", n, "_")))))
$_base_body \v: forall("zp2", implies(empty("zp2", "_"), apply(v, "zp2", "c0", "_")))

$pet_expected forall("tra", forall("ska", forall("ca_new", forall("c0",
    forall("ka", forall("delta", forall("ca", forall("w",
    implies(function("tra", "_"),
    implies(_db_body("tra")("ka"),
    implies(omega("w", "_"),
    implies(mem("ka", "w"),
    implies(successor("ska", "ka", "_"),
    implies(forall("zp", implies(empty("zp", "_"), apply("tra", "zp", "c0", "_"))),
    implies(_sv_body("tra")("ka"),
    implies(tm_step("delta", "ca", "ca_new", "_"),
    implies(apply("tra", "ka", "ca", "_"),
        exists("trn", and(function("trn", "_"), and(
            _db_body("trn")("ska"),
            and(_base_body("trn"),
                and(apply("trn", "ska", "ca_new", "_"),
                    _sv_body("trn")("ska")))))))))))))))))))))))
$_ qed(phase1_step_extend_trace, pet_expected, "z")
$_ tap("phase1_step_extend_trace ok")

$trl_expected forall("tape", forall("a", forall("b", forall("i", forall("one",
    implies(unary_tape("tape", "a", "b", "_"),
    implies(mem("i", "a"),
    implies(num("one", 1, "_"),
        apply("tape", "i", "one", "_")))))))))
$_ qed(tape_read_low, trl_expected, "z")
$_ tap("tape_read_low ok")

$pb_expected forall("d", forall("q0", forall("z", forall("tape", forall("c0",
    implies(num("z", 0, "_"),
    implies(tm_config("c0", "q0", "z", "tape", "_"),
        phase1_ind("z", "d", "q0", "tape", "c0", "_"))))))))
$_ qed(phase1_base, pb_expected, "z")
$_ tap("phase1_base ok")

$ok true
