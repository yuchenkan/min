from derived import implies, forall, eqv, and, qed
from vocab.tm.tm import tm_config, tm_transition, tape_update, head_move, tm_step
from vocab.sets import ordered_pair
from vocab.functions import apply
from vocab.nat.nat import num, successor
from theorems.tm.tm.config_elim import config_elim
from theorems.tm.tm.transition_apply import transition_apply
from theorems.tm.tm.head_move_right import head_move_right
from theorems.tm.tm.head_move_left import head_move_left
from theorems.tm.tm.step_elim import step_elim
from theorems.tm.tm.config_eq_transfer import config_eq_transfer
from theorems.tm.tm.tape_update_unique import tape_update_unique
from theorems.tm.tm.config_decompose import config_decompose
from theorems.tm.tm.transition_unique import transition_unique
from theorems.tm.tm.headmove_right_elim import headmove_right_elim
from theorems.tm.tm.tape_update_eq_args import tape_update_eq_args
from vocab.functions import function
$ce config_elim("c", "q", "h", "tape", "inner", ["inner", "tape", "h", "q", "c"])
$ce_expected forall("c", forall("q", forall("h", forall("tape", forall("inner",
    implies(tm_config("c", "q", "h", "tape", "_"),
        implies(ordered_pair("inner", "h", "tape", "_"),
            ordered_pair("c", "q", "inner", "_"))))))))
$_ qed(ce, ce_expected, "z")
$_ tap("config_elim ok")

$ta transition_apply("d", "q", "r", "w", "dv", "qn", "inp", "dp", "out",
    ["inp", "qn", "dv", "w", "r", "q", "d"])
$ta_expected forall("d", forall("q", forall("r", forall("w", forall("dv", forall("qn", forall("inp",
    implies(tm_transition("d", "q", "r", "w", "dv", "qn", "_"),
        implies(ordered_pair("inp", "q", "r", "_"),
            forall("dp", implies(ordered_pair("dp", "dv", "qn", "_"),
                forall("out", implies(ordered_pair("out", "w", "dp", "_"),
                    apply("d", "inp", "out", "_"))))))))))))))
$_ qed(ta, ta_expected, "z")
$_ tap("transition_apply ok")

$hmr head_move_right("h", "hn", "d", ["d", "hn", "h"])
$hmr_expected forall("h", forall("hn", forall("d",
    implies(num("d", 1, "_"), implies(successor("hn", "h", "_"),
        head_move("h", "hn", "d", "_"))))))
$_ qed(hmr, hmr_expected, "z")
$_ tap("head_move_right ok")

$hml head_move_left("h", "hn", "d", ["d", "hn", "h"])
$hml_expected forall("h", forall("hn", forall("d",
    implies(num("d", 0, "_"), implies(successor("h", "hn", "_"),
        head_move("h", "hn", "d", "_"))))))
$_ qed(hml, hml_expected, "z")
$_ tap("head_move_left ok")

$se step_elim("d", "c1", "c2", "q", "h", "tape", "sym", "w", "dv", "qn", "hn", "tn",
    ["tn", "hn", "qn", "dv", "w", "sym", "tape", "h", "q", "c2", "c1", "d"])
$se_expected forall("d", forall("c1", forall("c2", forall("q", forall("h", forall("tape",
    forall("sym", forall("w", forall("dv", forall("qn", forall("hn", forall("tn",
    implies(tm_step("d", "c1", "c2", "_"),
    implies(tm_config("c1", "q", "h", "tape", "_"),
    implies(apply("tape", "h", "sym", "_"),
    implies(tm_transition("d", "q", "sym", "w", "dv", "qn", "_"),
    implies(tape_update("tn", "tape", "h", "w", "_"),
    implies(head_move("h", "hn", "dv", "_"),
        tm_config("c2", "qn", "hn", "tn", "_")))))))))))))))))))
$_ qed(se, se_expected, "z")
$_ tap("step_elim ok")

$cet_expected forall("c", forall("q1", forall("h1", forall("t1",
    forall("q2", forall("h2", forall("t2",
    implies(tm_config("c", "q1", "h1", "t1", "_"),
    implies(eqv("q1", "q2", "_"), implies(eqv("h1", "h2", "_"), implies(eqv("t1", "t2", "_"),
        tm_config("c", "q2", "h2", "t2", "_"))))))))))))
$_ qed(config_eq_transfer, cet_expected, "z")
$_ tap("config_eq_transfer ok")

$tuu_expected forall("t1", forall("t2", forall("tape", forall("h", forall("w",
    implies(tape_update("t1", "tape", "h", "w", "_"),
    implies(tape_update("t2", "tape", "h", "w", "_"),
        eqv("t1", "t2", "_"))))))))
$_ qed(tape_update_unique, tuu_expected, "z")
$_ tap("tape_update_unique ok")

$cd_expected forall("c", forall("q", forall("h", forall("tape",
    forall("q2", forall("h2", forall("tape2",
    implies(tm_config("c", "q", "h", "tape", "_"),
    implies(tm_config("c", "q2", "h2", "tape2", "_"),
        and(eqv("q", "q2", "_"), and(eqv("h", "h2", "_"), eqv("tape", "tape2", "_"))))))))))))
$_ qed(config_decompose, cd_expected, "z")
$_ tap("config_decompose ok")

$tu_expected forall("delta", forall("q", forall("sym", forall("w", forall("d", forall("qn",
    forall("w2", forall("d2", forall("qn2",
    implies(function("delta", "_"),
    implies(tm_transition("delta", "q", "sym", "w", "d", "qn", "_"),
    implies(tm_transition("delta", "q", "sym", "w2", "d2", "qn2", "_"),
        and(eqv("w", "w2", "_"), and(eqv("d", "d2", "_"), eqv("qn", "qn2", "_")))))))))))))))
$_ qed(transition_unique, tu_expected, "z")
$_ tap("transition_unique ok")

$hre_expected forall("h", forall("hn", forall("d", forall("ka", forall("ska", forall("d1",
    implies(head_move("h", "hn", "d", "_"),
    implies(eqv("h", "ka", "_"),
    implies(eqv("d", "d1", "_"),
    implies(num("d1", 1, "_"),
    implies(successor("ska", "ka", "_"),
        eqv("hn", "ska", "_"))))))))))))
$_ qed(headmove_right_elim, hre_expected, "z")
$_ tap("headmove_right_elim ok")

$tuea_expected forall("t1", forall("t2", forall("tape1", forall("h1", forall("w1",
    forall("tape2", forall("h2", forall("w2",
    implies(tape_update("t1", "tape1", "h1", "w1", "_"),
    implies(tape_update("t2", "tape2", "h2", "w2", "_"),
    implies(eqv("tape1", "tape2", "_"),
    implies(eqv("h1", "h2", "_"),
    implies(eqv("w1", "w2", "_"),
        eqv("t1", "t2", "_"))))))))))))))
$_ qed(tape_update_eq_args, tuea_expected, "z")
$_ tap("tape_update_eq_args ok")

$ok true
