$tct_expected forall("d", forall("c1", forall("c2", forall("c3",
    implies(eq("c1", "c3", "_"),
    implies(tm_step("d", "c3", "c2", "_"),
        tm_step("d", "c1", "c2", "_")))))))
$_ qed(tmstep_c1_transfer, tct_expected, "z")
$_ tap("tmstep_c1_transfer ok")

$_sv_body \v: \n: forall("ja", implies(mem("ja", n),
    forall("sja", implies(successor("sja", "ja", "_"),
        forall("cja", implies(apply(v, "ja", "cja", "_"),
            exists("cja1", and(apply(v, "sja", "cja1", "_"),
                tm_step("delta", "cja", "cja1", "_")))))))))
$_db_body \v: \n: forall("xdn", forall("ydn",
    implies(apply(v, "xdn", "ydn", "_"), or(mem("xdn", n), eq("xdn", n, "_")))))
$_base_body \v: forall("zp2", implies(num("zp2", 0, "_"), apply(v, "zp2", "c0", "_")))

$et_expected forall("tra", forall("ska", forall("ca_new", forall("c0",
    forall("ka", forall("delta", forall("ca", forall("w",
    implies(function("tra", "_"),
    implies(_db_body("tra")("ka"),
    implies(omega("w", "_"),
    implies(mem("ka", "w"),
    implies(successor("ska", "ka", "_"),
    implies(forall("zp", implies(num("zp", 0, "_"), apply("tra", "zp", "c0", "_"))),
    implies(_sv_body("tra")("ka"),
    implies(tm_step("delta", "ca", "ca_new", "_"),
    implies(apply("tra", "ka", "ca", "_"),
        exists("trn", and(function("trn", "_"), and(
            _db_body("trn")("ska"),
            and(_base_body("trn"),
                and(apply("trn", "ska", "ca_new", "_"),
                    _sv_body("trn")("ska")))))))))))))))))))))))
$_ qed(extend_trace, et_expected, "z")
$_ tap("extend_trace ok")

$str_expected forall("d", forall("c1", forall("c2", forall("z", forall("one",
    implies(tm_step("d","c1","c2","_"),
    implies(num("z",0,"_"),
    implies(successor("one","z","_"),
    implies(nat("z","_"),
        tm_reaches("d","c1","one","c2","_"))))))))))
$_ qed(step_to_reaches, str_expected, "z")
$_ tap("step_to_reaches ok")

